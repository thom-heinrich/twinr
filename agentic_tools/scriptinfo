def _scan_scripthistory(
    sh_path: Path,
    *,
    script_path: str,
    event_ids: Optional[Set[str]] = None,
) -> Tuple[List[Entry], Dict[str, Any]]:
    """
    Read scripthistory in a targeted way.

    The store can be large; for scriptinfo we primarily want:
      - all events for the requested script path, and
      - optionally, specific event IDs referenced via 1-hop links.
    """

    stats: Dict[str, Any] = {
        "source": "scripthistory",
        "path": str(sh_path),
        "scripts_scanned": 0,
        "events_scanned": 0,
        "events_emitted": 0,
        "emitted": 0,
    }
    if not sh_path.exists():
        return [], {**stats, "missing": True}
    try:
        doc = json.loads(sh_path.read_text(encoding="utf-8"))
    except Exception as exc:
        return [], {**stats, "error": f"json_parse_error: {exc}"}
    scripts = doc.get("scripts")
    if not isinstance(scripts, dict):
        return [], stats

    wanted_script = _norm_rel_path(script_path)
    want_ids = {str(x).strip() for x in (event_ids or set()) if str(x).strip()}

    out: List[Entry] = []

    def _emit_event(script_p: str, ev: Mapping[str, Any]) -> None:
        ev_id = str(ev.get("id") or "").strip()
        ts_utc = str(ev.get("created_at") or "").strip()
        ts_epoch = _parse_ts_epoch(ts_utc) or 0.0
        ev_type = str(ev.get("type") or "").strip()
        agent = str(ev.get("agent") or "").strip()
        comment = str(ev.get("comment") or "").strip()
        links = _normalize_links(
            [f"script:{script_p}", f"scripthistory_event:{ev_id}"]
            + _extract_links_from_text_fields([comment])
        )
        out.append(
            Entry(
                ts_utc=ts_utc,
                ts_epoch=ts_epoch,
                source="scripthistory_event",
                entry_id=ev_id,
                title=ev_type,
                summary=comment[:4000],
                status="",
                links=tuple(links),
                path=script_p,
                active=True,
                noise=False,
                extra=tuple(sorted({"agent": agent}.items())),
            )
        )
        stats["events_emitted"] += 1

    # Prefer direct key lookup (fast path), then fallback to scanning for a matching `path`.
    script_doc: Optional[Dict[str, Any]] = None
    for key in {wanted_script, f"./{wanted_script}"}:
        sd = scripts.get(key)
        if isinstance(sd, dict):
            script_doc = sd
            break
    if script_doc is None:
        for spath, sdoc in scripts.items():
            if not isinstance(sdoc, dict):
                continue
            if _norm_rel_path(str(sdoc.get("path") or spath)) == wanted_script:
                script_doc = sdoc
                break

    if script_doc is not None:
        stats["scripts_scanned"] += 1
        script_p = _norm_rel_path(str(script_doc.get("path") or wanted_script))
        events = script_doc.get("events")
        if isinstance(events, list):
            for ev in events:
                if not isinstance(ev, dict):
                    continue
                stats["events_scanned"] += 1
                _emit_event(script_p, ev)

    # Additionally, fetch any explicitly referenced event IDs (1-hop walk), even if not on the target script.
    if want_ids:
        for spath, sdoc in scripts.items():
            if not isinstance(sdoc, dict):
                continue
            script_p = _norm_rel_path(str(sdoc.get("path") or spath))
            if script_p == wanted_script and script_doc is not None:
                continue
            events = sdoc.get("events")
            if not isinstance(events, list):
                continue
            for ev in events:
                if not isinstance(ev, dict):
                    continue
                ev_id = str(ev.get("id") or "").strip()
                if ev_id not in want_ids:
                    continue
                stats["scripts_scanned"] += 1
                stats["events_scanned"] += 1
                _emit_event(script_p, ev)

    stats["emitted"] = len(out)
    return out, stats


def _scan_findings_index(st_root: Path) -> Tuple[List[Entry], Dict[str, Any]]:
    index_path = (st_root / "findings" / "index.yml").resolve()
    stats: Dict[str, Any] = {
        "source": "findings",
        "path": str(index_path),
        "items": 0,
        "emitted": 0,
    }
    if not index_path.exists():
        return [], {**stats, "missing": True}
    try:
        doc = _yaml_safe_load_path(index_path, max_bytes=5 * 1024 * 1024) or {}
    except Exception as exc:
        return [], {**stats, "error": f"yaml_parse_error: {exc}"}
    items = doc.get("findings") if isinstance(doc, dict) else None
    out: List[Entry] = []
    if isinstance(items, list):
        for it in items:
            if not isinstance(it, dict):
                continue
            fid = str(it.get("finding_id") or "").strip()
            ts_utc = str(it.get("ts_utc") or "").strip()
            ts_epoch = _parse_ts_epoch(ts_utc) or 0.0
            title = str(it.get("title") or "").strip()
            summary = str(it.get("summary") or "").strip()
            status_raw = str(it.get("status") or "").strip()
            status = status_raw
            sev = str(it.get("severity") or "").strip()
            if sev:
                status = f"{status} ({sev})" if status else sev
            addressed = bool(it.get("addressed") is True)
            active = (not addressed) and (
                status_raw.strip().lower() not in _CLOSED_FINDING_STATUSES
            )
            target_path = _norm_rel_path(str(it.get("target_path") or "").strip())
            raw_links = it.get("links") if isinstance(it.get("links"), list) else []
            links = _normalize_links(
                list(raw_links)
                + ([f"finding:{fid}"] if fid else [])
                + _extract_links_from_text_fields([title, summary])
                + ([f"script:{target_path}"] if target_path else [])
            )
            out.append(
                Entry(
                    ts_utc=ts_utc,
                    ts_epoch=ts_epoch,
                    source="finding",
                    entry_id=fid,
                    title=title,
                    summary=summary[:4000],
                    status=status,
                    links=tuple(links),
                    path=target_path,
                    active=bool(active),
                    noise=False,
                    extra=tuple(
                        sorted(
                            {
                                "mode": it.get("mode"),
                                "scope": it.get("scope"),
                                "severity": sev,
                                "status_raw": status_raw,
                                "addressed": addressed,
                            }.items()
                        )
                    ),
                )
            )
            stats["items"] += 1
    stats["emitted"] = len(out)
    return out, stats


def _iter_ccr_files(reviews_dir: Path) -> List[Path]:
    out: List[Path] = []
    if reviews_dir.exists() and reviews_dir.is_dir():
        out.extend(
            sorted(
                [
                    p
                    for p in reviews_dir.iterdir()
                    if p.is_file() and p.name.startswith("CCR")
                ]
            )
        )
        arch = reviews_dir / "__archive__"
        if arch.exists() and arch.is_dir():
            out.extend(
                sorted(
                    [
                        p
                        for p in arch.iterdir()
                        if p.is_file() and p.name.startswith("CCR")
                    ]
                )
            )
    return out


