        except Exception:
            continue
        stats["yaml_loaded"] += 1
        if not isinstance(doc, dict):
            continue
        fr = doc.get("fixreport")
        if not isinstance(fr, dict):
            continue
        bf_id = str(fr.get("bf_id") or p.stem).strip()
        ts_utc = str(
            fr.get("ts_utc")
            or doc.get("tessairact_meta", {}).get("created_at_utc")
            or ""
        ).strip()
        ts_epoch = _parse_ts_epoch(ts_utc) or 0.0
        title = str(
            doc.get("narrative", {}).get("title")
            if isinstance(doc.get("narrative"), dict)
            else fr.get("title") or ""
        ).strip()
        summary = str(
            doc.get("narrative", {}).get("summary")
            if isinstance(doc.get("narrative"), dict)
            else fr.get("summary") or ""
        ).strip()
        status = str(fr.get("severity") or "").strip()
        links_doc, _warns = extract_links_from_doc(doc)
