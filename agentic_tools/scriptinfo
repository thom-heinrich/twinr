        out.append(
            Entry(
                ts_utc=ts_utc,
                ts_epoch=ts_epoch,
                source="fixreport",
                entry_id=bf_id,
                title=title,
                summary=summary[:4000],
                status=status,
                links=tuple(links),
                path=target_path,
                active=True,
