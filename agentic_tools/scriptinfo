def _scan_tasks(board_path: Path) -> Tuple[List[Entry], Dict[str, Any]]:
    stats: Dict[str, Any] = {
        "source": "tasks",
        "path": str(board_path),
        "tasks": 0,
        "tasks_active": 0,
        "tasks_closed": 0,
        "events": 0,
        "events_noise": 0,
        "events_no_text": 0,
        "emitted": 0,
    }
    if not board_path.exists():
        return [], {**stats, "missing": True}
    try:
        doc = json.loads(board_path.read_text(encoding="utf-8"))
    except Exception as exc:
        return [], {**stats, "error": f"json_parse_error: {exc}"}

    out: List[Entry] = []

    task_active: Dict[str, bool] = {}

    tasks = doc.get("tasks")
    if isinstance(tasks, dict):
        for tid, t in tasks.items():
            if not isinstance(t, dict):
                continue
            task_id = str(t.get("id") or tid).strip()
            ts_utc = str(t.get("updated_at") or t.get("created_at") or "").strip()
            ts_epoch = _parse_ts_epoch(ts_utc) or 0.0
            title = str(t.get("title") or "").strip()
            desc = str(t.get("description") or "").strip()
            status_raw = str(t.get("status") or "").strip()
            column_raw = str(t.get("column") or "").strip()
            status = status_raw
            column = column_raw
            if column:
                status = f"{status} ({column})" if status else column
            active = (column_raw.strip().lower() not in _CLOSED_TASK_COLUMNS) and (
                status_raw.strip().lower() not in _CLOSED_TASK_STATUSES
            )
            task_active[task_id] = bool(active)
            raw_links = t.get("links") if isinstance(t.get("links"), list) else []
            links = _normalize_links(
                list(raw_links)
                + [f"task:{task_id}"]
                + _extract_links_from_text_fields([title, desc])
            )
            out.append(
                Entry(
                    ts_utc=ts_utc or "",
                    ts_epoch=ts_epoch,
                    source="task",
                    entry_id=task_id,
                    title=title,
                    summary=desc[:4000],
                    status=status,
                    links=tuple(links),
                    path="",
                    active=bool(active),
                    noise=False,
                    extra=tuple(
                        sorted(
                            {
                                "priority": t.get("priority"),
                                "assignee": t.get("assignee"),
                                "column": column_raw,
                                "status_raw": status_raw,
                            }.items()
                        )
                    ),
                )
            )
            stats["tasks"] += 1
            if active:
                stats["tasks_active"] += 1
            else:
                stats["tasks_closed"] += 1

    events = doc.get("events")
    if isinstance(events, list):
        for ev in events:
            if not isinstance(ev, dict):
                continue
            ev_id = str(ev.get("id") or "").strip()
            task_id = str(ev.get("task_id") or "").strip()
            kind = str(ev.get("kind") or "").strip()
            ts_utc = str(ev.get("ts") or "").strip()
            ts_epoch = _parse_ts_epoch(ts_utc) or 0.0
            payload = ev.get("payload")
            actor = str(ev.get("actor") or "").strip()
            payload_links = _extract_links_from_text_fields([payload])
            links = _normalize_links([f"task:{task_id}"] + payload_links)
            title = kind or "task_event"
            summary = ""
            if (
                isinstance(payload, dict)
                and "text" in payload
                and isinstance(payload["text"], str)
            ):
                summary = payload["text"]
            is_system = kind.startswith("task_") or kind in _NOISE_TASK_EVENT_KINDS
            has_text = bool(str(summary or "").strip())
            noise = bool(is_system or not has_text)
            if noise and is_system:
                stats["events_noise"] += 1
            elif noise and not has_text:
                stats["events_no_text"] += 1
            active = bool(task_active.get(task_id, False))

            out.append(
                Entry(
                    ts_utc=ts_utc,
                    ts_epoch=ts_epoch,
                    source="task_event",
                    entry_id=ev_id or f"{task_id}:{kind}",
                    title=title,
                    summary=str(summary or "")[:4000],
                    status="",
                    links=tuple(links),
                    path="",
                    active=active,
                    noise=noise,
                    extra=tuple(
                        sorted(
                            {
                                "task_id": task_id,
                                "actor": actor,
                                "kind": kind,
                                "system": bool(is_system),
                            }.items()
                        )
                    ),
                )
            )
            stats["events"] += 1

    stats["emitted"] = len(out)
    return out, stats


