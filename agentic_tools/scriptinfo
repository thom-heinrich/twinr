def _emit_json(payload: Mapping[str, Any], *, pretty: bool) -> None:
    payload_out = enrich_payload_with_hints(payload, tool="scriptinfo")
    # NOTE: We intentionally keep insertion order (no sort_keys) for readability in
    # `--json-pretty` mode (wiki + overview should appear near the top). Payload
    # assembly is deterministic, so this remains stable across runs.
    sys.stdout.write(json.dumps(dict(payload_out), indent=2 if pretty else None) + "\n")


def _emit_markdown(text: str) -> None:
    out = str(text or "")
    if not out.endswith("\n"):
        out += "\n"
    sys.stdout.write(out)


def _extract_wiki_summary_lines(wiki_lines: Sequence[str]) -> List[str]:
    """
    Extract the content of the wiki "Summary" section.

    Returns Markdown lines (without the "## Summary" heading line).
    """
    heading_re = re.compile(r"^(?P<h>#{1,6})\s+(?P<t>.+?)\s*$")
    summary_heads = {"summary", "zusammenfassung", "kurzfassung"}

    start: Optional[int] = None
    for i, line in enumerate(list(wiki_lines)):
        m = heading_re.match(str(line))
        if not m:
            continue
        level = len(m.group("h"))
        if level != 2:
            continue
        title = m.group("t").strip().lower()
        if title in summary_heads:
            start = i + 1
            break

    if start is None:
        return []

    out: List[str] = []
    for line in list(wiki_lines)[start:]:
        m = heading_re.match(str(line))
        if m and len(m.group("h")) <= 2:
            break
        out.append(str(line))

    # Trim outer blank lines.
    while out and not out[0].strip():
        out.pop(0)
    while out and not out[-1].strip():
        out.pop()
    return out


def _extract_wiki_h2_section_lines(
    wiki_lines: Sequence[str], *, headings: Set[str]
) -> List[str]:
    """
    Extract the content of a H2 section by heading title.

    `headings` is matched case-insensitively (after stripping).
    Returns Markdown lines without the H2 heading line.
    """
    heading_re = re.compile(r"^(?P<h>#{1,6})\s+(?P<t>.+?)\s*$")
    want = {str(h).strip().lower() for h in headings if str(h).strip()}
    if not want:
        return []

    start: Optional[int] = None
    for i, line in enumerate(list(wiki_lines)):
        m = heading_re.match(str(line))
        if not m:
            continue
        level = len(m.group("h"))
        if level != 2:
            continue
        title = m.group("t").strip().lower()
        if title in want:
            start = i + 1
            break

    if start is None:
        return []

    out: List[str] = []
    for line in list(wiki_lines)[start:]:
        m = heading_re.match(str(line))
        if m and len(m.group("h")) <= 2:
            break
        out.append(str(line))

    # Trim outer blank lines.
    while out and not out[0].strip():
        out.pop(0)
    while out and not out[-1].strip():
        out.pop()
    return out


def _render_summary_markdown(payload: Mapping[str, Any]) -> str:
    """
    Render the `--summary` output as Markdown-only (no JSON noise).

    Contents (Markdown-only; no JSON noise):
    - Wiki article (leading; excludes Open Questions + Safety* unless --extensive)
    - LLM meta summary sections (single call across all artifacts)
    - Final hint on how to get full context (JSON)
    """
    script_path = (
        str(
            (
                (payload.get("script") or {})
                if isinstance(payload.get("script"), dict)
                else {}
            ).get("path")
            or ""
        )
    ).strip()

    wiki = payload.get("wiki") if isinstance(payload.get("wiki"), dict) else {}
    out_lines: List[str] = []

    wiki_lines = wiki.get("lines") if isinstance(wiki, dict) else None
    if isinstance(wiki_lines, list) and [str(x).strip() for x in wiki_lines if str(x).strip()]:
        # Emit the wiki content as-is (in summary mode this is the "leading" wiki summary).
        out_lines.extend([str(x) for x in wiki_lines])
        if out_lines and out_lines[-1].strip():
            out_lines.append("")
    else:
        title = str(wiki.get("title") or script_path).strip() or script_path or "scriptinfo"
        out_lines.append(f"# {title}".rstrip())
        out_lines.append("")
        if wiki.get("ok") is False:
            reason = str(wiki.get("reason") or "unavailable").strip()
            path = str(wiki.get("path") or "").strip()
            msg = f"_No wiki article available ({reason})._"
            if path:
                msg = f"{msg} (`{path}`)"
            out_lines.append(msg)
        else:
            out_lines.append("_No wiki content available._")
        out_lines.append("")

    llm_summary = (
        payload.get("llm_summary") if isinstance(payload.get("llm_summary"), dict) else None
    )
    out_lines.append("---")
    out_lines.append("")

    def _emit_section(title: str, paras: Optional[Sequence[str]]) -> None:
        out_lines.append(f"## {title}".rstrip())
        out_lines.append("")
        items = [str(p).replace("\r", "").strip() for p in (paras or []) if str(p).strip()]
        if not items:
            out_lines.append("_No summary text available._")
            out_lines.append("")
            return
        for p in items:
            out_lines.append(p)
            out_lines.append("")

    if llm_summary:
        b = str(llm_summary.get("backend") or "").strip()
        m = str(llm_summary.get("model") or "").strip()
        if b:
            if m:
                out_lines.append(f"_LLM backend:_ `{b}` (`{m}`)".rstrip())
            else:
                out_lines.append(f"_LLM backend:_ `{b}`".rstrip())
            out_lines.append("")
        attempts = llm_summary.get("attempts")
        if isinstance(attempts, list) and len(attempts) > 1:
            fails = []
            for a in attempts:
                if not isinstance(a, dict):
                    continue
                if a.get("ok") is True:
                    continue
                bb = str(a.get("backend") or "").strip()
                ee = str(a.get("error") or "").strip()
                if bb and ee:
                    fails.append(f"{bb}: {ee[:180]}")
            if fails:
                out_lines.append("_Failover:_ " + "; ".join(fails[:3]))
                out_lines.append("")

    if not llm_summary:
        _emit_section(
            "Evolution",
            [
                "No LLM summary available. Run with `--summary` and ensure an LLM backend is configured (DeepInfra/OpenAI/OpenRouter)."
            ],
        )
        _emit_section("Known Challenges", [])
        _emit_section("Open Work", [])
        _emit_section("Science", [])
    elif llm_summary.get("ok") is not True:
        err = str(llm_summary.get("error") or "unknown_error").strip()
        _emit_section("Evolution", [f"LLM summary failed: {err}"])
        _emit_section("Known Challenges", [])
        _emit_section("Open Work", [])
        _emit_section("Science", [])
    else:
        sections = llm_summary.get("sections")
        if not isinstance(sections, dict):
            sections = {}

        _emit_section("Evolution", sections.get("evolution"))
        _emit_section("Known Challenges", sections.get("known_challenges"))
        _emit_section("Open Work", sections.get("open_work"))
        _emit_section("Science", sections.get("science"))

    if script_path:
        out_lines.append("---")
        out_lines.append(
            f"Wenn du **MEHR WISSEN WILLST**, nutz `scriptinfo --no-llm {script_path}` (full JSON timeline/overview)."
        )
    return "\n".join(out_lines).rstrip() + "\n"

def _fail_json(
    code: str,
    detail: str,
    *,
    status: int = 1,
    pretty: bool,
    error_code: str = "",
    retryable: Optional[bool] = None,
    extra: Optional[Mapping[str, Any]] = None,
) -> NoReturn:
    normalized_error = str(code or "")
    normalized_error_code = (
        str(error_code or "").strip()
        or _ERROR_CODE_TOKEN_RE.sub("_", normalized_error).strip("_").upper()
        or "UNKNOWN_ERROR"
    )
    if retryable is None:
        token = normalized_error_code.upper()
        retryable = (
            token in {"LOCK_TIMEOUT", "TIMEOUT", "IO_ERROR"}
            or "TIMEOUT" in token
            or "LOCK" in token
        )
    out: Dict[str, Any] = {
        "ok": False,
        "error": normalized_error,
        "error_code": normalized_error_code,
        "detail": str(detail),
        "retryable": bool(retryable),
    }
    if extra:
        out.update(dict(extra))
    _emit_json(out, pretty=pretty)
    raise SystemExit(int(status))


def _parse_ts_epoch(ts: str) -> Optional[float]:
    s = str(ts or "").strip()
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def _norm_rel_path(raw: str) -> str:
    s = str(raw or "").strip()
    if not s:
        return ""
    p = Path(s)
    if p.is_absolute():
        try:
            rel = p.resolve().relative_to(REPO_ROOT)
        except Exception:
            return ""
        return str(rel.as_posix())

    rel = str(p.as_posix())
    while rel.startswith("./"):
        rel = rel[2:]
    rel = rel.strip("/")
    return rel


def _is_safe_repo_rel_path(path: str) -> bool:
    """
    Enforce a safe repo-relative path without traversal.

    We intentionally fail-closed on '..' segments to prevent path traversal when
    resolving filesystem paths (e.g. exists checks, indexer lookups).
    """
    s = str(path or "").strip()
    if not s:
        return False
    parts = Path(s).parts
    return not any(p == ".." for p in parts)


def _best_effort_repo_rel_from_store_path(p: Path) -> str:
    """
    Best-effort mapping from a physical store path to a repo-relative logical path.

    Stores can live outside REPO_ROOT (e.g. on an offload mount) while still
    containing the substring "artifacts/stores/...". For link tokens we prefer
    stable repo-relative logical paths when possible.
    """
    try:
        return str(p.resolve().relative_to(REPO_ROOT).as_posix())
    except Exception:
        pass
    s = p.as_posix()
    needle = "artifacts/stores/"
    idx = s.rfind(f"/{needle}")
    if idx >= 0:
        return s[idx + 1 :].lstrip("/")
    idx2 = s.rfind(needle)
    if idx2 >= 0:
        return s[idx2:].lstrip("/")
    return ""


def _normalize_links(tokens: Sequence[str]) -> List[str]:
    out: List[str] = []
    for tok in tokens:
        s = str(tok or "").strip()
        if not s or ":" not in s:
            continue
        kind_raw, ident_raw = s.split(":", 1)
        kind = kind_raw.strip().lower()
        ident = ident_raw.strip()
        if not kind or not ident:
            continue
        if kind == "script":
            ident = _norm_rel_path(ident)
            if not ident or not _is_safe_repo_rel_path(ident):
                continue
        token_norm = f"{kind}:{ident}"
        if not _LINK_TOKEN_RE.fullmatch(token_norm):
            continue
        out.append(token_norm)
    return dedupe_link_tokens(out)


def _extract_links_from_text_fields(fields: Iterable[Any]) -> List[str]:
    texts: List[str] = []
    for v in fields:
        if v is None:
            continue
        if isinstance(v, str):
            texts.append(v)
        elif isinstance(v, (int, float, bool)):
            continue
        else:
            # Best-effort: stringify small dict/list payloads.
            try:
                s = json.dumps(v, sort_keys=True)
            except Exception:
                s = str(v)
            if s and len(s) <= 4000:
                texts.append(s)
    return extract_link_tokens_from_texts(texts)


def _read_text_limited(path: Path, *, max_bytes: int) -> str:
    if max_bytes > 0:
        try:
            sz = int(path.stat().st_size)
        except Exception:
            sz = -1
        if sz >= 0 and sz > max_bytes:
            raise ValueError(f"file_too_large: {path} ({sz} bytes > {max_bytes})")
    return path.read_text(encoding="utf-8")


def _yaml_safe_load_path(path: Path, *, max_bytes: int) -> Any:
    class _LimitedSafeLoader(yaml.SafeLoader):
        def __init__(self, stream) -> None:
            super().__init__(stream)
            self._alias_count = 0
            self._depth = 0

        def compose_node(self, parent, index):  # type: ignore[override]
            max_aliases = int(os.environ.get("CAIA_SCRIPTINFO_MAX_YAML_ALIASES", "200"))
            max_depth = int(os.environ.get("CAIA_SCRIPTINFO_MAX_YAML_DEPTH", "2000"))
            if max_depth > 0:
                self._depth += 1
                if self._depth > max_depth:
                    raise yaml.YAMLError(
                        f"yaml_max_depth_exceeded: {self._depth} > {max_depth}"
                    )
            try:
                if max_aliases > 0 and self.check_event(yaml.events.AliasEvent):
                    self._alias_count += 1
                    if self._alias_count > max_aliases:
                        raise yaml.YAMLError(
                            f"yaml_alias_limit_exceeded: {self._alias_count} > {max_aliases}"
                        )
                return super().compose_node(parent, index)
            finally:
                if max_depth > 0:
                    self._depth -= 1

    text = _read_text_limited(path, max_bytes=max_bytes)
    max_aliases = int(os.environ.get("CAIA_SCRIPTINFO_MAX_YAML_ALIASES", "200"))
    max_depth = int(os.environ.get("CAIA_SCRIPTINFO_MAX_YAML_DEPTH", "2000"))
    if max_aliases <= 0 and max_depth <= 0:
        return yaml.safe_load(text)
    return yaml.load(text, Loader=_LimitedSafeLoader)


@dataclass(frozen=True)
class Entry:
    ts_utc: str
    ts_epoch: float
    source: str
    entry_id: str
    title: str
    summary: str
    status: str
    links: Tuple[str, ...]
    path: str
    active: bool
    noise: bool
    extra: Tuple[Tuple[str, Any], ...]

    def to_dict(
        self,
        *,
        extensive: bool,
    ) -> Dict[str, Any]:
        if not extensive:
            # Baseline mode: prioritize human-readable text + time (minimal keys).
            return {
                "ts_utc": self.ts_utc,
                "source": self.source,
                "id": self.entry_id,
                "title": self.title,
                "summary": self.summary,
            }

        full_links = list(self.links)
        links_out = full_links

        out: Dict[str, Any] = {
            "ts_utc": self.ts_utc,
            "source": self.source,
            "id": self.entry_id,
            "title": self.title,
            "summary": self.summary,
            "status": self.status,
            "path": self.path,
            "active": bool(self.active),
            "noise": bool(self.noise),
            "links": links_out,
            "links_total": int(len(full_links)),
            "links_omitted": 0,
        }
        if self.extra:
            out["extra"] = {k: v for k, v in self.extra}
        return out

    def has_link(self, token: str) -> bool:
        return token in self.links

    def has_any_link(self, tokens: Set[str]) -> bool:
        if not tokens:
            return False
        for t in self.links:
            if t in tokens:
                return True
        return False


