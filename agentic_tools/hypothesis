def load_store() -> Dict[str, Any]:
    """Load the hypothesis store from YAML, or create a new one."""
    if not STORE_PATH.exists():
        logging.info(
            "Hypothesis store %s does not exist, using in-memory default until first write.",
            STORE_PATH,
        )
        return _default_store()

    try:
        with STORE_PATH.open("r", encoding="utf-8") as fh:
            data = yaml.safe_load(fh) or {}
    except yaml.YAMLError as exc:
        _emit_json(
            _error_payload(
                "invalid_yaml",
                f"Failed to parse hypothesis store YAML: {exc}",
                file=str(STORE_PATH),
            )
        )
        sys.exit(1)

    if not isinstance(data, Mapping):
        _emit_json(
            _error_payload(
                "invalid_store",
                "Hypothesis store root must be a mapping.",
                file=str(STORE_PATH),
            )
        )
        sys.exit(1)

    store = _ensure_store_shape(data)
    logging.info(
        "Loaded hypothesis store from %s (schema_version=%s, hypotheses=%s, evidence=%s).",
        STORE_PATH,
        store.get("schema_version"),
        len(store.get("hypotheses", {})),
        len(store.get("evidence", {})),
    )
    return store


def save_store(store: Mapping[str, Any]) -> None:
    """Persist the hypothesis store atomically to YAML."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    mutable = dict(store)
    mutable["updated_at"] = utc_now_iso()
    tmp_path = STORE_PATH.with_suffix(".yml.tmp")
    logging.info("Saving hypothesis store to %s", STORE_PATH)
    with tmp_path.open("w", encoding="utf-8") as fh:
        yaml.safe_dump(mutable, fh, sort_keys=True)
    os.replace(tmp_path, STORE_PATH)


def _load_scripthistory_store() -> Dict[str, Any]:
    """Load the scripthistory JSON store from the repo root.

    This is used by sync-scripthistory to discover references from script
    evolution events to hypothesis ids (e.g. \"H00001\" inside comments).
    """
    if not SCRIPTHISTORY_PATH.exists():
        _emit_json(
            _error_payload(
                "scripthistory_missing",
                f"scripthistory store not found at {SCRIPTHISTORY_PATH}",
                file=str(SCRIPTHISTORY_PATH),
            )
        )
        sys.exit(1)

    try:
        with SCRIPTHISTORY_PATH.open("r", encoding="utf-8") as fh:
            data = json.load(fh)
    except json.JSONDecodeError as exc:
        _emit_json(
            _error_payload(
                "scripthistory_invalid_json",
                f"Failed to parse scripthistory store JSON: {exc}",
                file=str(SCRIPTHISTORY_PATH),
            )
        )
        sys.exit(1)

    if not isinstance(data, Mapping):
        _emit_json(
            _error_payload(
                "scripthistory_invalid_store",
                "scripthistory store root must be a JSON object.",
                file=str(SCRIPTHISTORY_PATH),
            )
        )
        sys.exit(1)

    scripts = data.get("scripts")
    if scripts is None or not isinstance(scripts, Mapping):
        _emit_json(
            _error_payload(
                "scripthistory_missing_scripts",
                "scripthistory store missing 'scripts' mapping.",
                file=str(SCRIPTHISTORY_PATH),
            )
        )
        sys.exit(1)

    return data


def _generate_id(store: Mapping[str, Any], key: str, prefix: str) -> Tuple[str, Dict[str, Any]]:
    """Generate a new human-friendly identifier and update the counter.

    Returns the new id and a mutated store dict.
    """
    mutable = dict(store)
    next_id = int(mutable.get(key, 1))
    existing_ids: Iterable[str]
    if prefix == "H":
        existing_ids = mutable.get("hypotheses", {}).keys()
    elif prefix == "E":
        existing_ids = mutable.get("evidence", {}).keys()
    else:
        existing_ids = (ev.get("id") for ev in mutable.get("events", []))

    existing_set = {str(eid) for eid in existing_ids if eid is not None}
    while True:
        candidate = f"{prefix}{next_id:05d}"
        if candidate not in existing_set:
            mutable[key] = next_id + 1
            return candidate, mutable
        next_id += 1


