                    "config/",
                    "clickhouse/",
                    "contracts/",
                    "schemas/",
                    "docs/",
                    "research/",
                    "llm/",
                    "artifacts/llm/",
                    "artifacts/evaluations/",
                    "artifacts/audit/",
                    "__ignore__/",
                )
            )
            for m in matches
        ):
            continue
        candidates.extend(matches[: max(1, min(5, max_paths))])

    candidates = _dedupe_keep_order(candidates)
    candidates.sort(key=_path_rank)
    return candidates[:max_paths]


