def _load_ssot_entries() -> Dict[str, Dict[str, Any]]:
    """Load SSOT registry entries from .ssot.json (best-effort)."""
    if not SSOT_PATH.is_file():
        return {}
    try:
        raw = json.loads(SSOT_PATH.read_text(encoding="utf-8")) or {}
    except Exception:
        return {}
    entries = raw.get("entries") if isinstance(raw, Mapping) else None
    if not isinstance(entries, Mapping):
        return {}
    out: Dict[str, Dict[str, Any]] = {}
    for k, v in entries.items():
        if not isinstance(k, str) or not isinstance(v, Mapping):
            continue
        out[k] = dict(v)
    return out


def _build_ssot_topic_index(entries: Mapping[str, Mapping[str, Any]]) -> Dict[str, List[str]]:
    """Build topic -> [entry_key] index from SSOT entries (best-effort)."""
    idx: Dict[str, List[str]] = {}

    def add(topic: str, *, entry_key: str) -> None:
        t = str(topic or "").strip()
        if not t:
            return
        idx.setdefault(t, []).append(entry_key)
        tl = t.lower()
        if tl and tl != t:
            idx.setdefault(tl, []).append(entry_key)
        # Simple delimiter normalization helps bridge e.g. delta-leadlag vs delta_leadlag.
        if "-" in t:
            idx.setdefault(t.replace("-", "_"), []).append(entry_key)
        if "_" in t:
            idx.setdefault(t.replace("_", "-"), []).append(entry_key)

    for key, entry in entries.items():
        if not isinstance(key, str) or not isinstance(entry, Mapping):
            continue
        # 1) key itself is often a topic-ish name (analytics.*)
        add(key, entry_key=key)
        # Also index the final component (e.g. "delta-leadlag" from service.caia-analytics-delta-leadlag).
        add(key.rsplit(".", 1)[-1], entry_key=key)

        meta = entry.get("metadata")
        if isinstance(meta, Mapping):
            t = meta.get("topic")
            if isinstance(t, str) and t.strip():
                add(t.strip(), entry_key=key)
            ts = meta.get("topics")
            if isinstance(ts, list):
                for item in ts:
                    if isinstance(item, str) and item.strip():
                        add(item.strip(), entry_key=key)
            inst = meta.get("instrument")
            if isinstance(inst, str) and inst.strip():
                add(inst.strip(), entry_key=key)

            exec_path = meta.get("exec_path")
            if isinstance(exec_path, str) and exec_path.strip():
                ep = exec_path.strip()
                add(ep, entry_key=key)
                add(Path(ep).name, entry_key=key)
                stem = Path(ep).stem
                if stem:
                    add(stem, entry_key=key)
                    for pref in ("analytics_", "regime_", "execution_", "ch_sink_", "sink_", "caia_"):
                        if stem.startswith(pref) and stem != pref:
                            add(stem[len(pref) :], entry_key=key)

            unit = meta.get("unit")
            if isinstance(unit, str) and unit.strip():
                u = unit.strip()
                add(u, entry_key=key)
                stem = Path(u).stem
                if stem:
                    add(stem, entry_key=key)
                    if stem.startswith("caia-") and stem != "caia-":
                        add(stem[len("caia-") :], entry_key=key)
                    if stem.startswith("caia_") and stem != "caia_":
                        add(stem[len("caia_") :], entry_key=key)

        tags = entry.get("tags")
        if isinstance(tags, list):
            for tag in tags:
                if isinstance(tag, str) and tag.strip():
                    add(tag.strip(), entry_key=key)
    # Stable de-dupe each list
    for topic, keys in list(idx.items()):
        idx[topic] = _dedupe_keep_order(keys)
    return idx


def _ssot_script_anchor_paths_for_topics(
    topics: Iterable[str],
    *,
    repo_files_set: set[str],
    by_basename: Mapping[str, List[str]],
    max_paths: int,
) -> List[str]:
    """Resolve SSOT topic(s) -> repo file paths suitable as script anchors."""
    entries = _load_ssot_entries()
    if not entries:
        return []
    topic_index = _build_ssot_topic_index(entries)

    candidates: List[str] = []
    for topic in topics:
        t = str(topic or "").strip()
        if not t:
            continue
        for entry_key in (topic_index.get(t) or []):
            entry = entries.get(entry_key)
            if not isinstance(entry, Mapping):
                continue
            paths = entry.get("paths") or []
            if isinstance(paths, list):
                for p in paths:
                    if isinstance(p, str) and p.strip():
                        candidates.append(p.strip())
            meta = entry.get("metadata")
            if isinstance(meta, Mapping):
                exec_path = meta.get("exec_path")
                if isinstance(exec_path, str) and exec_path.strip():
                    candidates.append(exec_path.strip())

    resolved: List[str] = []
    seen: set[str] = set()
    for raw in candidates:
        rp = _resolve_repo_path(raw, repo_files_set=repo_files_set, by_basename=by_basename)
        if rp is None:
            continue
        if not _is_reasonable_script_anchor_path(rp):
            continue
        if rp in seen:
            continue
        seen.add(rp)
        resolved.append(rp)

    resolved.sort(key=_path_rank)
    if max_paths > 0:
        resolved = resolved[:max_paths]
    return resolved


