        "schema_version": store.get("schema_version", 1),
    }
    _emit_json(payload)


def cmd_create(args: argparse.Namespace) -> None:
    """Create a new hypothesis with initial metadata."""
    scope = args.scope
    status = args.status
    _validate_scope(scope)
    _validate_status(status)
    confidence = _clamp_confidence(args.confidence)
    metadata = _parse_json_arg(args.metadata_json, "--metadata-json")
    related = _parse_json_arg(args.related_json, "--related-json")
    links = [str(x).strip() for x in (getattr(args, "links", None) or []) if str(x).strip()]
    scripts = [str(x).strip() for x in (getattr(args, "scripts", None) or []) if str(x).strip()]
    if scripts:
        links = list(links) + [f"script:{p}" for p in scripts]
    text_links = extract_link_tokens_from_texts([str(args.title or ""), str(args.statement or "")])
    links = list(links) + list(text_links)
    bad_links = [x for x in links if not LINK_TOKEN_RE.fullmatch(x)]
    if bad_links:
        _emit_json(
            _error_payload(
                "invalid_link",
                "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
                bad=bad_links[:20],
            )
        )
        sys.exit(1)

    # Validate/normalize script anchors and enforce "script:" presence.
    repo_files = _git_ls_files(REPO_ROOT)
    if not repo_files:
        _emit_json(
            _error_payload(
                "repo_index_failed",
                "Failed to index repo files via git ls-files (repo might not be a git checkout).",
                repo_root=str(REPO_ROOT),
            )
        )
        sys.exit(1)

    repo_files_set = set(repo_files)
    by_basename: Dict[str, List[str]] = {}
    for p in repo_files:
        by_basename.setdefault(Path(p).name, []).append(p)

    normalized_links: List[str] = []
    invalid_script_links: List[Dict[str, str]] = []
    for token in links:
        if not token.startswith("script:"):
            normalized_links.append(token)
            continue
        raw_path = token.split("script:", 1)[1].strip()
        if raw_path.startswith("/"):
            invalid_script_links.append({"token": token, "reason": "absolute_path"})
            continue
        rp = _resolve_repo_path(raw_path, repo_files_set=repo_files_set, by_basename=by_basename)
        if rp is None:
            invalid_script_links.append({"token": token, "reason": "path_not_found"})
            continue
        if not _is_reasonable_script_anchor_path(rp):
            invalid_script_links.append({"token": token, "reason": "path_not_reasonable"})
            continue
        normalized_links.append(f"script:{rp}")

    if invalid_script_links:
        _emit_json(
            _error_payload(
                "invalid_script_links",
                "One or more script:<path> links do not resolve to a repo file.",
                invalid_script_links=invalid_script_links[:20],
            )
        )
        sys.exit(1)

    if not any(x.startswith("script:") for x in normalized_links):
        # Fallback: infer anchors from topic -> SSOT.paths.
        topic_candidates: List[str] = []
        if args.topics:
            topic_candidates.extend([str(t).strip() for t in args.topics if str(t).strip()])
        topic_candidates.extend(TOPIC_RE.findall(f"{args.title} {args.statement}"))
        topic_candidates = _dedupe_keep_order(topic_candidates)

        inferred_paths = _ssot_script_anchor_paths_for_topics(
            topic_candidates,
            repo_files_set=repo_files_set,
            by_basename=by_basename,
            max_paths=8,
        )
        if not inferred_paths:
            _emit_json(
                _error_payload(
                    "missing_script_anchor",
                    "Hypothesis creation requires at least one script:<path> anchor in links. Provide --script <repo_relative_path> or a --topic that exists in SSOT (.ssot.json) so scripts can be inferred.",
                    provided_topics=topic_candidates[:12],
                )
            )
            sys.exit(1)
        normalized_links.extend(_script_tokens_from_paths(inferred_paths))

    normalized_links = _dedupe_keep_order(normalized_links)

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    with lock:
        store = load_store()
        hypothesis_id, store_mut = _generate_id(store, "next_hypothesis_id", "H")
        now = utc_now_iso()
        hypothesis = {
            "id": hypothesis_id,
            "title": args.title,
            "statement": args.statement,
            "scope": scope,
            "status": status,
            "topics": args.topics or [],
            "tags": args.tags or [],
            "links": normalized_links,
            "confidence": confidence,
            "created_at": now,
            "created_by": args.author,
            "updated_at": now,
            "updated_by": args.author,
            "evidence_ids": [],
            "related": related or {},
            "metadata": metadata,
        }
        hypotheses = dict(store_mut.get("hypotheses", {}))
        hypotheses[hypothesis_id] = hypothesis
        store_mut["hypotheses"] = hypotheses

        event_payload = {
            "title": args.title,
            "scope": scope,
            "status": status,
        }
        event, store_mut2 = _append_event(
            store_mut,
            kind="hypothesis_created",
            hypothesis_id=hypothesis_id,
            actor=args.author,
            payload=event_payload,
        )
        save_store(store_mut2)

    enriched = _public_hypothesis(store_mut2, hypothesis)
    out_doc: Dict[str, Any] = {
        "ok": True,
        "action": "create",
        "store_path": str(STORE_PATH),
        "hypothesis": enriched,
        "event": event,
    }
    out_doc["next_steps"] = next_steps_for_hypothesis_action(
        action="create",
        hypothesis_id=str(enriched.get("id") or hypothesis_id),
        status=str(enriched.get("status") or ""),
        links=list(enriched.get("links") or []) if isinstance(enriched.get("links"), list) else [],
        evidence_stats=enriched.get("evidence_stats") if isinstance(enriched.get("evidence_stats"), Mapping) else None,
    )
    _emit_json(out_doc)


def _compute_store_stats(store: Mapping[str, Any]) -> Dict[str, Any]:
    hypotheses = store.get("hypotheses", {})
    evidence = store.get("evidence", {})
    events = store.get("events", [])
    hypotheses_total = len(hypotheses) if isinstance(hypotheses, Mapping) else 0
    evidence_total = len(evidence) if isinstance(evidence, Mapping) else 0
    events_total = len(events) if isinstance(events, list) else 0
    return {
        "schema_version": store.get("schema_version"),
        "created_at": store.get("created_at"),
        "updated_at": store.get("updated_at"),
        "hypotheses_total": hypotheses_total,
        "evidence_total": evidence_total,
        "events_total": events_total,
    }


