class FileLock(GovernanceFileLock):
    """Hypothesis store lock backed by the shared governance lock primitive."""

    def __init__(
        self,
        path: Path,
        timeout: float = 30.0,
        poll_interval: float = 0.05,
        stale_after_sec: int = 120,
    ) -> None:
        settings = resolve_lock_settings(
            timeout_envs=("CAIA_HYPOTHESIS_LOCK_TIMEOUT_SEC", "HYPOTHESIS_LOCK_TIMEOUT"),
            timeout_default=float(timeout),
            poll_env="CAIA_HYPOTHESIS_LOCK_POLL_SEC",
            poll_default=float(poll_interval),
            stale_env="CAIA_HYPOTHESIS_LOCK_STALE_SEC",
            stale_default=int(stale_after_sec),
            heartbeat_env="CAIA_HYPOTHESIS_LOCK_HEARTBEAT_SEC",
        )
        super().__init__(
            path=path,
            timeout_sec=settings.timeout_sec,
            poll_sec=settings.poll_sec,
            stale_after_sec=settings.stale_after_sec,
            heartbeat_sec=settings.heartbeat_sec,
        )


