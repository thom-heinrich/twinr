_JSON_PRETTY = False


def _json_dumps(payload: Any, *, pretty: bool) -> str:
    if pretty:
        return json.dumps(payload, indent=2, sort_keys=True)
    return json.dumps(payload, separators=(",", ":"), sort_keys=True)


def _emit_json(payload: Mapping[str, Any], *, pretty: Optional[bool] = None) -> None:
    if pretty is None:
        pretty = bool(_JSON_PRETTY)
    out = enrich_payload_with_hints(payload, tool="hypothesis")
    try:
        sys.stdout.write(_json_dumps(out, pretty=bool(pretty)) + "\n")
    except BrokenPipeError:
        try:
            sys.stdout.close()
        except Exception:
            pass


