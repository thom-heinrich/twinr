def cmd_sync_scripthistory(args: argparse.Namespace) -> None:
    """Ingest references from scripthistory into hypothesis evidence.

    This command scans artifacts/stores/scripthistory/scripthistory.json for events whose comments mention
    hypothesis ids of the form \"H00001\". For each (hypothesis_id, event)
    pair, it creates a new evidence entry with:

    - kind:       'observation'
    - polarity:   'inconclusive' (safe default; humans upgrade later)
    - strength:   'weak' by default
    - summary:    event.comment (truncated if needed)
    - topics:     auto-detected CAIA topics inside the comment (analytics.*, cex.*, ...)
    - sources:    structured pointer back to scripthistory (path, event_id, agent, created_at)

    Duplicate ingestion is avoided by tracking ingested scripthistory event ids
    inside the hypothesis store under sync_state.scripthistory.ingested_event_ids.
    """
    sh_store = _load_scripthistory_store()
    scripts = sh_store.get("scripts", {})
    if not isinstance(scripts, Mapping):
        _emit_json(
            _error_payload(
                "scripthistory_invalid_scripts",
                "scripthistory 'scripts' field must be a mapping.",
                file=str(SCRIPTHISTORY_PATH),
            )
        )
        sys.exit(1)

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    created_evidence: List[Dict[str, Any]] = []
    skipped_unknown: List[str] = []
    scanned_events = 0

    with lock:
        store = load_store()
        hypotheses = store.get("hypotheses", {})
        if not isinstance(hypotheses, Mapping):
            _emit_json(
                _error_payload(
                    "invalid_store_hypotheses",
                    "hypotheses field must be a mapping.",
                    file=str(STORE_PATH),
                )
            )
            sys.exit(1)

        sync_state = dict(store.get("sync_state", {}))
        sh_state = dict(sync_state.get("scripthistory", {}))
        ingested_ids_list = sh_state.get("ingested_event_ids") or []
        if not isinstance(ingested_ids_list, list):
            ingested_ids_list = []
        ingested_ids = set(str(eid) for eid in ingested_ids_list)

        max_events = args.max_events

        for script in scripts.values():
            if not isinstance(script, Mapping):
                continue
            script_path = script.get("path") or "UNKNOWN_PATH"
            events = script.get("events") or []
            if not isinstance(events, list):
                continue
            for ev in events:
                if not isinstance(ev, Mapping):
                    continue
                ev_id = ev.get("id")
                if ev_id is None:
                    continue
                ev_id_str = str(ev_id)
                if ev_id_str in ingested_ids:
                    continue
                scanned_events += 1
                comment = str(ev.get("comment") or "")

                # Extract hypothesis ids from the comment.
                hyp_ids = sorted(set(HYPOTHESIS_ID_RE.findall(comment)))
                if not hyp_ids:
                    continue

                # Extract topic names if present.
                topics = sorted(set(TOPIC_RE.findall(comment)))

                for hyp_id in hyp_ids:
                    if hyp_id not in hypotheses:
                        skipped_unknown.append(hyp_id)
                        continue

                    # Build evidence entry with safe defaults.
                    summary = comment.strip()
                    if len(summary) > 240:
                        summary = summary[:237] + "..."

                    now = utc_now_iso()
                    strength = "weak"
                    # Simple heuristic: upgrade strength if comment mentions backtest or incident.
                    lowered = comment.lower()
                    if "backtest" in lowered or "backtesting" in lowered:
                        strength = "medium"
                    if "incident" in lowered or "outage" in lowered:
                        strength = "medium"

                    sources = [
                        {
                            "type": "scripthistory",
                            "path": script_path,
                            "event_id": ev_id_str,
                            "event_type": ev.get("type"),
                            "event_agent": ev.get("agent"),
                            "event_created_at": ev.get("created_at"),
                        }
                    ]

                    metadata = {
                        "scripthistory_comment": comment,
                    }

                    evidence_id, store = _generate_id(store, "next_evidence_id", "E")
                    evidence = {
                        "id": evidence_id,
                        "hypothesis_id": hyp_id,
                        "kind": "observation",
                        "polarity": "inconclusive",
                        "strength": strength,
                        "summary": summary,
                        "detail": None,
                        "topics": topics,
                        "sources": sources,
                        "links": [
                            f"script:{script_path}",
                            f"scripthistory_event:{ev_id_str}",
                        ],
                        "created_at": now,
                        "created_by": args.actor,
                        "metadata": metadata,
                    }

                    # Persist in evidence map.
                    evidence_map = dict(store.get("evidence", {}))
                    evidence_map[evidence_id] = evidence
                    store = dict(store)
                    store["evidence"] = evidence_map

                    # Link into hypothesis.
                    hyp_obj = hypotheses.get(hyp_id, {})
                    hyp_mut = dict(hyp_obj)
                    ev_ids = list(hyp_mut.get("evidence_ids") or [])
                    ev_ids.append(evidence_id)
                    hyp_mut["evidence_ids"] = ev_ids
                    hyp_mut["updated_at"] = now
                    hyp_mut["updated_by"] = args.actor

                    hypotheses = dict(hypotheses)
                    hypotheses[hyp_id] = hyp_mut
                    store["hypotheses"] = hypotheses

                    # Record event.
                    event_payload = {
                        "evidence_id": evidence_id,
                        "source": "scripthistory",
                        "scripthistory_event_id": ev_id_str,
                        "script_path": script_path,
                    }
                    _event, store = _append_event(
                        store,
                        kind="evidence_added",
                        hypothesis_id=hyp_id,
                        actor=args.actor,
                        payload=event_payload,
                        evidence_id=evidence_id,
                    )
                    created_evidence.append(
                        {
                            "hypothesis_id": hyp_id,
                            "evidence_id": evidence_id,
                            "scripthistory_event_id": ev_id_str,
                            "script_path": script_path,
                        }
                    )

                ingested_ids.add(ev_id_str)

                if max_events is not None and max_events > 0:
                    if len(created_evidence) >= max_events:
                        break
            if max_events is not None and max_events > 0:
                if len(created_evidence) >= max_events:
                    break

        # Update sync_state.
        sh_state["ingested_event_ids"] = sorted(ingested_ids)
        sync_state["scripthistory"] = sh_state
        store["sync_state"] = sync_state

        save_store(store)

    _emit_json(
        {
            "ok": True,
            "action": "sync-scripthistory",
            "store_path": str(STORE_PATH),
            "scripthistory_path": str(SCRIPTHISTORY_PATH),
            "scanned_events": scanned_events,
            "new_evidence_count": len(created_evidence),
            "created_evidence": created_evidence,
            "skipped_unknown_hypotheses": sorted(set(skipped_unknown)),
            "ingested_event_ids_count": len(ingested_ids),
        }
    )


def cmd_init(args: argparse.Namespace) -> None:
    """Initialise the hypothesis store if not present."""
    try:
        store = load_store()
    except SystemExit:
        # load_store already printed a structured error.
        raise
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if STORE_PATH.exists() and not args.force:
