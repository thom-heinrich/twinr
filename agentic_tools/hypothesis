def cmd_overview(args: argparse.Namespace) -> None:
    """Return compact store-level summary for fast agent orientation."""
    store = load_store()
    hypotheses = [
        h for h in (store.get("hypotheses", {}) or {}).values() if isinstance(h, Mapping)
    ]
    hypotheses.sort(key=lambda h: (str(h.get("created_at") or ""), str(h.get("id") or "")), reverse=True)
    limit = max(1, min(int(getattr(args, "limit", 200) or 200), 5000))
    hypotheses = hypotheses[:limit]

    by_status: Dict[str, int] = {}
    by_scope: Dict[str, int] = {}
    top: List[Dict[str, Any]] = []
    for hyp in hypotheses:
        status = str(hyp.get("status") or "unknown")
        scope = str(hyp.get("scope") or "unknown")
        by_status[status] = int(by_status.get(status, 0)) + 1
        by_scope[scope] = int(by_scope.get(scope, 0)) + 1
        if len(top) < 12:
            pub = _public_hypothesis(store, hyp)
            top.append(
                {
                    "id": str(pub.get("id") or ""),
                    "title": str(pub.get("title") or ""),
                    "status": status,
                    "scope": scope,
                    "confidence": pub.get("confidence"),
                    "evidence_stats": pub.get("evidence_stats"),
                    "created_at": pub.get("created_at"),
                }
            )

    payload: Dict[str, Any] = {
        "ok": True,
        "action": "overview",
        "store_path": str(STORE_PATH),
        "count": len(hypotheses),
        "counts_by_status": by_status,
        "counts_by_scope": by_scope,
        "top_hypotheses": top,
        "recommended_next_calls": [
            "hypothesis list --status in_review --limit 30",
            "hypothesis explain --id <Hxxxxx>",
            "hypothesis add-evidence --hypothesis-id <Hxxxxx> ...",
        ],
    }
    _emit_json(payload)


def cmd_add_evidence(args: argparse.Namespace) -> None:
    """Attach an evidence item to a hypothesis."""
    hypothesis_id = args.hypothesis_id
    _validate_evidence_fields(args.kind, args.polarity, args.strength)
    metadata = _parse_json_arg(args.metadata_json, "--metadata-json")
    sources = _parse_json_list_arg(args.sources_json, "--sources-json")
    links = [str(x).strip() for x in (getattr(args, "links", None) or []) if str(x).strip()]
    text_links = extract_link_tokens_from_texts([str(args.summary or ""), str(args.detail or "")])
    links = list(links) + list(text_links)
    bad_links = [x for x in links if not LINK_TOKEN_RE.fullmatch(x)]
    if bad_links:
        _emit_json(
            _error_payload(
                "invalid_link",
                "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
                bad=bad_links[:20],
            )
        )
        sys.exit(1)

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    with lock:
        store = load_store()
        hypotheses = store.get("hypotheses", {})
        hypothesis = hypotheses.get(hypothesis_id)
        if not hypothesis:
            _emit_json(
                _error_payload(
                    "not_found",
                    f"Hypothesis '{hypothesis_id}' not found.",
                    id=hypothesis_id,
                )
            )
            sys.exit(1)

        evidence_id, store_mut = _generate_id(store, "next_evidence_id", "E")
        now = utc_now_iso()
        evidence = {
            "id": evidence_id,
            "hypothesis_id": hypothesis_id,
            "kind": args.kind,
            "polarity": args.polarity,
            "strength": args.strength,
            "summary": args.summary,
            "detail": args.detail,
            "topics": args.topics or [],
            "sources": sources,
            "links": links,
            "created_at": now,
            "created_by": args.actor,
            "metadata": metadata,
        }

        evidence_map = dict(store_mut.get("evidence", {}))
        evidence_map[evidence_id] = evidence
        store_mut["evidence"] = evidence_map

        # Update hypothesis linkage.
        hypotheses = dict(store_mut.get("hypotheses", {}))
        hyp_mut = dict(hypothesis)
        ev_ids = list(hyp_mut.get("evidence_ids") or [])
        ev_ids.append(evidence_id)
        hyp_mut["evidence_ids"] = ev_ids
        hyp_mut["updated_at"] = now
        hyp_mut["updated_by"] = args.actor
        hypotheses[hypothesis_id] = hyp_mut
        store_mut["hypotheses"] = hypotheses

        event_payload = {
            "evidence_id": evidence_id,
            "kind": args.kind,
            "polarity": args.polarity,
            "strength": args.strength,
        }
        event, store_mut2 = _append_event(
            store_mut,
            kind="evidence_added",
            hypothesis_id=hypothesis_id,
            actor=args.actor,
            payload=event_payload,
            evidence_id=evidence_id,
        )
        save_store(store_mut2)

    hyp_public = _public_hypothesis(store_mut2, hyp_mut)
    out_doc2: Dict[str, Any] = {
        "ok": True,
        "action": "add-evidence",
        "store_path": str(STORE_PATH),
        "hypothesis": hyp_public,
        "evidence": evidence,
        "event": event,
    }
    out_doc2["next_steps"] = next_steps_for_hypothesis_action(
        action="add-evidence",
        hypothesis_id=str(hyp_public.get("id") or hypothesis_id),
        status=str(hyp_public.get("status") or ""),
        links=list(hyp_public.get("links") or []) if isinstance(hyp_public.get("links"), list) else [],
        evidence_stats=hyp_public.get("evidence_stats") if isinstance(hyp_public.get("evidence_stats"), Mapping) else None,
    )
    _emit_json(out_doc2)


def cmd_add_links(args: argparse.Namespace) -> None:
    """Append outbound links to an existing hypothesis (truth edges)."""
    hypothesis_id = str(getattr(args, "hypothesis_id", "") or "").strip()
    actor = str(getattr(args, "actor", "") or "").strip()
    links_add_raw = getattr(args, "links_add", None) or []

    if not actor:
        _emit_json(
            _error_payload(
                "missing_actor",
                "Missing --actor/--author (required for audit trail).",
            )
        )
        sys.exit(1)

    if not hypothesis_id:
        _emit_json(_error_payload("missing_hypothesis_id", "Missing --hypothesis-id/--id."))
        sys.exit(1)

    if not isinstance(links_add_raw, list):
        _emit_json(_error_payload("invalid_links_add", "--link-add/--links-add must be repeatable strings."))
        sys.exit(1)

    links_add = [str(x).strip() for x in links_add_raw if isinstance(x, str) and str(x).strip()]
    if not links_add:
        _emit_json(_error_payload("missing_links_add", "No --link-add values provided."))
        sys.exit(1)

    bad_links = [x for x in links_add if not LINK_TOKEN_RE.fullmatch(x)]
    if bad_links:
        _emit_json(
            _error_payload(
                "invalid_link",
                "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
                bad=bad_links[:20],
            )
        )
        sys.exit(1)

    # Validate script:<path> links to ensure they are truthy graph edges.
    repo_files = _git_ls_files(REPO_ROOT)
    if not repo_files:
        _emit_json(
            _error_payload(
                "repo_index_failed",
                "Failed to index repo files via git ls-files (repo might not be a git checkout).",
                repo_root=str(REPO_ROOT),
            )
        )
        sys.exit(1)
    repo_files_set = set(repo_files)

    invalid_script_links: List[Dict[str, str]] = []
    for token in links_add:
        if not token.startswith("script:"):
            continue
        path = token.split(":", 1)[1]
        if path.startswith("/"):
            invalid_script_links.append({"token": token, "reason": "absolute_path"})
            continue
        if path not in repo_files_set:
            invalid_script_links.append({"token": token, "reason": "path_not_found"})

    if invalid_script_links:
        _emit_json(
            _error_payload(
                "invalid_script_links",
                "One or more script:<path> links do not resolve to a repo file.",
                invalid_script_links=invalid_script_links[:20],
            )
        )
        sys.exit(1)

    dry_run = bool(getattr(args, "dry_run", False))

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    with lock:
        store = load_store()
        hypotheses = store.get("hypotheses", {})
        if not isinstance(hypotheses, Mapping):
            _emit_json(_error_payload("invalid_store", "hypotheses must be a mapping."))
            sys.exit(1)

        hypothesis = hypotheses.get(hypothesis_id)
        if not isinstance(hypothesis, Mapping):
            _emit_json(
                _error_payload(
                    "not_found",
                    f"Hypothesis '{hypothesis_id}' not found.",
                    id=hypothesis_id,
                )
            )
            sys.exit(1)

        existing_links = [
            str(x).strip()
            for x in (hypothesis.get("links") or [])
            if isinstance(x, str) and str(x).strip()
        ]

        seen = set(existing_links)
        added_links: List[str] = []
        for t in links_add:
            if t in seen:
                continue
            seen.add(t)
            added_links.append(t)

        if dry_run:
            hyp_public = _public_hypothesis(store, hypothesis)
            out_doc3: Dict[str, Any] = {
                "ok": True,
                "action": "add-links",
                "dry_run": True,
                "store_path": str(STORE_PATH),
                "hypothesis": hyp_public,
                "added_links": added_links,
            }
            out_doc3["next_steps"] = next_steps_for_hypothesis_action(
                action="add-links",
                hypothesis_id=str(hyp_public.get("id") or hypothesis_id),
                status=str(hyp_public.get("status") or ""),
                links=list(hyp_public.get("links") or []) if isinstance(hyp_public.get("links"), list) else [],
                evidence_stats=hyp_public.get("evidence_stats") if isinstance(hyp_public.get("evidence_stats"), Mapping) else None,
            )
            _emit_json(out_doc3)
            return

        if not added_links:
            hyp_public = _public_hypothesis(store, hypothesis)
            out_doc4: Dict[str, Any] = {
                "ok": True,
                "action": "add-links",
                "store_path": str(STORE_PATH),
                "hypothesis": hyp_public,
                "added_links": [],
                "note": "No changes (all provided links already present).",
            }
            out_doc4["next_steps"] = next_steps_for_hypothesis_action(
                action="add-links",
                hypothesis_id=str(hyp_public.get("id") or hypothesis_id),
                status=str(hyp_public.get("status") or ""),
                links=list(hyp_public.get("links") or []) if isinstance(hyp_public.get("links"), list) else [],
                evidence_stats=hyp_public.get("evidence_stats") if isinstance(hyp_public.get("evidence_stats"), Mapping) else None,
            )
            _emit_json(out_doc4)
            return

        now = utc_now_iso()
        hyp_mut = dict(hypothesis)
        hyp_mut["links"] = list(existing_links) + list(added_links)
        hyp_mut["updated_at"] = now
        hyp_mut["updated_by"] = actor

        hypotheses_mut = dict(hypotheses)
        hypotheses_mut[hypothesis_id] = hyp_mut
        store_mut = dict(store)
        store_mut["hypotheses"] = hypotheses_mut

        event_payload = {"added_links": added_links}
        event, store_mut2 = _append_event(
            store_mut,
            kind="links_added",
            hypothesis_id=hypothesis_id,
            actor=actor,
            payload=event_payload,
        )
        save_store(store_mut2)

    hyp_public = _public_hypothesis(store_mut2, hyp_mut)
    out_doc5: Dict[str, Any] = {
        "ok": True,
        "action": "add-links",
        "store_path": str(STORE_PATH),
        "hypothesis": hyp_public,
        "added_links": added_links,
        "event": event,
    }
    out_doc5["next_steps"] = next_steps_for_hypothesis_action(
        action="add-links",
        hypothesis_id=str(hyp_public.get("id") or hypothesis_id),
        status=str(hyp_public.get("status") or ""),
        links=list(hyp_public.get("links") or []) if isinstance(hyp_public.get("links"), list) else [],
        evidence_stats=hyp_public.get("evidence_stats") if isinstance(hyp_public.get("evidence_stats"), Mapping) else None,
    )
    _emit_json(out_doc5)


def cmd_set_status(args: argparse.Namespace) -> None:
    """Update hypothesis status/confidence and record an event."""
    hypothesis_id = args.hypothesis_id
    new_status = args.status
    _validate_status(new_status)
    new_conf = _clamp_confidence(args.confidence)
    verdict = _parse_json_arg(args.verdict_json, "--verdict-json")

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    with lock:
        store = load_store()
        hypotheses = store.get("hypotheses", {})
        hypothesis = hypotheses.get(hypothesis_id)
        if not hypothesis:
            _emit_json(
                _error_payload(
                    "not_found",
                    f"Hypothesis '{hypothesis_id}' not found.",
                    id=hypothesis_id,
                )
            )
            sys.exit(1)

        old_status = hypothesis.get("status")
        old_conf = hypothesis.get("confidence")
        now = utc_now_iso()

        hyp_mut = dict(hypothesis)
        hyp_mut["status"] = new_status
        if new_conf is not None:
            hyp_mut["confidence"] = new_conf
        if verdict:
            hyp_mut["verdict"] = verdict
        hyp_mut["updated_at"] = now
        hyp_mut["updated_by"] = args.actor

        hypotheses = dict(hypotheses)
        hypotheses[hypothesis_id] = hyp_mut

        store_mut: Dict[str, Any] = dict(store)
        store_mut["hypotheses"] = hypotheses

        evidence_stats = _compute_evidence_stats(store, hypothesis_id)
        event_payload: Dict[str, Any] = {
            "old_status": old_status,
            "new_status": new_status,
            "old_confidence": old_conf,
            "new_confidence": new_conf,
            "reason": args.reason,
            "evidence_stats": evidence_stats,
        }

        warnings: List[str] = []
        if new_status in {"supported", "refuted"}:
            if not args.reason:
                warnings.append("missing_reason")
            if new_status == "supported" and evidence_stats.get("supporting", 0) == 0:
                warnings.append("no_supporting_evidence")
            if new_status == "refuted" and evidence_stats.get("contradicting", 0) == 0:
                warnings.append("no_contradicting_evidence")
        if warnings:
            event_payload["warnings"] = warnings

        event, store_mut2 = _append_event(
            store_mut,
            kind="status_changed",
            hypothesis_id=hypothesis_id,
            actor=args.actor,
            payload=event_payload,
        )
        save_store(store_mut2)

    hyp_public = _public_hypothesis(store_mut2, hyp_mut)
    out_doc6: Dict[str, Any] = {
        "ok": True,
        "action": "set-status",
        "store_path": str(STORE_PATH),
        "hypothesis": hyp_public,
        "event": event,
    }
    out_doc6["next_steps"] = next_steps_for_hypothesis_action(
        action="set-status",
        hypothesis_id=str(hyp_public.get("id") or hypothesis_id),
        status=str(hyp_public.get("status") or ""),
        links=list(hyp_public.get("links") or []) if isinstance(hyp_public.get("links"), list) else [],
        evidence_stats=hyp_public.get("evidence_stats") if isinstance(hyp_public.get("evidence_stats"), Mapping) else None,
    )
    _emit_json(out_doc6)


def cmd_backfill_links(args: argparse.Namespace) -> None:
    """Backfill missing hypothesis.links entries based on explicit file paths and SSOT topics."""
    actor = str(args.actor or "").strip()
    if not actor:
        _emit_json(
            _error_payload(
                "missing_actor",
                "Missing --actor/--author (required for audit trail).",
            )
        )
        sys.exit(1)

    mode = str(args.mode or "both").strip()
    if mode not in {"statement", "evidence", "both", "topics", "all"}:
        _emit_json(_error_payload("invalid_mode", "mode must be one of: statement, evidence, both, topics, all."))
        sys.exit(1)

    repo_files = _git_ls_files(REPO_ROOT)
    if not repo_files:
        _emit_json(
            _error_payload(
                "repo_index_failed",
                "Failed to index repo files via git ls-files (repo might not be a git checkout).",
                repo_root=str(REPO_ROOT),
            )
        )
        sys.exit(1)

    repo_files_set = set(repo_files)
    by_basename: Dict[str, List[str]] = {}
    for p in repo_files:
        by_basename.setdefault(Path(p).name, []).append(p)

    status_filters = set(str(s).strip() for s in (getattr(args, "status", None) or []) if str(s).strip())
    if status_filters:
        unknown = sorted(status_filters.difference(HYPOTHESIS_STATUSES))
        if unknown:
            _emit_json(_error_payload("invalid_status_filter", "Unknown status in --status filter.", bad=unknown))
            sys.exit(1)

    only_hypothesis_id = str(args.only_hypothesis_id or "").strip() or None

    lock = FileLock(STORE_PATH.with_suffix(STORE_PATH.suffix + ".lock"))
    with lock:
        store = load_store()
        hypotheses = store.get("hypotheses", {})
        evidence_map = store.get("evidence", {})
        if not isinstance(hypotheses, Mapping) or not isinstance(evidence_map, Mapping):
            _emit_json(_error_payload("invalid_store", "hypotheses/evidence must be mappings."))
            sys.exit(1)

        # Optional cross-store link-walk (explicit links only) to harvest script anchors.
        tasks_by_id: Dict[str, Any] = {}
        fixreport_dir = (
            resolve_store_dir(
                legacy_rel="state/fixreport",
                canonical_rel="fixreport",
                repo_root=REPO_ROOT,
            )
            / "reports"
        )
        if mode in {"all"}:
            tasks_path = resolve_store_file(
                env_keys=("TASKS_FILE", "KANBAN_FILE"),
                legacy_rel=".kanban_board.json",
                canonical_rel="tasks/board.json",
                repo_root=REPO_ROOT,
            )
            try:
                if tasks_path.is_file():
                    board = json.loads(tasks_path.read_text(encoding="utf-8")) or {}
                    tasks_by_id = dict(board.get("tasks") or {}) if isinstance(board, dict) else {}
            except Exception:
                tasks_by_id = {}

        now = utc_now_iso()
        considered = 0
        updated: List[Dict[str, Any]] = []
        skipped_with_script = 0

        for hyp_key, hyp_obj in hypotheses.items():
            hyp_id = str(hyp_obj.get("id") if isinstance(hyp_obj, Mapping) else hyp_key)
            if only_hypothesis_id and hyp_id != only_hypothesis_id:
                continue
            if not isinstance(hyp_obj, Mapping):
                continue
            if status_filters and str(hyp_obj.get("status") or "").strip() not in status_filters:
                continue
            considered += 1

            existing_links = [
                str(x).strip()
                for x in (hyp_obj.get("links") or [])
                if isinstance(x, str) and str(x).strip()
            ]
            if any(x.startswith("script:") for x in existing_links):
                skipped_with_script += 1
                continue

            candidates: List[str] = []
            if mode in {"statement", "both", "all"}:
                candidates.extend(_extract_repo_file_mentions(str(hyp_obj.get("title") or "")))
                candidates.extend(_extract_repo_file_mentions(str(hyp_obj.get("statement") or "")))

            if mode in {"evidence", "both", "all"}:
                ev_ids = hyp_obj.get("evidence_ids") or []
                if isinstance(ev_ids, list):
                    for ev_id in ev_ids:
                        ev = evidence_map.get(ev_id)
                        if not isinstance(ev, Mapping):
                            continue
                        candidates.extend(_extract_repo_file_mentions(str(ev.get("summary") or "")))
                        candidates.extend(_extract_repo_file_mentions(str(ev.get("detail") or "")))
                        # Evidence may already carry explicit script links.
                        ev_links = ev.get("links") or []
                        if isinstance(ev_links, list):
                            for t in ev_links:
                                if isinstance(t, str) and t.startswith("script:"):
                                    candidates.append(t.split("script:", 1)[1].strip())
                        sources = ev.get("sources") or []
                        if isinstance(sources, Mapping):
                            sources = [sources]
                        if isinstance(sources, list):
                            for src in sources:
                                if not isinstance(src, Mapping):
                                    continue
                                if isinstance(src.get("path"), str):
                                    candidates.append(str(src.get("path") or ""))
                                for k, v in src.items():
                                    if k == "path":
                                        continue
                                    if isinstance(v, str):
                                        candidates.extend(_extract_repo_file_mentions(v))

            if mode in {"topics", "all"}:
                topics: List[str] = []
                if isinstance(hyp_obj.get("topics"), list):
                    topics.extend([str(t).strip() for t in (hyp_obj.get("topics") or []) if str(t).strip()])
                topics.extend(TOPIC_RE.findall(f"{str(hyp_obj.get('title') or '')} {str(hyp_obj.get('statement') or '')}"))
                topics = _dedupe_keep_order(topics)
                ssot_paths = _ssot_script_anchor_paths_for_topics(
                    topics,
                    repo_files_set=repo_files_set,
                    by_basename=by_basename,
                    max_paths=int(args.max_links_per_hypothesis),
                )
                if ssot_paths:
                    candidates.extend(ssot_paths)
                else:
                    # Conservative heuristic fallback when SSOT lookup misses.
                    candidates.extend(
                        _infer_repo_paths_from_terms(
                            topics,
                            repo_files=repo_files,
                            max_paths=int(args.max_links_per_hypothesis),
                        )
                    )

            # Explicit link-walk: task/fixreport -> script anchors.
            if mode in {"all"}:
                for token in existing_links:
                    if token.startswith("task:"):
                        tid = token.split("task:", 1)[1].strip()
                        t = tasks_by_id.get(tid)
                        if isinstance(t, Mapping):
                            t_links = t.get("links") or []
                            if isinstance(t_links, list):
                                for lt in t_links:
                                    if isinstance(lt, str) and lt.startswith("script:"):
                                        candidates.append(lt.split("script:", 1)[1].strip())
                    if token.startswith("fixreport:"):
                        bf_id = token.split("fixreport:", 1)[1].strip()
                        if not bf_id:
                            continue
                        p = None
                        for suf in (".yml", ".yaml"):
                            cand = (fixreport_dir / f"{bf_id}{suf}").resolve()
                            if cand.is_file():
                                p = cand
                                break
                        if p is None:
                            continue
                        try:
                            doc = yaml.safe_load(p.read_text(encoding="utf-8")) or {}
                        except Exception:
                            continue
                        fr = doc.get("fixreport") if isinstance(doc, dict) else None
                        if not isinstance(fr, Mapping):
                            continue
                        target_path = str(fr.get("target_path") or "").strip()
                        if target_path:
                            candidates.append(target_path)
                        touched = fr.get("paths_touched") or []
                        if isinstance(touched, list):
                            for tp in touched:
                                if isinstance(tp, str) and tp.strip():
                                    candidates.append(tp.strip())

            resolved: List[str] = []
            seen_paths: set[str] = set()
            for raw in candidates:
                rp = _resolve_repo_path(raw, repo_files_set=repo_files_set, by_basename=by_basename)
                if rp is None or rp in seen_paths:
                    continue
                seen_paths.add(rp)
                resolved.append(rp)

            resolved = [p for p in resolved if _is_reasonable_script_anchor_path(p)]
            if not resolved:
                continue

            resolved.sort(key=_path_rank)
            tokens = _script_tokens_from_paths(resolved)
            tokens = [t for t in tokens if t not in existing_links]
            if not tokens:
                continue

            max_links = int(args.max_links_per_hypothesis)
            if max_links > 0:
                tokens = tokens[:max_links]

            if args.dry_run:
                updated.append({"hypothesis_id": hyp_id, "added_links": tokens})
                continue

            hyp_mut = dict(hyp_obj)
            links_new = list(existing_links)
            links_new.extend(tokens)
            hyp_mut["links"] = links_new
            hyp_mut["updated_at"] = now
            hyp_mut["updated_by"] = actor

            hypotheses = dict(hypotheses)
            hypotheses[hyp_id] = hyp_mut
            store = dict(store)
            store["hypotheses"] = hypotheses

            event_payload = {
                "added_links": tokens,
                "mode": mode,
                "resolved_paths": resolved[: max_links if max_links > 0 else 12],
            }
            _event, store = _append_event(
                store,
                kind="links_added",
                hypothesis_id=hyp_id,
                actor=actor,
                payload=event_payload,
            )
            updated.append({"hypothesis_id": hyp_id, "added_links": tokens})

        if not args.dry_run and updated:
            save_store(store)

    _emit_json(
        {
            "ok": True,
            "action": "backfill-links",
            "store_path": str(STORE_PATH),
            "dry_run": bool(args.dry_run),
            "mode": mode,
            "only_hypothesis_id": only_hypothesis_id,
            "considered": considered,
            "updated": len(updated),
            "skipped_with_script": skipped_with_script,
            "changes_sample": updated[: min(50, len(updated))],
        }
    )


def cmd_history(args: argparse.Namespace) -> None:
    """Show the event history for a hypothesis."""
    hypothesis_id = args.hypothesis_id
    store = load_store()
    events = list(store.get("events", []))
    filtered: List[Dict[str, Any]] = []
    for ev in events:
        if not isinstance(ev, Mapping):
            continue
        if ev.get("hypothesis_id") != hypothesis_id:
            continue
        filtered.append(dict(ev))

    filtered.sort(key=lambda ev: (str(ev.get("timestamp") or ""), str(ev.get("id") or "")))

    limit = args.limit
    if limit is not None and limit > 0 and len(filtered) > limit:
        filtered = filtered[-limit:]

    _emit_json(
        {
            "ok": True,
            "action": "history",
            "store_path": str(STORE_PATH),
            "hypothesis_id": hypothesis_id,
            "events": filtered,
            "count": len(filtered),
        }
    )


