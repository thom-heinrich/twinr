            )
        )
        sys.exit(1)
    return value


def _compute_evidence_stats(store: Mapping[str, Any], hypothesis_id: str) -> Dict[str, int]:
    """Compute counts of evidence by polarity for a hypothesis."""
    evidence = store.get("evidence", {})
    counts = {
        "supporting": 0,
        "contradicting": 0,
        "inconclusive": 0,
    }
    if not isinstance(evidence, Mapping):
        return counts
    for ev in evidence.values():
        if not isinstance(ev, Mapping):
            continue
        if ev.get("hypothesis_id") != hypothesis_id:
            continue
        polarity = ev.get("polarity")
        if polarity in counts:
            counts[polarity] += 1
    return counts


def _compute_evidence_summary(store: Mapping[str, Any], hypothesis_id: str) -> Dict[str, Any]:
    """Compute a richer evidence summary used for guidance and auditing.

    This is advisory/meta information; it does not drive any hard logic.
    """
    evidence_map = store.get("evidence", {})
    counts_by_polarity: Dict[str, int] = {
        "supporting": 0,
        "contradicting": 0,
        "inconclusive": 0,
    }
    counts_by_ps: Dict[str, Dict[str, int]] = {
        "supporting": {s: 0 for s in EVIDENCE_STRENGTHS},
        "contradicting": {s: 0 for s in EVIDENCE_STRENGTHS},
        "inconclusive": {s: 0 for s in EVIDENCE_STRENGTHS},
    }
    total = 0

    if isinstance(evidence_map, Mapping):
        for ev in evidence_map.values():
            if not isinstance(ev, Mapping):
                continue
            if ev.get("hypothesis_id") != hypothesis_id:
                continue
            pol = ev.get("polarity")
            strength = ev.get("strength")
            total += 1
            if pol in counts_by_polarity:
                counts_by_polarity[pol] += 1
                if pol in counts_by_ps and strength in EVIDENCE_STRENGTHS:
                    counts_by_ps[pol][strength] += 1

    def weight(ps_counts: Dict[str, int]) -> int:
        return (
            ps_counts.get("weak", 0)
            + 2 * ps_counts.get("medium", 0)
            + 3 * ps_counts.get("strong", 0)
        )

    support_score = weight(counts_by_ps["supporting"])
    contra_score = weight(counts_by_ps["contradicting"])

    if support_score == 0 and contra_score == 0:
        strongest: Optional[str] = None
    elif support_score >= contra_score * 1.5:
        strongest = "supporting"
    elif contra_score >= support_score * 1.5:
        strongest = "contradicting"
    else:
        strongest = "mixed"

    return {
        "total_evidence": total,
        "counts_by_polarity": counts_by_polarity,
        "counts_by_polarity_and_strength": counts_by_ps,
        "strongest_polarity": strongest,
        "support_score": support_score,
        "contradict_score": contra_score,
    }


def _append_event(
    store: Mapping[str, Any],
    *,
    kind: str,
    hypothesis_id: str,
    actor: Optional[str],
    payload: Optional[Dict[str, Any]] = None,
    evidence_id: Optional[str] = None,
) -> Tuple[Dict[str, Any], Dict[str, Any]]:
    """Append an event to the store and return (event, mutated_store)."""
    if payload is None:
        payload = {}
    event_id, mutable = _generate_id(store, "next_event_id", "EV")
    events = list(mutable.get("events", []))
    event = {
        "id": event_id,
        "kind": kind,
        "hypothesis_id": hypothesis_id,
        "evidence_id": evidence_id,
        "actor": actor,
        "timestamp": utc_now_iso(),
        "payload": payload,
    }
    events.append(event)
    mutable["events"] = events
    logging.info(
        "Recorded event %s for hypothesis=%s kind=%s actor=%s",
        event_id,
        hypothesis_id,
        kind,
        actor,
    )
    return event, mutable


def _public_hypothesis(store: Mapping[str, Any], hyp: Mapping[str, Any]) -> Dict[str, Any]:
    """Return a public representation of a hypothesis enriched with stats."""
    hypothesis_id = str(hyp.get("id"))
    enriched = dict(hyp)
    stats = _compute_evidence_stats(store, hypothesis_id)
    enriched.setdefault("evidence_stats", stats)
    enriched.setdefault("evidence_summary", _compute_evidence_summary(store, hypothesis_id))
    return enriched


def _as_string_list(value: Any) -> List[str]:
    if isinstance(value, list):
        out: List[str] = []
        for item in value:
            if item is None:
                continue
            text = str(item).strip()
            if text:
                out.append(text)
        return out
    if isinstance(value, str):
        text = value.strip()
        return [text] if text else []
    return []


def _pick_first_nonempty(*values: Any) -> str:
    for value in values:
        if value is None:
            continue
        text = str(value).strip()
        if text:
            return text
    return ""


def _dedupe_keep_order(values: List[str]) -> List[str]:
    out: List[str] = []
    seen: set[str] = set()
    for value in values:
        text = str(value).strip()
        if not text or text in seen:
            continue
        seen.add(text)
        out.append(text)
    return out


def _normalize_hypothesis_explain(
    store: Mapping[str, Any], hypothesis: Mapping[str, Any]
) -> Dict[str, Any]:
    evidence_summary = _compute_evidence_summary(store, str(hypothesis.get("id") or ""))
    evidence_stats = _compute_evidence_stats(store, str(hypothesis.get("id") or ""))
    links = _dedupe_keep_order(_as_string_list(hypothesis.get("links")))
    status = str(hypothesis.get("status") or "").strip().lower()
    confidence = hypothesis.get("confidence")

    how: List[str] = []
    if isinstance(evidence_summary, dict):
        top_support = _as_string_list(evidence_summary.get("top_supporting_points"))
        top_contra = _as_string_list(evidence_summary.get("top_contradicting_points"))
        how.extend([f"supporting: {item}" for item in top_support[:3]])
        how.extend([f"contradicting: {item}" for item in top_contra[:3]])
    if not how:
        how.append("Add balanced supporting/contradicting evidence before status changes.")

    guardrails: List[str] = [
        "Status changes to supported/refuted require explicit evidence rationale.",
        "Keep hypothesis statements falsifiable and scope-specific.",
    ]
    if confidence is not None:
        guardrails.append(f"Current confidence={confidence}; update only with new evidence.")

    evidence: List[str] = []
    evidence.extend(_as_string_list(hypothesis.get("links")))
    if isinstance(evidence_stats, dict):
        total = evidence_stats.get("total")
        if total is not None:
            evidence.append(f"evidence_total:{total}")
        support = evidence_stats.get("supporting")
        if support is not None:
            evidence.append(f"supporting:{support}")
        contra = evidence_stats.get("contradicting")
        if contra is not None:
            evidence.append(f"contradicting:{contra}")

    conflicts: List[str] = []
    if status in {"refuted", "deprecated"}:
        conflicts.append(f"status={status}")
    if isinstance(evidence_summary, dict):
        strongest = str(evidence_summary.get("strongest_polarity") or "").strip().lower()
        if strongest == "mixed":
            conflicts.append("evidence polarity is mixed")

    return {
        "what": _pick_first_nonempty(hypothesis.get("title"), hypothesis.get("statement"), hypothesis.get("id"), "Hypothesis"),
        "why": _pick_first_nonempty(
            hypothesis.get("statement"),
            hypothesis.get("description"),
            "Track and test a falsifiable claim.",
        ),
        "how": _dedupe_keep_order(how),
        "guardrails": _dedupe_keep_order(guardrails),
        "evidence": _dedupe_keep_order(evidence),
        "conflicts": _dedupe_keep_order(conflicts),
        "links": links,
    }


def _git_ls_files(repo_root: Path) -> List[str]:
    try:
        out = subprocess.check_output(
            ["git", "-C", str(repo_root), "ls-files"],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return []
    return [line.strip() for line in out.splitlines() if line.strip()]


def _extract_repo_file_mentions(text: str) -> List[str]:
    if not text:
        return []
    out: List[str] = []
    for m in REPO_FILE_MENTION_RE.finditer(text):
        p = (m.group("path") or "").strip().strip("`\"'()[]{}.,;:")
        if p and p not in out:
            out.append(p)
    return out


def _normalize_repo_path(raw: str) -> str:
    s = str(raw or "").strip()
    if not s:
        return ""
    if s.startswith("./"):
        s = s[2:]
    if s.startswith(str(REPO_ROOT) + "/"):
        s = s[len(str(REPO_ROOT) + "/") :]
    if s.startswith("/etc/systemd/system/"):
        unit = s.split("/etc/systemd/system/", 1)[1]
        s = f"systemd/units/{unit}"
    return s


def _resolve_repo_path(
    raw: str,
    *,
    repo_files_set: set[str],
    by_basename: Mapping[str, List[str]],
) -> Optional[str]:
    s = _normalize_repo_path(raw)
    if not s:
        return None

    # Absolute non-repo paths: allow mapping by basename if unique.
    if s.startswith("/"):
        base = Path(s).name
        candidates = sorted(set(by_basename.get(base, [])))
        if len(candidates) == 1:
            return candidates[0]
        return None

    if any(part == ".." for part in Path(s).parts):
        return None

    if s in repo_files_set or (REPO_ROOT / s).is_file():
        return s

    if "/" not in s:
        candidates = sorted(set(by_basename.get(Path(s).name, [])))
        if len(candidates) == 1:
            return candidates[0]
    return None


def _script_tokens_from_paths(paths: Iterable[str]) -> List[str]:
    out: List[str] = []
    for p in paths:
        p = str(p).strip()
        if not p:
            continue
        out.append(f"script:{p}")
    # Stable de-dupe in order.
    seen: set[str] = set()
    deduped: List[str] = []
    for t in out:
        if t in seen:
            continue
        seen.add(t)
        deduped.append(t)
    return deduped


def _is_reasonable_script_anchor_path(path: str) -> bool:
    """Heuristic guardrail: keep Meta script anchors focused on code/config, not ephemeral artifacts."""
    p = str(path or "").strip()
    if not p:
        return False
    if p.startswith(("reports/", "artifacts/reports/", "artifacts/stores/", "state/", "logs/", "exports/")):
        return False
    if "/__pycache__/" in p:
        return False
    return True


