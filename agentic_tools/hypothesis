def utc_now_iso() -> str:
    """Return current UTC time as ISO8601 string with Z suffix."""
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def configure_logging() -> None:
    """Configure verbose logging to stderr for observability."""
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] hypothesis %(message)s",
        stream=sys.stderr,
    )


