def _default_store() -> Dict[str, Any]:
    """Return a fresh, empty hypothesis store structure."""
    now = utc_now_iso()
    return {
        "schema_version": 1,
        "created_at": now,
        "updated_at": now,
        "next_hypothesis_id": 1,
        "next_evidence_id": 1,
        "next_event_id": 1,
        "hypotheses": {},
        "evidence": {},
        "events": [],
        "sync_state": {
            "scripthistory": {
                "ingested_event_ids": [],
            }
        },
    }


def _ensure_store_shape(store: Mapping[str, Any]) -> Dict[str, Any]:
    """Ensure mandatory top-level keys exist on the store."""
    mutable: Dict[str, Any] = dict(store)
    if "schema_version" not in mutable:
        mutable["schema_version"] = 1
    if "created_at" not in mutable:
        mutable["created_at"] = utc_now_iso()
    if "updated_at" not in mutable:
        mutable["updated_at"] = utc_now_iso()
    if "next_hypothesis_id" not in mutable:
        mutable["next_hypothesis_id"] = 1
    if "next_evidence_id" not in mutable:
        mutable["next_evidence_id"] = 1
    if "next_event_id" not in mutable:
        mutable["next_event_id"] = 1
    if "hypotheses" not in mutable or not isinstance(mutable["hypotheses"], dict):
        mutable["hypotheses"] = {}
    if "evidence" not in mutable or not isinstance(mutable["evidence"], dict):
        mutable["evidence"] = {}
    if "events" not in mutable or not isinstance(mutable["events"], list):
        mutable["events"] = []
    # Ensure sync_state is present but preserve any existing content.
    if "sync_state" not in mutable or not isinstance(mutable["sync_state"], Mapping):
        mutable["sync_state"] = {
            "scripthistory": {
                "ingested_event_ids": [],
            }
        }
    else:
        sync_state = dict(mutable["sync_state"])
        sh_state = dict(sync_state.get("scripthistory", {}))
        ingested = sh_state.get("ingested_event_ids")
        if not isinstance(ingested, list):
            sh_state["ingested_event_ids"] = []
        sync_state["scripthistory"] = sh_state
        mutable["sync_state"] = sync_state
    return mutable


def _derive_error_code(error: str) -> str:
    token = ERROR_CODE_TOKEN_RE.sub("_", str(error or "").strip()).strip("_").upper()
    return token or "UNKNOWN_ERROR"


def _default_retryable(error_code: str) -> bool:
    code = str(error_code or "").upper()
    if code in {"LOCK_TIMEOUT", "TIMEOUT", "IO_ERROR"}:
        return True
    if "TIMEOUT" in code or "LOCK" in code:
        return True
    return False


def _error_payload(error: str, detail: str, **extra: Any) -> Dict[str, Any]:
    normalized_error = str(error or "")
    error_code = str(extra.pop("error_code", "") or "").strip() or _derive_error_code(normalized_error)
    retryable_extra = extra.pop("retryable", None)
    payload: Dict[str, Any] = {
        "ok": False,
        "error": normalized_error,
        "error_code": error_code,
        "detail": str(detail or ""),
        "retryable": _default_retryable(error_code) if retryable_extra is None else bool(retryable_extra),
    }
    payload.update(extra)
    return payload


def _classify_exception(exc: BaseException) -> Tuple[str, Optional[bool]]:
    if isinstance(exc, _HypothesisArgparseError):
        return ("ARGPARSE_ERROR", False)
    if isinstance(exc, FileLockTimeout):
        return ("LOCK_TIMEOUT", True)
    if isinstance(exc, PermissionError):
        return ("PERMISSION_DENIED", False)
    if isinstance(exc, FileNotFoundError):
        return ("NOT_FOUND", False)
    if isinstance(exc, TimeoutError):
        return ("TIMEOUT", True)
    if isinstance(exc, ValueError):
        return ("VALIDATION_ERROR", False)
    if isinstance(exc, OSError):
        return ("IO_ERROR", True)
    return ("UNHANDLED_EXCEPTION", None)


