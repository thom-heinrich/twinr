    if path.startswith("scripts/"):
        return (1, path)
    if path.startswith("systemd/units/"):
        return (2, path)
    if path.startswith("agentic_tools/"):
        return (3, path)
    if path.startswith("llm/"):
        return (4, path)
    if path.startswith("artifacts/llm/"):
        return (4, path)
    if path.startswith("config/"):
        return (5, path)
    if path.startswith("clickhouse/"):
        return (6, path)
    if path.startswith("contracts/"):
        return (7, path)
    if path.startswith("schemas/"):
        return (8, path)
    if path.startswith("artifacts/evaluations/"):
        return (9, path)
    if path.startswith("artifacts/audit/"):
        return (10, path)
    if path.startswith("docs/"):
        return (11, path)
    return (50, path)


