def cmd_list(args: argparse.Namespace) -> None:
    """List hypotheses, optionally filtered by status/scope/topic/tag."""
    store = load_store()
    hypotheses = list(store.get("hypotheses", {}).values())

    status_filters = set(args.status or [])
    scope_filters = set(args.scope or [])
    tag_filters = set(args.tag or [])
    topic_filters = set(args.topic or [])
    search = args.search.lower() if args.search else None

    def _matches(h: Mapping[str, Any]) -> bool:
        if status_filters and h.get("status") not in status_filters:
            return False
        if scope_filters and h.get("scope") not in scope_filters:
            return False
        if tag_filters:
            tags = set(h.get("tags") or [])
            if not tags.intersection(tag_filters):
                return False
        if topic_filters:
            topics = set(h.get("topics") or [])
            if not topics.intersection(topic_filters):
                return False
        if search:
            hay = " ".join(
                [
                    str(h.get("id") or ""),
                    str(h.get("title") or ""),
                    str(h.get("statement") or ""),
                ]
            ).lower()
            if search not in hay:
                return False
        return True

    filtered = [h for h in hypotheses if isinstance(h, Mapping) and _matches(h)]
    filtered.sort(key=lambda h: (str(h.get("created_at") or ""), str(h.get("id") or "")))

    limit = args.limit
    if limit is not None and limit > 0 and len(filtered) > limit:
        filtered = filtered[-limit:]

    out = [_public_hypothesis(store, h) for h in filtered]
    payload: Dict[str, Any] = {
        "ok": True,
        "action": "list",
        "store_path": str(STORE_PATH),
        "store_stats": _compute_store_stats(store),
        "filters": {
            "status": sorted(status_filters) or None,
            "scope": sorted(scope_filters) or None,
            "tag": sorted(tag_filters) or None,
            "topic": sorted(topic_filters) or None,
            "search": search,
            "limit": limit,
        },
        "hypotheses": out,
        "count": len(out),
        "recommended_next_calls": [
            "hypothesis explain --id <Hxxxxx>",
            "hypothesis get --id <Hxxxxx> --include-evidence",
        ],
        "next_steps": [
            {
                "text": "Explain a hypothesis to see normalized what/why/how + guardrails and links.",
                "commands": ["hypothesis explain --id <Hxxxxx>"],
                "links": [],
            },
            {
                "text": "Open one hypothesis with evidence when you need full grounding.",
                "commands": ["hypothesis get --id <Hxxxxx> --include-evidence"],
                "links": [],
            },
        ],
    }
    _emit_json(payload)


def cmd_get(args: argparse.Namespace) -> None:
    """Retrieve a single hypothesis (optionally with evidence)."""
    hypothesis_id = (
        str(getattr(args, "id", "") or "").strip()
        or str(getattr(args, "id_positional", "") or "").strip()
    )
    if not hypothesis_id:
        _emit_json(
            _error_payload(
                "invalid_arguments",
                "Missing hypothesis id. Provide --id <Hxxxxx> (or --hypothesis-id) or a positional id.",
                error_code="ARGPARSE_ERROR",
                retryable=False,
            )
        )
        sys.exit(2)
    store = load_store()
    hypotheses = store.get("hypotheses", {})
    hypothesis = hypotheses.get(hypothesis_id)
    if not hypothesis:
        _emit_json(
            _error_payload(
                "not_found",
                f"Hypothesis '{hypothesis_id}' not found.",
                id=hypothesis_id,
            )
        )
        sys.exit(1)

    enriched = _public_hypothesis(store, hypothesis)
    payload: Dict[str, Any] = {
        "ok": True,
        "action": "get",
        "store_path": str(STORE_PATH),
        "hypothesis": enriched,
    }
    payload["next_steps"] = next_steps_for_hypothesis_action(
        action="get",
        hypothesis_id=str(enriched.get("id") or hypothesis_id),
        status=str(enriched.get("status") or ""),
        links=list(enriched.get("links") or []) if isinstance(enriched.get("links"), list) else [],
        evidence_stats=enriched.get("evidence_stats") if isinstance(enriched.get("evidence_stats"), Mapping) else None,
    )

    if args.include_evidence:
        evidence_map = store.get("evidence", {})
        evidence_entries: List[Dict[str, Any]] = []
        if isinstance(evidence_map, Mapping):
            for ev in evidence_map.values():
                if not isinstance(ev, Mapping):
                    continue
                if ev.get("hypothesis_id") != hypothesis_id:
                    continue
                evidence_entries.append(dict(ev))
        evidence_entries.sort(
            key=lambda ev: (str(ev.get("created_at") or ""), str(ev.get("id") or ""))
        )
        payload["evidence"] = evidence_entries
        payload["evidence_count"] = len(evidence_entries)

    _emit_json(payload)


