class _HypothesisArgparseError(Exception):
    """Raised when argument parsing fails and should return JSON output."""

    def __init__(self, message: str, usage: str = "") -> None:
        super().__init__(message)
        self.message = str(message)
        self.usage = str(usage or "")


class _HypothesisArgumentParser(argparse.ArgumentParser):
    """Argument parser that preserves JSON-only stdout on errors."""

    def error(self, message: str) -> None:  # noqa: A003 (argparse API)
        raise _HypothesisArgparseError(str(message), self.format_usage())


