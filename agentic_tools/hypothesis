def main(argv: Optional[List[str]] = None) -> None:
    """Entry point for the CLI."""
    configure_logging()
    parser = build_parser()
    argv_list = list(sys.argv[1:] if argv is None else argv)
    pretty_guess = "--json-pretty" in argv_list

    # Allow global flags to appear after the subcommand (LLM/tool friendly).
    moved: List[str] = []
    rest: List[str] = []
    for a in argv_list:
        if a == "--json-pretty":
            moved.append(a)
        else:
            rest.append(a)
    argv_list = moved + rest

    try:
        args = parser.parse_args(argv_list)
    except _HypothesisArgparseError as exc:
        payload = _error_payload(
            "invalid_arguments",
            exc.message,
            error_code="ARGPARSE_ERROR",
            retryable=False,
        )
        usage = (exc.usage or "").strip()
        if usage:
            payload["usage"] = usage
        _emit_json(payload, pretty=pretty_guess)
        sys.exit(2)
    except SystemExit:
        raise

    global _JSON_PRETTY
    _JSON_PRETTY = bool(getattr(args, "json_pretty", False))
    if not hasattr(args, "func"):
        _emit_json(
            _error_payload(
                "missing_command",
                "No command specified. Use 'hypothesis --help' for usage.",
            )
        )
        sys.exit(1)
    try:
        if str(getattr(args, "command", "") or "") in _MUTATING_COMMANDS:
            _run_mutation_with_retry(str(getattr(args, "command", "") or ""), lambda: args.func(args))
        else:
            args.func(args)
    except SystemExit:
        raise
    except Exception as exc:
        error_code, retryable = _classify_exception(exc)
        _emit_json(
            _error_payload(
                "internal_error",
                str(exc),
                error_code=error_code,
                retryable=retryable,
            )
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
