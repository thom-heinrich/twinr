def _is_user_facing_tool_name(name: str) -> bool:
    value = str(name or "").strip()
    if not value:
        return False
    if value.startswith("_"):
        return False
    if value in _INTERNAL_TOOL_NAMES:
        return False
    if value in _INTERNAL_DEFAULT_HIDDEN:
        return False
    if value.endswith(".py"):
        return False
    if value in _USER_FACING_ALLOWLIST:
        return True
    # Prefer explicit curation. Generic placeholder descriptions indicate
    # low-confidence tool metadata and are hidden by default.
    desc = TOOL_DESCRIPTIONS.get(value, "")
    if desc and not desc.startswith("Agentic tool in this repository;"):
        return True
    return False


@dataclass
class ToolInfo:
    name: str
    path: Path
    description: str
    in_path: bool
    user_facing: bool
    commands: Optional[Dict[str, str]] = None
    schema_supported: bool = False
    schema_error: Optional[str] = None

    def to_public(self) -> Dict[str, Any]:
        visibility = "user_facing" if bool(self.user_facing) else "internal"
        tier = "internal"
        if bool(self.user_facing):
            # "core" tools are explicitly allowlisted; "extended" tools are
            # still user-facing but less frequently used.
            tier = "core" if self.name in _USER_FACING_ALLOWLIST else "extended"
        out: Dict[str, Any] = {
            "name": self.name,
            "path": str(self.path),
            "description": self.description,
            "in_path": self.in_path,
            "user_facing": bool(self.user_facing),
            "internal": not bool(self.user_facing),
            "visibility": visibility,
            "tier": tier,
            "schema_supported": self.schema_supported,
        }
        if self.commands is not None:
            out["commands"] = self.commands
        if self.schema_error is not None:
            out["schema_error"] = self.schema_error
        return out


def discover_tools(tools_dir: Path, *, include_internal: bool = False) -> List[ToolInfo]:
    """Discover tools in the given directory."""
    logging.info("Discovering tools in %s", tools_dir)
    if not tools_dir.is_dir():
        payload = _error_payload(
            "tools_dir_not_found",
            f"Tools directory does not exist: {tools_dir}",
            error_code="TOOLS_DIR_NOT_FOUND",
            retryable=False,
            tools_dir=str(tools_dir),
        )
        print(json.dumps(payload))
        sys.exit(1)

    tool_infos: List[ToolInfo] = []
    for entry in sorted(tools_dir.iterdir(), key=lambda p: p.name):
        if not entry.is_file():
            continue
        # Skip hidden files, Markdown/docs and other non-CLI artefacts that may
        # accidentally be executable (e.g. .chatlog.test.json), so that we only
        # treat real CLIs as tools.
        if entry.name.startswith("."):
            continue
        if entry.suffix.lower() in {
            ".md",
            ".rst",
            ".json",
            ".yml",
            ".yaml",
            ".log",
            ".tmp",
        }:
            continue
        if not os.access(entry, os.X_OK):
            continue
        name = entry.name
        user_facing = _is_user_facing_tool_name(name)
        if not include_internal and not user_facing:
            continue
        # Explicitly hide decommissioned tools from the meta listing so that
        # agents do not discover or rely on them anymore.
        if name in {"worklock", "lock", "ontology_tool"}:
            logging.info(
                "Skipping decommissioned agentic tool '%s' in meta listing.", name
            )
            continue
        description = TOOL_DESCRIPTIONS.get(
            name,
            "Agentic tool in this repository; use 'tools help {name}' for details.".format(
                name=name
            ),
        )
        in_path = shutil.which(name) is not None
        tool_infos.append(
            ToolInfo(
                name=name,
                path=entry.resolve(),
                description=description,
                in_path=in_path,
                user_facing=user_facing,
            )
        )
    logging.info("Discovered %d tools.", len(tool_infos))

    # Virtual/installed tools: surface stable names even if the repo directory
    # name is already used for a module folder (e.g. agentic_tools/fixreport/).
    # In this repo copy we keep the package folders plus local *_cli wrappers.
    virtual_tools = {
        "fixreport": "fixreport_cli",
        "healthstream": "healthstream_cli",
        "findings": "findings_cli",
        "code_graph": "code_graph_cli",
    }
    existing = {t.name for t in tool_infos}
    for name, executable_name in virtual_tools.items():
        if name in existing:
            continue
        candidate = tools_dir / executable_name
        if candidate.is_file() and os.access(candidate, os.X_OK):
            path = str(candidate.resolve())
        else:
            path = shutil.which(executable_name)
        if not path:
            continue
        tool_infos.append(
            ToolInfo(
                name=name,
                path=Path(path).resolve(),
                description=TOOL_DESCRIPTIONS.get(
                    name, f"Agentic tool '{name}' in PATH."
                ),
                in_path=shutil.which(name) is not None,
                user_facing=_is_user_facing_tool_name(name),
            )
        )
    tool_infos.sort(key=lambda x: x.name)
    return tool_infos


@dataclass
class _CappedStream:
    limit: int
    buf: bytearray = field(default_factory=bytearray)
    truncated: bool = False

    def append(self, chunk: bytes) -> None:
        if not chunk:
            return
        if self.limit <= 0:
            # Unlimited (not recommended); keep behavior explicit.
            self.buf.extend(chunk)
            return
        remaining = self.limit - len(self.buf)
        if remaining <= 0:
            self.truncated = True
            return
        if len(chunk) <= remaining:
            self.buf.extend(chunk)
            if len(self.buf) >= self.limit:
                self.truncated = True
            return
        self.buf.extend(chunk[:remaining])
        self.truncated = True


@dataclass
class _SubprocessCappedResult:
    returncode: Optional[int]
    stdout_text: str
    stderr_text: str
    timed_out: bool
    stdout_truncated: bool
    stderr_truncated: bool


def _build_child_env() -> Optional[Dict[str, str]]:
    """
    Child env behavior:
    - Default: inherit environment (drop-in).
    - Optional: TOOLS_SANITIZE_SUBPROCESS_ENV=1 to reduce inherited env surface.
    - Always: default NO_COLOR / PYTHON_COLORS if not already set, to stabilize help/schema output.
    """
    base = dict(os.environ)

    if _env_truthy("TOOLS_SANITIZE_SUBPROCESS_ENV"):
        allow = {
            "PATH",
            "HOME",
            "USER",
            "LOGNAME",
            "TMPDIR",
            "TEMP",
            "TMP",
            "LANG",
            "LC_ALL",
            "LC_CTYPE",
            "SHELL",
            "COMSPEC",
            "SYSTEMROOT",
            "WINDIR",
        }
        sanitized: Dict[str, str] = {}
        for k, v in base.items():
            if k in allow or k.startswith("TOOLS_"):
                sanitized[k] = v
        base = sanitized

    # Reduce ANSI noise where tools honor standard conventions; do not override if already set.
    base.setdefault("NO_COLOR", "1")
    base.setdefault("PYTHON_COLORS", "0")
    return base


def _terminate_process(proc: subprocess.Popen, kill_process_group: bool) -> None:
    if proc.poll() is not None:
        return

    if kill_process_group and os.name == "posix":
        try:
            os.killpg(proc.pid, signal.SIGTERM)
        except ProcessLookupError:
            return
        except Exception:
            # Fallback if killpg fails.
            try:
                proc.terminate()
            except Exception:
                return
    else:
        try:
            proc.terminate()
        except Exception:
            return


def _kill_process(proc: subprocess.Popen, kill_process_group: bool) -> None:
    if proc.poll() is not None:
        return

    if kill_process_group and os.name == "posix":
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            return
        except Exception:
            try:
                proc.kill()
            except Exception:
                return
    else:
        try:
            proc.kill()
        except Exception:
            return


def _read_stream_fully(stream, capped: _CappedStream) -> None:
    try:
        while True:
            chunk = stream.read(4096)
            if not chunk:
                break
            if capped.truncated:
                # Still drain to avoid subprocess blocking on full pipes.
                continue
            capped.append(chunk)
    except Exception:
        # Best-effort capture; errors here should not crash the parent process.
        return
    finally:
        try:
            stream.close()
        except Exception:
            pass


def _run_subprocess_capped(
    argv: Sequence[str],
    timeout: float,
    max_stdout_bytes: int,
    max_stderr_bytes: int,
) -> _SubprocessCappedResult:
    """
    Run a subprocess with:
    - stdin=DEVNULL (avoid hangs on stdin reads),
    - bounded stdout/stderr in memory with draining beyond cap (DoS-safe),
    - hard timeout with best-effort process-group termination on POSIX,
    - UTF-8 decoding with errors=replace (avoid UnicodeDecodeError crashes),
    - ANSI escape stripping for cleaner deterministic payloads.
    """
    kill_process_group = os.name == "posix"
    start_new_session = kill_process_group  # safe only on POSIX
    child_env = _build_child_env()

    stdout_cap = _CappedStream(limit=max_stdout_bytes)
    stderr_cap = _CappedStream(limit=max_stderr_bytes)

    try:
        proc = subprocess.Popen(
            list(argv),
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            close_fds=True,
            env=child_env,
            start_new_session=start_new_session,
        )
    except FileNotFoundError:
        raise
    except Exception:
        raise

    assert proc.stdout is not None
    assert proc.stderr is not None

    t_out = threading.Thread(
        target=_read_stream_fully, args=(proc.stdout, stdout_cap), daemon=True
    )
    t_err = threading.Thread(
        target=_read_stream_fully, args=(proc.stderr, stderr_cap), daemon=True
    )
    t_out.start()
    t_err.start()

    timed_out = False
    try:
        proc.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        timed_out = True
        _terminate_process(proc, kill_process_group=kill_process_group)
        try:
            proc.wait(timeout=_env_int("TOOLS_SUBPROCESS_TERM_GRACE_MS", 200) / 1000.0)
        except subprocess.TimeoutExpired:
            _kill_process(proc, kill_process_group=kill_process_group)
            try:
                proc.wait(
                    timeout=_env_int("TOOLS_SUBPROCESS_KILL_GRACE_MS", 200) / 1000.0
                )
            except Exception:
                pass
        except Exception:
            pass
    except Exception:
        # Unexpected wait error: attempt to terminate and proceed with whatever we captured.
        _terminate_process(proc, kill_process_group=kill_process_group)
        try:
            proc.wait(timeout=0.2)
        except Exception:
            pass

    # Ensure reader threads have a chance to drain remaining output.
    try:
        t_out.join(timeout=1.0)
        t_err.join(timeout=1.0)
    except Exception:
        pass

    returncode = proc.returncode

    stdout_text = stdout_cap.buf.decode("utf-8", errors="replace")
    stderr_text = stderr_cap.buf.decode("utf-8", errors="replace")
    stdout_text = _strip_ansi(stdout_text)
    stderr_text = _strip_ansi(stderr_text)

    return _SubprocessCappedResult(
        returncode=returncode,
        stdout_text=stdout_text,
        stderr_text=stderr_text,
        timed_out=timed_out,
        stdout_truncated=stdout_cap.truncated,
        stderr_truncated=stderr_cap.truncated,
    )


def _schema_worker(
    tool_path: Path,
    timeout: float,
    max_stdout_bytes: int,
    max_stderr_bytes: int,
) -> Tuple[bool, Optional[Dict[str, str]], Optional[str]]:
    """
    Returns: (schema_supported, commands, schema_error)
    """
    try:
        res = _run_subprocess_capped(
            [str(tool_path), "schema"],
            timeout=timeout,
            max_stdout_bytes=max_stdout_bytes,
            max_stderr_bytes=max_stderr_bytes,
        )
    except FileNotFoundError as exc:
        return (False, None, f"Executable not found: {exc}")
    except Exception as exc:
        return (False, None, f"schema_call_exception: {exc}")

    if res.timed_out:
        return (False, None, "schema_call_timeout")

    if res.returncode != 0:
        stderr_lines = (res.stderr_text or "").splitlines()
        if len(stderr_lines) > 5:
            stderr_lines = stderr_lines[:5] + ["..."]
        return (
            False,
            None,
            f"schema_call_failed (code={res.returncode}, stderr={stderr_lines})",
        )

    try:
        payload = json.loads(res.stdout_text or "{}")
    except json.JSONDecodeError as exc:
        return (False, None, f"invalid_schema_json: {exc}")

    commands = payload.get("commands")
    if isinstance(commands, dict):
        items: List[Tuple[str, str]] = [(str(k), str(v)) for k, v in commands.items()]
        items.sort(key=lambda kv: kv[0])
        return (True, dict(items), None)

    return (False, None, "no_commands_field_in_schema")


def enrich_with_schema(tool_infos: List[ToolInfo], timeout: float = 5.0) -> None:
    """Attempt to enrich each ToolInfo with commands from `<tool> schema`."""
    # Caps are sized to prevent memory blowups while keeping typical help/schema outputs intact.
    schema_max_stdout = _env_int("TOOLS_SCHEMA_MAX_STDOUT_BYTES", 256 * 1024)
    schema_max_stderr = _env_int("TOOLS_SCHEMA_MAX_STDERR_BYTES", 64 * 1024)
    max_workers = _env_int("TOOLS_SCHEMA_MAX_WORKERS", 4)

    # Filter upfront to keep pool sizing stable and deterministic.
    targets: List[ToolInfo] = []
    for info in tool_infos:
        # Avoid recursion: do not try to call tools schema on itself for 'tools'.
        if info.name == "tools":
            continue
        targets.append(info)

    if not targets:
        return

    workers = max(1, min(max_workers, len(targets)))

    # Parallelize schema calls with bounded concurrency to avoid N*timeout latency.
    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as ex:
        future_to_info: Dict[concurrent.futures.Future, ToolInfo] = {}
        for info in targets:
            logging.info("Querying schema for tool '%s'.", info.name)
            fut = ex.submit(
                _schema_worker,
                info.path,
                timeout,
                schema_max_stdout,
                schema_max_stderr,
            )
            future_to_info[fut] = info

        for fut in concurrent.futures.as_completed(future_to_info):
            info = future_to_info[fut]
            try:
                supported, commands, err = fut.result()
            except Exception as exc:
                info.schema_supported = False
                info.schema_error = f"schema_call_exception: {exc}"
                continue

            info.schema_supported = supported
            info.commands = commands
            info.schema_error = err


def categorize_user_facing_tools(tool_names: Iterable[str]) -> Tuple[Dict[str, List[str]], Dict[str, str]]:
    """
    Categorize user-facing tools for discovery UX.

    Contract:
    - Deterministic output (stable ordering).
    - Each tool appears in at most one category.
    - Any uncategorized tool is placed under "other".
    """
    names = {str(x or "").strip() for x in tool_names if str(x or "").strip()}

    # Ordered, curated buckets. The first matching bucket wins.
    category_specs: List[Tuple[str, List[str]]] = [
        (
            "core",
            [
                "tools",
                "tasks",
                "findings",
                "fixreport",
                "bug-memory",
                "rules",
                "ssot",
                "scripthistory",
                "scriptinfo",
                "hypothesis",
                "chat",
                "endturn",
            ],
        ),
        ("quality", ["checkreview", "metric-eval"]),
        ("blackbook", ["bug-blackbook", "policy-blackbook"]),
        ("ops", ["healthstream", "svc_health_check", "admintool", "gpu", "codex_compact", "tessairact-workspace"]),
        ("research", ["research", "rit"]),
        ("interop", ["mcp"]),
        ("media", ["web-slides", "qwen3tts"]),
        ("refactor", ["safemove"]),
    ]

    assigned: set[str] = set()
    categories: Dict[str, List[str]] = {}
    tool_to_category: Dict[str, str] = {}

    for category, group in category_specs:
        present: List[str] = []
        for tool in group:
            if tool not in names or tool in assigned:
                continue
            assigned.add(tool)
            present.append(tool)
            tool_to_category[tool] = category
        if present:
            categories[category] = present

    remaining = sorted([tool for tool in names if tool not in assigned])
    if remaining:
        categories["other"] = remaining
        for tool in remaining:
            tool_to_category[tool] = "other"
    return categories, tool_to_category


def cmd_list(args: argparse.Namespace) -> None:
    """List all agentic tools with summaries."""
    tools_dir = resolve_tools_dir(args.dir)
    tool_infos = discover_tools(tools_dir, include_internal=bool(args.all_tools))
    if args.include_commands:
        enrich_with_schema(tool_infos, timeout=args.schema_timeout)

    categories, tool_to_category = categorize_user_facing_tools(
        [info.name for info in tool_infos if info.user_facing]
    )
    tools_payload = [info.to_public() for info in tool_infos]
    for tool in tools_payload:
        if tool.get("user_facing") is True:
            tool["category"] = tool_to_category.get(str(tool.get("name") or ""), "other")
    visibility_filter = "all" if bool(args.all_tools) else "user_facing"
    counts_by_visibility = {
        "user_facing": sum(1 for info in tool_infos if info.user_facing),
        "internal": sum(1 for info in tool_infos if not info.user_facing),
    }
    print(
        json.dumps(
            {
                "ok": True,
                "action": "list",
                "tools_dir": str(tools_dir),
                "tools": tools_payload,
                "count": len(tools_payload),
                "include_commands": bool(args.include_commands),
                "all_tools": bool(args.all_tools),
                "visibility_filter": visibility_filter,
                "counts_by_visibility": counts_by_visibility,
                "categories": categories,
                "machine_readable": True,
            }
        )
    )


def cmd_summary(args: argparse.Namespace) -> None:
    """Emit a high-level taxonomy of tools grouped by role."""
    tools_dir = resolve_tools_dir(args.dir)
    tool_infos = discover_tools(tools_dir, include_internal=False)
    names = {info.name for info in tool_infos}
    categories, _ = categorize_user_facing_tools(
        [info.name for info in tool_infos if info.user_facing]
    )

    deprecated_tools = [name for name in ["kanban"] if name in names]

    print(
        json.dumps(
            {
                "ok": True,
                "action": "summary",
                "tools_dir": str(tools_dir),
                "categories": categories,
                "deprecated_tools": deprecated_tools,
                "machine_readable": True,
            }
        )
    )


def cmd_help(args: argparse.Namespace) -> None:
    """Retrieve the help text for a specific tool."""
    tools_dir = resolve_tools_dir(args.dir)
    tools = {info.name: info for info in discover_tools(tools_dir, include_internal=True)}
    tool_name = args.tool
    info = tools.get(tool_name)

    # If not found in the local directory, fall back to PATH (unless disabled via env).
    tool_path: Optional[str]
    if info is not None:
        tool_path = str(info.path)
    else:
        if _env_truthy("TOOLS_DISABLE_PATH_FALLBACK"):
            tool_path = None
        else:
            tool_path = shutil.which(tool_name)

    if not tool_path:
        payload = _error_payload(
            "tool_not_found",
            f"Tool '{tool_name}' not found in tools dir or PATH.",
            error_code="TOOL_NOT_FOUND",
            retryable=False,
            tool=tool_name,
            tools_dir=str(tools_dir),
        )
        print(json.dumps(payload))
        sys.exit(1)

    logging.info("Retrieving --help for tool '%s' at %s.", tool_name, tool_path)
    try:
        help_max_stdout = _env_int("TOOLS_HELP_MAX_STDOUT_BYTES", 1024 * 1024)
        help_max_stderr = _env_int("TOOLS_HELP_MAX_STDERR_BYTES", 256 * 1024)
        res = _run_subprocess_capped(
            [tool_path, "--help"],
            timeout=args.help_timeout,
            max_stdout_bytes=help_max_stdout,
            max_stderr_bytes=help_max_stderr,
        )
    except FileNotFoundError as exc:
        payload = _error_payload(
            "tool_executable_not_found",
            str(exc),
            error_code="TOOL_EXECUTABLE_NOT_FOUND",
            retryable=False,
            tool=tool_name,
            path=tool_path,
        )
        print(json.dumps(payload))
        sys.exit(1)
    except Exception as exc:
        payload = _error_payload(
            "help_call_failed",
            f"Failed while running '{tool_name} --help': {exc}",
            error_code="HELP_CALL_FAILED",
            retryable=True,
            tool=tool_name,
            path=tool_path,
        )
        print(json.dumps(payload))
        sys.exit(1)

    if res.timed_out:
        payload = _error_payload(
            "help_call_timeout",
            f"Timed out while running '{tool_name} --help'.",
            error_code="HELP_CALL_TIMEOUT",
            retryable=True,
            tool=tool_name,
            path=tool_path,
        )
        print(json.dumps(payload))
        sys.exit(1)

    if res.returncode != 0:
        # Keep payload schema stable; only truncate stderr if it would be excessive.
        stderr_text = res.stderr_text or ""
        stderr_max_chars = _env_int("TOOLS_HELP_ERROR_STDERR_MAX_CHARS", 32_768)
        if len(stderr_text) > stderr_max_chars:
            stderr_text = stderr_text[:stderr_max_chars] + "\n..."
        payload = _error_payload(
            "help_call_failed",
            f"'--help' exited with code {res.returncode}.",
            error_code="HELP_CALL_FAILED",
            retryable=False,
            tool=tool_name,
            path=tool_path,
            stderr=stderr_text,
        )
        print(json.dumps(payload))
        sys.exit(1)

    help_text = res.stdout_text or ""
    tool_info_payload: Optional[Dict[str, Any]] = info.to_public() if info is not None else None
    print(
        json.dumps(
            {
                "ok": True,
                "action": "help",
                "tool": tool_name,
                "path": tool_path,
                "help_text": help_text,
                "tool_info": tool_info_payload,
                "machine_readable": True,
            }
        )
    )


def _parse_json_stdout(tool: str, stdout_text: str) -> Tuple[Optional[Dict[str, Any]], Optional[str]]:
    if not stdout_text or not stdout_text.strip():
        return None, f"{tool}: empty stdout"
    try:
        return json.loads(stdout_text), None
    except Exception as exc:
        return None, f"{tool}: stdout is not valid JSON: {exc}"


def _has_error_envelope_fields(doc: Mapping[str, Any]) -> bool:
    return all(k in doc for k in ("ok", "error", "error_code", "detail", "retryable"))


def _has_hint_envelope_fields(doc: Mapping[str, Any]) -> bool:
    return all(k in doc for k in ("hints_version", "hints", "suppressed_hints", "next_tools", "hint_stats", "hint_engine"))


def _has_hint_envelope_schema(doc: Mapping[str, Any]) -> bool:
    if "hint_envelope" in doc:
        return True
    schema = doc.get("schema")
    return isinstance(schema, Mapping) and "hint_envelope" in schema


def cmd_validate(args: argparse.Namespace) -> None:
    """
    Validate core CLI contracts (JSON + error envelope + hint envelope).

    This is intentionally conservative: it runs only read-only commands that
    should have no side effects and finishes quickly with strict timeouts.
    """
    tools_dir = resolve_tools_dir(args.dir)
    timeout = float(getattr(args, "timeout", 5.0) or 5.0)
    max_stdout = _env_int("TOOLS_VALIDATE_MAX_STDOUT_BYTES", 2 * 1024 * 1024)
    max_stderr = _env_int("TOOLS_VALIDATE_MAX_STDERR_BYTES", 512 * 1024)

    # Core user-facing CLIs we rely on for governance + workflows.
    cases: List[Dict[str, Any]] = [
        {"name": "findings", "success": ["findings", "schema"], "error": ["findings", "get"], "expect_hints": True},
        {"name": "fixreport", "success": ["fixreport", "schema"], "error": ["fixreport", "schema", "--json"], "expect_hints": True},
        {"name": "tasks", "success": ["tasks", "schema"], "error": ["tasks", "schema", "--json-pretty"], "expect_hints": True},
        {"name": "hypothesis", "success": ["hypothesis", "schema"], "error": ["hypothesis", "get"], "expect_hints": True},
        {"name": "rules", "success": ["rules", "schema"], "error": ["rules", "explain"], "expect_hints": True},
        {"name": "ssot", "success": ["ssot", "schema"], "error": ["ssot", "get"], "expect_hints": True},
        {"name": "scripthistory", "success": ["scripthistory", "schema"], "error": ["scripthistory", "get"], "expect_hints": True},
        {"name": "scriptinfo", "success": ["scriptinfo", "schema"], "error": ["scriptinfo"], "expect_hints": True},
        {"name": "tools", "success": ["tools", "list"], "error": ["tools", "list", "--nope"], "expect_hints": False},
    ]

    results: List[Dict[str, Any]] = []
    ok_all = True
    for case in cases:
        tool_name = str(case["name"])
        tool_ok = True
        tool_checks: List[Dict[str, Any]] = []

        for check_id, argv, expect_ok in [
            ("success", list(case["success"]), True),
            ("error", list(case["error"]), False),
        ]:
            check_passed = True
            res = _run_subprocess_capped(
                argv,
                timeout=timeout,
                max_stdout_bytes=max_stdout,
                max_stderr_bytes=max_stderr,
            )
            doc, parse_err = _parse_json_stdout(tool_name, res.stdout_text or "")
            check: Dict[str, Any] = {
                "id": check_id,
                "argv": argv,
                "returncode": int(res.returncode),
                "timed_out": bool(res.timed_out),
                "ok": False,
                "parse_error": parse_err,
            }
            if res.timed_out:
                check["error"] = "timeout"
                check_passed = False
                tool_checks.append(check)
                continue
            if parse_err or doc is None or not isinstance(doc, Mapping):
                check["error"] = "invalid_json"
                check["stderr"] = res.stderr_text or ""
                check_passed = False
                tool_checks.append(check)
                continue

            check_ok = bool(doc.get("ok") is True) if expect_ok else bool(doc.get("ok") is False)
            if not check_ok:
                check["error"] = "unexpected_ok_flag"
                check["doc_ok"] = doc.get("ok")
                check_passed = False

            if expect_ok:
                if bool(case.get("expect_hints")):
                    if not _has_hint_envelope_fields(doc):
                        check["error"] = "missing_hint_envelope"
                        check_passed = False
                    if not _has_hint_envelope_schema(doc):
                        check["error"] = "missing_hint_schema"
                        check_passed = False
            else:
                if not _has_error_envelope_fields(doc):
                    check["error"] = "missing_error_envelope"
                    check_passed = False

            check["ok"] = bool(check_passed)
            tool_checks.append(check)
            if not check_passed:
                tool_ok = False

        results.append({"name": tool_name, "ok": tool_ok, "checks": tool_checks})
        if not tool_ok:
            ok_all = False

    print(
        json.dumps(
            {
                "ok": ok_all,
                "action": "validate",
                "tools_dir": str(tools_dir),
                "results": results,
                "count": len(results),
                "failed": [r["name"] for r in results if not r["ok"]],
                "machine_readable": True,
            }
        )
    )


@dataclass
class _CliTrap(Exception):
    status: int
    payload: Dict[str, Any]


class _HelpAction(argparse.Action):
    def __call__(self, parser, namespace, values, option_string=None):
        if _json_help_enabled():
            raise _CliTrap(
                status=0,
                payload={
                    "ok": True,
                    "action": "cli_help",
                    "help_text": parser.format_help(),
                },
            )
        parser.print_help()
        parser.exit(0)


class ToolsArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        raise _CliTrap(
            status=2,
            payload=_error_payload(
                "invalid_arguments",
                str(message),
                error_code="ARGPARSE_ERROR",
                retryable=False,
                usage=self.format_usage(),
            ),
        )


def build_parser() -> argparse.ArgumentParser:
    """Build the top-level argument parser with rich help text."""
    description = (
        "Meta-CLI for agentic tools in this repository.\n\n"
        "Use this tool to discover which helper CLIs are available (kanban,\n"
        "rules, chat, ssot, scripthistory, etc.) and to retrieve\n"
        "their detailed --help output in a JSON-safe way.\n\n"
        "Common workflows:\n"
        "  - List all tools with summaries:\n"
        "      tools list --include-commands\n"
        "  - Inspect detailed help for a specific tool:\n"
        "      tools help kanban\n"
    )
    epilog = (
        "Exit codes:\n"
        "  0  Command succeeded.\n"
        "  1  Command failed (e.g. invalid arguments, not found).\n\n"
        "All commands print a single JSON object to stdout.\n"
        "Errors are also returned as JSON with at least: ok=false, error, detail.\n"
        "Verbose logs and heartbeats are written to stderr for observability.\n"
    )

    # Keep drop-in behavior for -h/--help in normal mode, while allowing an opt-in
    # JSON-only mode via TOOLS_STRICT_JSON=1 without changing CLI flags.
    parser = ToolsArgumentParser(
        prog="tools",
        description=description,
        epilog=epilog,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    parser.add_argument(
        "-h",
        "--help",
        action=_HelpAction,
        nargs=0,
        help="show this help message and exit",
    )

    parser.add_argument(
        "--dir",
        help=(
            "Explicit path to the agentic tools directory. "
            "Defaults to the directory containing this script."
        ),
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help=(
            "Request machine-readable JSON output explicitly. "
            "This tool is JSON-first; the flag is for deterministic automation."
        ),
    )

    subparsers = parser.add_subparsers(
        dest="command",
        required=True,
        parser_class=ToolsArgumentParser,
    )

    p_list = subparsers.add_parser(
        "list",
        help="List all agentic tools with summaries.",
        description=(
            "List all agentic tools discovered in the tools directory, along\n"
            "with short descriptions and (optionally) subcommand summaries from\n"
            "each tool's JSON schema."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_list.add_argument(
        "--include-commands",
        action="store_true",
        help="If set, query each tool's schema to include command summaries.",
    )
    p_list.add_argument(
        "--schema-timeout",
        type=float,
        default=5.0,
        help="Timeout in seconds for each '<tool> schema' call (default: 5.0).",
    )
    p_list.add_argument(
        "--all-tools",
        action="store_true",
        help=(
            "Include technical/internal helpers in the listing "
            "(default shows user-facing CLIs only)."
        ),
    )
    p_list.add_argument(
        "--json",
        action="store_true",
        help="Request machine-readable JSON output (default behavior).",
    )
    p_list.set_defaults(func=cmd_list)

    p_help = subparsers.add_parser(
        "help",
        help="Retrieve the help text for a specific tool.",
        description=(
            "Retrieve the detailed '--help' output for a specific tool and\n"
            "return it as a JSON field. This is useful for agents that need to\n"
            "inspect human-oriented help text without breaking JSON protocols."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_help.add_argument(
        "tool",
        help="Name of the tool to inspect (e.g. 'rules').",
    )
    p_help.add_argument(
        "--help-timeout",
        type=float,
        default=5.0,
        help="Timeout in seconds for the '<tool> --help' call (default: 5.0).",
    )
    p_help.add_argument(
        "--json",
        action="store_true",
        help="Request machine-readable JSON output (default behavior).",
    )
    p_help.set_defaults(func=cmd_help)

    p_summary = subparsers.add_parser(
        "summary",
        help="Show a high-level taxonomy of tools grouped by role.",
        description=(
            "Emit a high-level taxonomy of tools grouped by role (planning,\n"
            "policy, discovery, hypotheses, operations, refactors).\n"
            "This is a structured JSON view so agents can quickly\n"
            "discover the right tool for a task without parsing AGENTS.md."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_summary.add_argument(
        "--json",
        action="store_true",
        help="Request machine-readable JSON output (default behavior).",
    )
    p_summary.set_defaults(func=cmd_summary)

    p_validate = subparsers.add_parser(
        "validate",
        help="Validate core CLI JSON/error/hint contracts.",
        description=(
            "Run a small read-only contract check over core agentic CLIs.\n"
            "This validates JSON-only stdout, error envelopes, and (for core\n"
            "tools) the presence of the hint envelope + hint schema.\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_validate.add_argument(
        "--timeout",
        type=float,
        default=5.0,
        help="Per-command timeout in seconds (default: 5.0).",
    )
    p_validate.add_argument(
        "--json",
        action="store_true",
        help="Request machine-readable JSON output (default behavior).",
    )
    p_validate.set_defaults(func=cmd_validate)

    return parser


def main(argv: Optional[List[str]] = None) -> None:
    """Entry point for the CLI."""
    global _FORCE_JSON_HELP
    argv_list = list(argv) if argv is not None else sys.argv[1:]
    _FORCE_JSON_HELP = "--json" in argv_list

    configure_logging()
    parser = build_parser()
    try:
        args = parser.parse_args(argv_list)
        args.func(args)
    except _CliTrap as exc:
        # Opt-in JSON-only behavior for argparse help/errors.
        print(json.dumps(exc.payload))
        raise SystemExit(exc.status)
    except SystemExit:
        # Preserve default argparse behavior (drop-in).
        raise


if __name__ == "__main__":
    main()
