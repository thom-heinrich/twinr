_FORCE_JSON_HELP = False


def configure_logging() -> None:
    """Configure verbose logging to stderr for observability."""
    verbose = os.environ.get("TOOLS_VERBOSE", "").strip().lower() in {"1", "true", "yes", "y", "on"}
    logging.basicConfig(
        level=logging.INFO if verbose else logging.WARNING,
        format="%(asctime)s [%(levelname)s] tools %(message)s",
        stream=sys.stderr,
    )


def _env_truthy(name: str) -> bool:
    val = os.environ.get(name, "")
    return val.strip().lower() in {"1", "true", "yes", "y", "on"}


def _env_int(name: str, default: int) -> int:
    raw = os.environ.get(name)
    if raw is None or raw.strip() == "":
        return default
    try:
        n = int(raw)
    except ValueError:
        return default
    if n <= 0:
        return default
    return n


def _strict_json_enabled() -> bool:
    # Opt-in mode for environments that require JSON-only stdout even for
    # argparse help/errors. Default behavior remains unchanged (drop-in).
    return _env_truthy("TOOLS_STRICT_JSON")


def _json_help_enabled() -> bool:
    return _strict_json_enabled() or _FORCE_JSON_HELP


ANSI_ESCAPE_RE = re.compile(r"\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])")


def _strip_ansi(text: str) -> str:
    if not text:
        return text
    return ANSI_ESCAPE_RE.sub("", text)


def _error_payload(
    error: str,
    detail: str,
    *,
    error_code: str = "",
    retryable: bool = False,
    **extra: Any,
) -> Dict[str, Any]:
    code = str(error_code or "").strip() or "UNKNOWN_ERROR"
    payload: Dict[str, Any] = {
        "ok": False,
        "error": str(error or "unknown_error"),
        "error_code": code,
        "detail": str(detail or ""),
        "retryable": bool(retryable),
    }
    payload.update(extra)
    return payload


def resolve_tools_dir(explicit: Optional[str] = None) -> Path:
    """Resolve the agentic tools directory.

    If `explicit` is provided, it is used as a directory path. Otherwise, the
    directory containing this script is used.
    """
    # Optional hardening: allow operators to disallow directory overrides
    # without changing CLI semantics by default.
    if explicit and _env_truthy("TOOLS_DISALLOW_DIR_OVERRIDE"):
        logging.warning("TOOLS_DISALLOW_DIR_OVERRIDE is set; ignoring --dir override.")
        explicit = None

    if explicit:
        return Path(explicit).expanduser().resolve()
    return Path(__file__).resolve().parent


