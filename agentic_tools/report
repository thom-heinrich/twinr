#!/usr/bin/env python3
"""
`report` — Abschlussbericht / Research-Report CLI (JSON-only stdout).

This tool persists "closing reports" (wins, benchmarks, deployments, research)
as durable, linkable artefacts:
- machine store: artifacts/stores/report (YAML + index/events)
- human report:  artifacts/reports/report/<report_id>/report.md (+ assets/)

All truth-edges are carried via `tessairact_meta.links` (LINKS_CONTRACT).
"""

from __future__ import annotations

import sys
from pathlib import Path


def _ensure_repo_root_on_syspath() -> Path:
    here = Path(__file__).resolve()
    repo_root = here.parent.parent
    if str(repo_root) not in sys.path:
        sys.path.insert(0, str(repo_root))
    return repo_root


def main(argv: list[str]) -> int:
    repo_root = _ensure_repo_root_on_syspath()
    from agentic_tools.report_tool.cli import main as _main  # noqa: WPS433

    return int(_main(argv=argv, repo_root=repo_root) or 0)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))

