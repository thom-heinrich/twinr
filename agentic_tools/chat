def cmd_thread(args: argparse.Namespace) -> None:
    """List messages belonging to a thread."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    store = load_store(path)
    messages = store.get("messages", {})

    root_id: Optional[str] = None
    if args.root_id:
        root_id = args.root_id
    elif args.id:
        msg = messages.get(args.id)
        if not msg:
            payload = {
                "ok": False,
                "error": "not_found",
                "detail": f"Message '{args.id}' not found.",
                "id": args.id,
            }
            _safe_print_json(payload)
            sys.exit(1)
        root_id = msg.get("root_id") or msg.get("id")
    else:
        payload = {
            "ok": False,
            "error": "missing_identifier",
            "detail": "Either --root-id or --id must be provided.",
        }
        _safe_print_json(payload)
        sys.exit(1)

    # Collect all messages in the same thread (same root_id).
    thread_messages = [m for m in messages.values() if m.get("root_id") == root_id]
    if not thread_messages:
        payload = {
            "ok": True,
            "action": "thread",
            "file": str(path),
            "root_id": root_id,
            "messages": [],
            "count": 0,
        }
        _safe_print_json(payload)
        return

    thread_messages.sort(key=lambda m: (m.get("created_at", ""), m.get("id", "")))
    out = [message_to_public(m) for m in thread_messages]
    root_msg = messages.get(root_id) if isinstance(messages, dict) else None
    out_doc3: Dict[str, Any] = {
        "ok": True,
        "action": "thread",
        "file": str(path),
        "root_id": root_id,
        "messages": out,
        "count": len(out),
    }
    if isinstance(root_msg, dict):
        out_doc3["next_steps"] = next_steps_for_chat_action(
            action="thread",
            message_id=str(root_msg.get("id") or root_id),
            channel=str(root_msg.get("channel") or ""),
            links=list(root_msg.get("links") or []) if isinstance(root_msg.get("links"), list) else [],
        )
    _safe_print_json(out_doc3)


def cmd_backfill_links(args: argparse.Namespace) -> None:
    """Backfill missing chat message script links based on explicit repo path mentions."""
    actor = str(args.actor or "").strip()
    if not actor:
        payload = {
            "ok": False,
            "error": "missing_actor",
            "detail": "Missing --actor (required).",
        }
        _safe_print_json(payload)
        sys.exit(1)

    since_ts: Optional[float] = None
    if args.since:
        try:
            since_ts = parse_iso(args.since)
        except ValueError as exc:
            payload = {
                "ok": False,
                "error": "invalid_since",
                "detail": str(exc),
                "since": args.since,
            }
            _safe_print_json(payload)
            sys.exit(1)

    channel_filter = str(args.channel or "").strip() or None
    max_links = int(args.max_links_per_message or 0)
    if max_links <= 0:
        payload = {
            "ok": False,
            "error": "invalid_max_links",
            "detail": "--max-links-per-message must be > 0.",
        }
        _safe_print_json(payload)
        sys.exit(1)

    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    repo_files_set, by_basename, by_stem_key = _build_repo_file_index(REPO_ROOT)
    if not repo_files_set:
        payload = {
            "ok": False,
            "error": "repo_index_failed",
            "detail": "Failed to index repo files via git ls-files (repo might not be a git checkout).",
            "repo_root": str(REPO_ROOT),
        }
        _safe_print_json(payload)
        sys.exit(1)

    considered = 0
    updated = 0
    skipped_with_script = 0
    changes: List[Dict[str, Any]] = []

    with lock:
        store = load_store(path)
        messages = store.get("messages", {})
        if not isinstance(messages, dict):
            payload = {
                "ok": False,
                "error": "invalid_store",
                "detail": "chat store 'messages' must be a dict.",
            }
            _safe_print_json(payload)
            sys.exit(1)

        for mid, msg in list(messages.items()):
            if not isinstance(msg, dict):
                continue

            if channel_filter and str(msg.get("channel") or "") != channel_filter:
                continue

            if since_ts is not None:
                try:
                    created_at = parse_iso(str(msg.get("created_at") or ""))
                except Exception:
                    created_at = None
                if created_at is None or created_at < since_ts:
                    continue

            considered += 1
            existing_links = [
                str(x).strip()
                for x in (msg.get("links") or [])
                if isinstance(x, str) and str(x).strip()
            ]
            mentions = _extract_repo_file_mentions(str(msg.get("text") or ""))
            resolved: List[str] = []
            for raw in mentions:
                rp = _resolve_repo_path(raw, repo_files_set=repo_files_set, by_basename=by_basename, by_stem_key=by_stem_key)
                if rp is None or not _is_reasonable_script_anchor_path(rp):
                    continue
                resolved.append(rp)

            tokens = [f"script:{p}" for p in sorted(set(resolved))]
            text_links = extract_link_tokens_from_text(str(msg.get("text") or ""))
            text_links = [x for x in text_links if LINK_TOKEN_RE.fullmatch(x)]
            tokens = _dedupe_keep_order(tokens + text_links)
            if not tokens:
                continue
            tokens = tokens[:max_links]

            if any(x.startswith("script:") for x in existing_links) and all(x in existing_links for x in tokens):
                skipped_with_script += 1
                continue

            if args.dry_run:
                changes.append({"message_id": mid, "added_links": tokens})
                updated += 1
                continue

            links_new = _dedupe_keep_order(existing_links + tokens)
            msg_mut = dict(msg)
            msg_mut["links"] = links_new
            meta = msg_mut.get("metadata")
            if not isinstance(meta, dict):
                meta = {}
            meta = dict(meta)
            meta["links_backfilled_at"] = now_iso()
            meta["links_backfilled_by"] = actor
            meta["links_backfilled_count"] = int(meta.get("links_backfilled_count") or 0) + 1
            msg_mut["metadata"] = meta
            messages[mid] = msg_mut
            changes.append({"message_id": mid, "added_links": tokens})
            updated += 1

        if not args.dry_run and updated:
            store["messages"] = messages
            save_store(path, store)

    _safe_print_json(
        {
            "ok": True,
            "action": "backfill-links",
            "file": str(path),
            "dry_run": bool(args.dry_run),
            "channel": channel_filter,
            "since": args.since,
            "considered": considered,
            "updated": updated,
            "skipped_with_script": skipped_with_script,
            "changes_sample": changes[: min(50, len(changes))],
        }
    )


def build_parser() -> argparse.ArgumentParser:
    """Build the top-level argument parser with rich help text."""
    description = (
        "Repository-local chat CLI for AI agents.\n\n"
        "Use this tool to exchange short, structured messages between agents\n"
        "inside this repository. It supports channels, simple threading, and\n"
        "filtering by author or topic.\n\n"
        "Common workflows:\n"
        "  - Initialize the chat store:\n"
        "      chat init\n"
        "  - Send a message in the 'general' channel:\n"
        "      chat send --channel general --author agent-planner \\\n"
        "          --text \"Starting work on worklock design.\"\n"
        "  - Reply to an existing message:\n"
        "      chat send --channel general --author agent-refactor \\\n"
        "          --text \"I'll own the refactor.\" --reply-to M00001\n"
        "  - List recent messages:\n"
        "      chat list --channel general --limit 20\n"
        "  - Inspect a thread:\n"
        "      chat thread --root-id M00001\n"
    )
    epilog = (
        "Exit codes:\n"
        "  0  Command succeeded.\n"
        "  1  Command failed (e.g. invalid arguments, not found).\n\n"
        "All commands print a single JSON object to stdout.\n"
        "Errors are also returned as JSON with at least: ok=false, error, detail.\n"
        "Verbose logs and heartbeats are written to stderr for observability.\n"
    )

    parser_kwargs: Dict[str, Any] = dict(
        prog="chat",
        description=description,
        epilog=epilog,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # Avoid passing unsupported kwargs on older Python versions.
    try:
        sig = inspect.signature(argparse.ArgumentParser.__init__)
        if "color" in sig.parameters:
            parser_kwargs["color"] = False
        if "suggest_on_error" in sig.parameters:
            parser_kwargs["suggest_on_error"] = False
    except Exception:
        pass

    parser = JsonArgumentParser(**parser_kwargs)
    parser.add_argument(
        "--file",
        default=CHAT_DEFAULT_FILENAME,
        help=(
            "Path to chat store JSON file "
            "(default: %(default)s; override with CHAT_FILE env var)."
        ),
    )

    subparsers = parser.add_subparsers(
        dest="command",
        required=True,
        parser_class=JsonArgumentParser,
    )

    p_init = subparsers.add_parser(
        "init",
        help="Initialize a chat store file.",
        description=(
            "Initialize a new chat store JSON file.\n\n"
            "If the file already exists, the command fails unless --force is\n"
            "provided. This command is optional; other commands auto-create an\n"
            "in-memory default when the file does not yet exist."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_init.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing chat store file if it exists.",
    )
    p_init.set_defaults(func=cmd_init)

    p_schema = subparsers.add_parser(
        "schema",
        help="Output JSON schema for the store.",
        description=(
            "Print the JSON schema describing the chat store, as well as the\n"
            "shape of individual message entries. Useful for agents that want\n"
            "to validate or introspect the data model."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_schema.set_defaults(func=cmd_schema)

    p_send = subparsers.add_parser(
        "send",
        help="Send a message to a channel.",
        description=(
            "Send a message to a channel. Messages can optionally reference a\n"
            "parent message via --reply-to to form threads. Additional context\n"
            "can be attached via tags and metadata."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_send.add_argument(
        "--channel",
        required=True,
        help="Channel name (e.g. 'general', 'ops', 'design').",
    )
    p_send.add_argument(
        "--author",
        help="Optional agent/human identifier sending the message.",
    )
    p_send.add_argument(
        "--role",
        help="Optional role (e.g. 'agent', 'human', 'system').",
    )
    p_send.add_argument(
        "--topic",
        help="Optional topic label (e.g. 'ops', 'tasks').",
    )
    p_send.add_argument(
        "--text",
        required=True,
        help="Message body text.",
    )
    p_send.add_argument(
        "--reply-to",
        help="Optional parent message id to reply to.",
    )
    p_send.add_argument(
        "--tag",
        dest="tags",
        action="append",
        help="Optional tag (can be specified multiple times).",
    )
    p_send.add_argument(
        "--link",
        "--links",
        dest="links",
        action="append",
        help="Optional cross-tool link token '<kind>:<id>' (repeatable). See architecture/LINKS_CONTRACT.md.",
    )
    p_send.add_argument(
        "--data",
        help="Optional JSON metadata object attached to the message.",
    )
    p_send.set_defaults(func=cmd_send)

    p_update = subparsers.add_parser(
        "update",
        help="Update a message (links only).",
        description=(
            "Update an existing message's links. This is primarily used by\n"
            "specialists that need to attach cross-tool link tokens (e.g.\n"
            "fixreport:BF..., task:T..., hypothesis:H...) after the fact.\n\n"
            "Only the message.links field is modified. The tool preserves link\n"
            "ordering and de-duplicates tokens deterministically."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_update.add_argument(
        "--id",
        required=True,
        help="Message id (e.g. 'M00001').",
    )
    p_update.add_argument(
        "--actor",
        required=True,
        help="Agent/human performing the update (required).",
    )
    p_update.add_argument(
        "--link-add",
        action="append",
        help="Link token '<kind>:<id>' to append (repeatable).",
    )
    p_update.add_argument(
        "--link-remove",
        action="append",
        help="Link token '<kind>:<id>' to remove (repeatable).",
    )
    p_update.set_defaults(func=cmd_update)

    p_list = subparsers.add_parser(
        "list",
        help="List messages, optionally filtered.",
        description=(
            "List messages, optionally filtered by channel, author, role, topic or\n"
            "minimum timestamp. Results are sorted by time, and an optional\n"
            "limit can be used to focus on the latest messages."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_list.add_argument(
        "--channel",
        help="Optional channel filter (e.g. 'general').",
    )
    p_list.add_argument(
        "--author",
        help="Optional author filter.",
    )
    p_list.add_argument(
        "--role",
        help="Optional role filter (e.g. 'human', 'agent', 'system').",
    )
    p_list.add_argument(
        "--topic",
        help="Optional topic filter.",
    )
    p_list.add_argument(
        "--since",
        help="Optional ISO8601 timestamp; only messages at or after this time.",
    )
    p_list.add_argument(
        "--limit",
        type=int,
        help="Optional limit for number of messages (latest N).",
    )
    p_list.set_defaults(func=cmd_list)

    p_get = subparsers.add_parser(
        "get",
        help="Get a single message by id.",
        description=(
            "Get a single message by its id (e.g. 'M00001'). Useful for\n"
            "drilling into a specific message returned from 'list'."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_get.add_argument(
        "--id",
        required=True,
        help="Message id (e.g. 'M00001').",
    )
    p_get.set_defaults(func=cmd_get)

    p_thread = subparsers.add_parser(
        "thread",
        help="List messages belonging to a thread.",
        description=(
            "List messages belonging to a thread identified by a root id or by\n"
            "an arbitrary message id. When --id is provided, the tool resolves\n"
            "the corresponding root_id and returns all messages in that thread."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_thread.add_argument(
        "--root-id",
        help="Root message id of the thread.",
    )
    p_thread.add_argument(
        "--id",
        help="Any message id within the thread.",
    )
    p_thread.set_defaults(func=cmd_thread)

    p_backfill = subparsers.add_parser(
        "backfill-links",
        help="Retroactively add script:<path> links to existing messages.",
        description=(
            "Scan existing chat messages and add explicit `script:<repo_relative_path>`\n"
            "tokens into message.links when the message text contains unambiguous repo\n"
            "file references. This improves Meta graph truth edges and reduces reliance\n"
            "on heuristic path matching.\n\n"
            "Only messages without existing script: links are modified.\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_backfill.add_argument(
        "--actor",
        required=True,
        help="Agent/human performing the backfill (required).",
    )
    p_backfill.add_argument(
        "--channel",
        help="Optional: only process messages in this channel.",
    )
    p_backfill.add_argument(
        "--since",
        help="Optional: only process messages created at/after this ISO timestamp (YYYY-MM-DDTHH:MM:SSZ).",
    )
    p_backfill.add_argument(
        "--max-links-per-message",
        type=int,
        default=5,
        help="Cap number of added script links per message (default: 5).",
    )
    p_backfill.add_argument(
        "--dry-run",
        action="store_true",
        help="Compute and report changes, but do not write the store.",
    )
    p_backfill.set_defaults(func=cmd_backfill_links)

    return parser


def main(argv: Optional[List[str]] = None) -> None:
    """Entry point for the CLI."""
    configure_logging()
    parser = build_parser()

    try:
        args = parser.parse_args(argv)
    except ArgumentParseError as exc:
        # Preserve argparse exit code semantics (2) while returning JSON on stdout.
        _safe_print_json(
            _error_payload(
                "invalid_arguments",
                exc.message,
                error_code="ARGPARSE_ERROR",
                retryable=False,
                usage=(exc.usage or "").strip(),
            )
        )
        raise SystemExit(2)

    try:
        handler = getattr(args, "func", None)
        handler_name = getattr(handler, "__name__", "")
        if handler_name in _MUTATING_CHAT_HANDLERS:
            _run_chat_mutation_with_retry(handler_name.replace("cmd_", ""), lambda: handler(args))
        else:
            handler(args)
    except FileLockTimeout as exc:
        payload = _error_payload(
            "lock_timeout",
            str(exc),
            error_code="LOCK_TIMEOUT",
            retryable=True,
            file=getattr(args, "file", CHAT_DEFAULT_FILENAME),
        )
        _safe_print_json(payload)
        sys.exit(1)
    except StoreLimitExceeded as exc:
        payload = _error_payload(
            "store_limit_exceeded",
            str(exc),
            error_code="STORE_LIMIT_EXCEEDED",
            retryable=False,
            file=getattr(args, "file", CHAT_DEFAULT_FILENAME),
        )
        _safe_print_json(payload)
        sys.exit(1)
    except Exception as exc:
        payload: Dict[str, Any] = _error_payload(
            "internal_error",
            str(exc),
            error_code=exc.__class__.__name__.upper(),
            retryable=False,
            type=exc.__class__.__name__,
        )
        if _env_bool("CHAT_DEBUG", False):
            payload["traceback"] = traceback.format_exc()
        _safe_print_json(payload)
        sys.exit(1)


if __name__ == "__main__":
    main()
