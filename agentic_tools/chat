def _env_bool(name: str, default: bool = False) -> bool:
    raw = os.environ.get(name)
    if raw is None:
        return default
    v = str(raw).strip().lower()
    if not v:
        return default
    return v in ("1", "true", "yes", "y", "on")


def _env_int(name: str, default: Optional[int] = None) -> Optional[int]:
    raw = os.environ.get(name)
    if raw is None:
        return default
    s = str(raw).strip()
    if not s:
        return default
    try:
        return int(s)
    except Exception:
        return default


def _env_float(name: str, default: float) -> float:
    raw = os.environ.get(name)
    if raw is None:
        return default
    s = str(raw).strip()
    if not s:
        return default
    try:
        return float(s)
    except Exception:
        return default


def _safe_print_json(payload: Dict[str, Any]) -> None:
    try:
        sys.stdout.write(json.dumps(payload, ensure_ascii=False) + "\n")
    except BrokenPipeError:
        # Respect typical CLI conventions when the consumer closes the pipe.
        try:
            sys.stdout.close()
        except Exception:
            pass


def _is_path_within_repo(path: Path) -> bool:
    try:
        resolved = path.resolve()
    except Exception:
        return False
    try:
        return resolved.is_relative_to(_REPO_ROOT_RESOLVED)  # py>=3.9
    except AttributeError:
        root = str(_REPO_ROOT_RESOLVED)
        rp = str(resolved)
        return rp == root or rp.startswith(root.rstrip(os.sep) + os.sep)


def now_iso() -> str:
    """Return current UTC timestamp in ISO8601 format with 'Z' suffix."""
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def parse_iso(ts: str) -> float:
    """Parse an ISO8601 timestamp produced by now_iso() into epoch seconds."""
    try:
        return calendar.timegm(time.strptime(ts, "%Y-%m-%dT%H:%M:%SZ"))
    except (ValueError, TypeError) as exc:
        raise ValueError(f"Invalid ISO8601 timestamp: {ts}") from exc


class FileLockTimeout(Exception):
    """Raised when the file-level lock cannot be acquired within the timeout."""


