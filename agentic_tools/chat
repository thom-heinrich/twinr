def _error_payload(
    error: str,
    detail: str,
    *,
    error_code: str,
    retryable: bool,
    **extra: Any,
) -> Dict[str, Any]:
    payload: Dict[str, Any] = {
        "ok": False,
        "error": str(error or "internal_error"),
        "error_code": str(error_code or "UNKNOWN_ERROR"),
        "detail": str(detail or ""),
        "retryable": bool(retryable),
    }
    payload.update(extra)
    return payload


