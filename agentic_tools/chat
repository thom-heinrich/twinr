def _max_message_chars() -> Optional[int]:
    v = _env_int("CHAT_MAX_MESSAGE_CHARS", None)
    return v if (v is not None and v > 0) else None


def cmd_send(args: argparse.Namespace) -> None:
    """Send a message to a channel."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    metadata = parse_json_arg(args.data, "--data")

    # Optional defensive cap (off by default) to prevent pathological store growth.
    max_chars = _max_message_chars()
    if max_chars is not None:
        txt = str(args.text or "")
        if len(txt) > max_chars:
            payload = {
                "ok": False,
                "error": "message_too_large",
                "detail": f"Message text length {len(txt)} exceeds limit {max_chars}.",
                "limit": max_chars,
                "length": len(txt),
            }
            _safe_print_json(payload)
            sys.exit(1)

    # Build repo index only if text contains repo file mentions (perf).
    auto_links: List[str] = []
    mentions = _extract_repo_file_mentions(str(args.text or ""))
    if mentions:
        repo_files_set, by_basename, by_stem_key = _build_repo_file_index(REPO_ROOT)
        resolved: List[str] = []
        for raw in mentions:
            rp = _resolve_repo_path(raw, repo_files_set=repo_files_set, by_basename=by_basename, by_stem_key=by_stem_key)
            if rp is None or not _is_reasonable_script_anchor_path(rp):
                continue
            resolved.append(rp)
        if resolved:
            # Stable ordering keeps diffs readable.
            resolved_unique = sorted(set(resolved))
            auto_links = [f"script:{p}" for p in resolved_unique]

    user_links = [str(x).strip() for x in (args.links or []) if str(x).strip()]
    bad_links = [x for x in user_links if not LINK_TOKEN_RE.fullmatch(x)]
    if bad_links:
        payload = {
            "ok": False,
            "error": "invalid_link",
            "detail": "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
            "bad": bad_links[:20],
        }
        _safe_print_json(payload)
        sys.exit(1)

    text_links = extract_link_tokens_from_text(str(args.text or ""))
    text_links = [x for x in text_links if LINK_TOKEN_RE.fullmatch(x)]
    links = _dedupe_keep_order(user_links + auto_links + text_links)
    links = append_codex_links(links)

    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    recent_for_channel: List[Dict[str, Any]] = []
    with lock:
        store = load_store(path)
        messages = store.get("messages", {})

        # Resolve parent/root if this is a reply.
        root_id: Optional[str]
        if args.reply_to:
            parent = messages.get(args.reply_to)
            if not parent:
                payload = {
                    "ok": False,
                    "error": "parent_not_found",
                    "detail": f"Parent message '{args.reply_to}' not found.",
                    "reply_to": args.reply_to,
                }
                _safe_print_json(payload)
                sys.exit(1)
            root_id = parent.get("root_id") or parent.get("id")
        else:
            root_id = None

        message_id = generate_message_id(store)
        if root_id is None:
            root_id = message_id

        now = now_iso()
        message = {
            "id": message_id,
            "channel": args.channel,
            "author": args.author,
            "role": args.role,
            "topic": args.topic,
            "text": args.text,
            "reply_to": args.reply_to,
            "root_id": root_id,
            "tags": args.tags or [],
            "links": links,
            "metadata": metadata,
            "created_at": now,
        }
        messages[message_id] = message
        store["messages"] = messages

        # Compute recent colleague messages in the same channel *after*
        # updating the store so that the view reflects the latest state.
        recent_for_channel = recent_colleague_messages(
            store=store,
            channel=args.channel,
            author=args.author,
            limit=20,
        )

        save_store(path, store)

    recent_out = [message_to_public(m) for m in recent_for_channel]

    out_doc: Dict[str, Any] = {
        "ok": True,
        "action": "send",
        "file": str(path),
        "message": message_to_public(message),
        "auto_links_added": auto_links,
        "text_links_added": [x for x in text_links if x not in user_links],
        "recent_colleague_messages": {
            "note": (
                "Please also keep in mind what your colleagues are "
                "doing or did in this channel."
            ),
            "channel": args.channel,
            "author": args.author,
            "limit": 20,
            "count": len(recent_out),
            "messages": recent_out,
        },
    }
    out_doc["next_steps"] = next_steps_for_chat_action(
        action="send",
        message_id=str(message_id),
        channel=str(args.channel or ""),
        links=links,
    )
    _safe_print_json(out_doc)


def cmd_list(args: argparse.Namespace) -> None:
    """List messages, optionally filtered by channel, author, role, topic, time."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    store = load_store(path)
    messages = list(store.get("messages", {}).values())

    if args.channel:
        messages = [m for m in messages if m.get("channel") == args.channel]
    if args.author:
        messages = [m for m in messages if m.get("author") == args.author]
    if getattr(args, "role", None):
        messages = [m for m in messages if m.get("role") == args.role]
    if args.topic:
        messages = [m for m in messages if m.get("topic") == args.topic]
    if args.since:
        try:
            since_ts = parse_iso(args.since)
        except ValueError as exc:
            payload = {
                "ok": False,
                "error": "invalid_since",
                "detail": str(exc),
                "since": args.since,
            }
            _safe_print_json(payload)
            sys.exit(1)

        filtered: List[Dict[str, Any]] = []
        for m in messages:
            if "created_at" not in m:
                continue
            try:
                created = parse_iso(str(m.get("created_at") or ""))
            except Exception:
                # Skip invalid timestamps instead of crashing the entire command.
                continue
            if created >= since_ts:
                filtered.append(m)
        messages = filtered

    # Sort by timestamp ascending, then id.
    messages.sort(key=lambda m: (m.get("created_at", ""), m.get("id", "")))

    # If a limit is set, keep the latest N messages.
    limit = args.limit
    if limit is not None and limit > 0 and len(messages) > limit:
        messages = messages[-limit:]

    out = [message_to_public(m) for m in messages]
    _safe_print_json(
        {
            "ok": True,
            "action": "list",
            "file": str(path),
            "channel_filter": args.channel,
            "author_filter": args.author,
            "role_filter": getattr(args, "role", None),
            "topic_filter": args.topic,
            "since_filter": args.since,
            "limit": limit,
            "messages": out,
            "count": len(out),
        }
    )


def cmd_update(args: argparse.Namespace) -> None:
    """Update an existing message (links only)."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)

    actor = str(args.actor or "").strip()
    if not actor:
        _safe_print_json(
            {
                "ok": False,
                "error": "invalid_actor",
                "detail": "--actor is required.",
            }
        )
        sys.exit(1)

    message_id = str(args.id or "").strip()
    if not message_id:
        _safe_print_json(
            {
                "ok": False,
                "error": "invalid_message_id",
                "detail": "--id is required.",
            }
        )
        sys.exit(1)

    link_add = [str(x).strip() for x in (args.link_add or []) if str(x).strip()]
    link_remove = [str(x).strip() for x in (args.link_remove or []) if str(x).strip()]
    if not link_add and not link_remove:
        _safe_print_json(
            {
                "ok": False,
                "error": "no_changes",
                "detail": "At least one of --link-add or --link-remove must be provided.",
            }
        )
        sys.exit(1)

    bad_links = [x for x in (link_add + link_remove) if not LINK_TOKEN_RE.fullmatch(x)]
    if bad_links:
        _safe_print_json(
            {
                "ok": False,
                "error": "invalid_link",
                "detail": "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
                "bad": bad_links[:20],
            }
        )
        sys.exit(1)

    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    with lock:
        store = load_store(path)
        messages = store.get("messages", {})
        msg = messages.get(message_id)
        if not isinstance(msg, dict):
            _safe_print_json(
                {
                    "ok": False,
                    "error": "message_not_found",
                    "detail": f"Message '{message_id}' not found.",
                    "id": message_id,
                }
            )
            sys.exit(1)

        raw_links = msg.get("links")
        if raw_links is None:
            raw_links = []
        if not isinstance(raw_links, list):
            _safe_print_json(
                {
                    "ok": False,
                    "error": "invalid_message_links",
                    "detail": "message.links must be a list.",
                    "id": message_id,
                }
            )
            sys.exit(1)

        existing_links = [
            str(x).strip()
            for x in raw_links
            if isinstance(x, str) and str(x).strip()
        ]

        to_remove = set(link_remove)
        links_after_remove = [x for x in existing_links if x not in to_remove]
        removed_links = [x for x in existing_links if x in to_remove]

        links_new = _dedupe_keep_order(links_after_remove + link_add)
        links_new = append_codex_links(links_new)
        added_links = [x for x in links_new if x not in links_after_remove]

        msg_mut = dict(msg)
        msg_mut["links"] = links_new

        meta = msg_mut.get("metadata")
        if not isinstance(meta, dict):
            meta = {}
        meta = dict(meta)
        meta["links_updated_at"] = now_iso()
        meta["links_updated_by"] = actor
        meta["links_updated_count"] = int(meta.get("links_updated_count") or 0) + 1
        msg_mut["metadata"] = meta

        messages[message_id] = msg_mut
        store["messages"] = messages
        save_store(path, store)

    _safe_print_json(
        {
            "ok": True,
            "action": "update",
            "file": str(path),
            "id": message_id,
            "actor": actor,
            "added_links": added_links,
            "removed_links": removed_links,
        }
    )


