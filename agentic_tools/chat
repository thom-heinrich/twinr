def _find_repo_root() -> Path:
    """
    Discover repo root robustly.

    The agentic tools are typically symlinked into /usr/local/bin. In some recovery
    situations the symlink can be replaced by a plain copy; in that case __file__
    no longer lives under the repo and we must fall back to cwd/env discovery.
    """
    env = (os.getenv("TESSAIRACT_REPO_ROOT") or os.getenv("CAIA_REPO_ROOT") or "").strip()
    candidates: List[Path] = []
    if env:
        candidates.append(Path(env).expanduser())

    cwd = Path.cwd()
    candidates.append(cwd)
    candidates.extend(cwd.parents)

    here = Path(__file__).resolve()
    candidates.append(here)
    candidates.extend(here.parents)

    for cand in candidates:
        try:
            c = cand.resolve()
        except Exception:
            continue
        if (c / "agentic_tools").is_dir() and (c / "common" / "__init__.py").is_file():
            return c

    # Fall back to historical behavior (works when executed from within the repo).
    return Path(__file__).resolve().parent.parent


