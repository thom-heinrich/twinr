def default_store() -> Dict[str, Any]:
    """Return a fresh, empty chat store structure."""
    now = now_iso()
    return {
        "version": 1,
        "created_at": now,
        "updated_at": now,
        "revision": 0,
        "next_message_id": 1,
        "messages": {},  # id -> message
    }


def ensure_store_shape(store: Dict[str, Any]) -> Dict[str, Any]:
    """Ensure mandatory top-level keys exist on the store (and validate critical types)."""
    if not isinstance(store, dict):
        raise StoreValidationError("chat store root must be a JSON object.")

    if "version" not in store:
        store["version"] = 1
    else:
        try:
            store["version"] = int(store["version"])
        except Exception as exc:
            raise StoreValidationError("chat store 'version' must be an int.") from exc

    if "created_at" not in store:
        store["created_at"] = now_iso()
    elif not isinstance(store["created_at"], str):
        raise StoreValidationError("chat store 'created_at' must be a string.")

    if "updated_at" not in store:
        store["updated_at"] = now_iso()
    elif not isinstance(store["updated_at"], str):
        raise StoreValidationError("chat store 'updated_at' must be a string.")

    if "revision" not in store:
        store["revision"] = 0
    else:
        try:
            store["revision"] = int(store["revision"])
        except Exception as exc:
            raise StoreValidationError("chat store 'revision' must be an int.") from exc

    if "next_message_id" not in store:
        store["next_message_id"] = 1
    else:
        try:
            store["next_message_id"] = int(store["next_message_id"])
        except Exception as exc:
            raise StoreValidationError("chat store 'next_message_id' must be an int.") from exc

    if "messages" not in store:
        store["messages"] = {}
    else:
        if not isinstance(store["messages"], dict):
            raise StoreValidationError("chat store 'messages' must be a dict.")

    return store


def load_store(path: Path) -> Dict[str, Any]:
    """Load the chat store from disk, or create a new one."""
    if not path.exists():
        logging.info(
            "Chat store %s does not exist, using in-memory default until first write.",
            path,
        )
        return default_store()
    try:
        with path.open("r", encoding="utf-8") as handle:
            store = json.load(handle)
    except json.JSONDecodeError as exc:
        payload = {
            "ok": False,
            "error": "invalid_json",
            "detail": f"Failed to parse chat store JSON: {exc}",
            "file": str(path),
        }
        _safe_print_json(payload)
        sys.exit(1)

    try:
        return ensure_store_shape(store)
    except StoreValidationError as exc:
        payload = {
            "ok": False,
            "error": "invalid_store_shape",
            "detail": str(exc),
            "file": str(path),
        }
        _safe_print_json(payload)
        sys.exit(1)


def _json_indent() -> Optional[int]:
    raw = os.environ.get("CHAT_JSON_INDENT")
    if raw is None:
        return 2  # preserve existing behavior
    s = str(raw).strip().lower()
    if s in ("", "none", "null", "compact", "min", "0"):
        return None
    try:
        v = int(str(raw).strip())
        return v if v >= 0 else 2
    except Exception:
        return 2


def _durable_writes_enabled() -> bool:
    return _env_bool("CHAT_DURABLE", False)


def _fsync_dir_best_effort(dir_path: Path) -> None:
    try:
        fd = os.open(str(dir_path), os.O_RDONLY)
    except Exception:
        return
    try:
        os.fsync(fd)
    except Exception:
        pass
    finally:
        try:
            os.close(fd)
        except Exception:
            pass


def _max_store_bytes() -> Optional[int]:
    v = _env_int("CHAT_MAX_STORE_BYTES", None)
    return v if (v is not None and v > 0) else None


def save_store(path: Path, store: Dict[str, Any]) -> None:
    """Persist the chat store atomically to disk."""
    store["updated_at"] = now_iso()
    store["revision"] = int(store.get("revision", 0)) + 1

    tmp_path = path.with_suffix(path.suffix + ".tmp")
    indent = _json_indent()

    with tmp_path.open("w", encoding="utf-8") as handle:
        json.dump(store, handle, ensure_ascii=False, indent=indent, sort_keys=True)
        handle.write("\n")
        if _durable_writes_enabled():
            try:
                handle.flush()
                os.fsync(handle.fileno())
            except Exception:
                pass

    limit = _max_store_bytes()
    if limit is not None:
        try:
            size = tmp_path.stat().st_size
        except Exception:
            size = None
        if size is not None and size > limit:
            try:
                tmp_path.unlink()
            except Exception:
                pass
            raise StoreLimitExceeded(f"Store size {size} exceeds configured limit {limit} bytes.")

    tmp_path.replace(path)
    if _durable_writes_enabled():
        _fsync_dir_best_effort(path.parent)

    logging.info("Persisted chat store to %s (revision=%s).", path, store["revision"])


def _git_ls_files(repo_root: Path) -> List[str]:
    try:
        out = subprocess.check_output(
            ["git", "-C", str(repo_root), "ls-files"],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return []
    return [line.strip() for line in out.splitlines() if line.strip()]


_VERSION_SUFFIX_RE = re.compile(r"(?:_v[0-9]+(?:_[0-9]+)*)$")
_VERSION_EXTRACT_RE = re.compile(r"_v(?P<ver>[0-9]+(?:_[0-9]+)*)$")


def _strip_version_suffix(stem: str) -> str:
    s = str(stem or "").strip()
    if not s:
        return ""
    return _VERSION_SUFFIX_RE.sub("", s)


def _parse_version_suffix(stem: str) -> Optional[tuple[int, ...]]:
    s = str(stem or "").strip()
    if not s:
        return None
    m = _VERSION_EXTRACT_RE.search(s)
    if not m:
        return None
    raw = str(m.group("ver") or "").strip()
    if not raw:
        return None
    parts: List[int] = []
    for p in raw.split("_"):
        try:
            parts.append(int(p))
        except Exception:
            return None
    return tuple(parts) if parts else None


def _build_repo_file_index(repo_root: Path) -> tuple[set[str], Dict[str, List[str]], Dict[tuple[str, str], List[str]]]:
    repo_files = _git_ls_files(repo_root)
    repo_files_set = set(repo_files)
    by_basename: Dict[str, List[str]] = {}
    by_stem_key: Dict[tuple[str, str], List[str]] = {}
    for p in repo_files:
        pp = Path(p)
        by_basename.setdefault(pp.name, []).append(p)
        ext = pp.suffix.lower()
        stem_key = _strip_version_suffix(pp.stem)
        if stem_key and ext:
            by_stem_key.setdefault((stem_key, ext), []).append(p)
    return repo_files_set, by_basename, by_stem_key


def _extract_repo_file_mentions(text: str) -> List[str]:
    if not text:
        return []
    out: List[str] = []
    for m in REPO_FILE_MENTION_RE.finditer(text):
        p = (m.group("path") or "").strip().strip("`\"'()[]{}.,;:")
        if p and p not in out:
            out.append(p)
    return out


def _normalize_repo_path(raw: str) -> str:
    s = str(raw or "").strip()
    if not s:
        return ""
    if s.startswith("./"):
        s = s[2:]
    rp = str(REPO_ROOT) + "/"
    if s.startswith(rp):
        s = s[len(rp) :]
    rp_noslash = str(REPO_ROOT).lstrip("/") + "/"
    if s.startswith(rp_noslash):
        s = s[len(rp_noslash) :]
    if s.startswith("/etc/systemd/system/"):
        unit = s.split("/etc/systemd/system/", 1)[1]
        s = f"systemd/units/{unit}"
    return s


def _safe_repo_relpath(rel: str) -> Optional[str]:
    """Return rel if it resolves within repo root; otherwise None."""
    s = str(rel or "").strip()
    if not s:
        return None
    p = REPO_ROOT / s
    try:
        if not p.is_file():
            return None
    except Exception:
        return None

    allow_out_of_repo = _env_bool("CHAT_ALLOW_OUT_OF_REPO_PATHS", False)
    if allow_out_of_repo:
        return s

    if _is_path_within_repo(p):
        return s
    return None


def _resolve_repo_path(
    raw: str,
    *,
    repo_files_set: set[str],
    by_basename: Dict[str, List[str]],
    by_stem_key: Dict[tuple[str, str], List[str]],
) -> Optional[str]:
    s = _normalize_repo_path(raw)
    if not s:
        return None

    if any(part == ".." for part in Path(s).parts):
        return None

    if s.startswith("/"):
        # Absolute non-repo paths: allow mapping by basename if unique.
        base = Path(s).name
        candidates = sorted(set(by_basename.get(base, [])))
        if len(candidates) == 1:
            return _safe_repo_relpath(candidates[0])
        return None

    if repo_files_set:
        if s in repo_files_set:
            return _safe_repo_relpath(s)

    # Allow anchoring to repo-local but untracked files (e.g. operational scripts).
    # Still guarded by _safe_repo_relpath() to avoid out-of-repo symlink resolution.
    anchored = _safe_repo_relpath(s)
    if anchored is not None:
        return anchored

    # If a message mentions a moved path, try unique basename mapping (even when a/dir/b.py was given).
    base = Path(s).name
    candidates = sorted(set(by_basename.get(base, [])))
    if len(candidates) == 1:
        return _safe_repo_relpath(candidates[0])

    # Heuristic: map legacy non-versioned file mentions to a single versioned file in the repo.
    # Example: services/analytics/analytics_l2_footprint.py -> services/analytics/analytics_l2_footprint_v3.py
    # We only accept a unique candidate to keep this safe.
    sp = Path(s)
    ext = sp.suffix.lower()
    stem_key = _strip_version_suffix(sp.stem)
    if ext and stem_key:
        stem_candidates = sorted(set(by_stem_key.get((stem_key, ext), [])))
        if len(stem_candidates) == 1:
            return _safe_repo_relpath(stem_candidates[0])
        # If multiple candidates exist, try narrowing by a 2-segment prefix (e.g. services/analytics).
        parts = [p for p in sp.parts if p]
        if len(stem_candidates) > 1 and len(parts) >= 2:
            prefix2 = "/".join(parts[:2]) + "/"
            narrowed = [c for c in stem_candidates if c.startswith(prefix2)]
            narrowed = sorted(set(narrowed))
            if len(narrowed) == 1:
                return _safe_repo_relpath(narrowed[0])
            stem_candidates = narrowed or stem_candidates

        # If still ambiguous, prefer the highest version suffix when all candidates
        # are versioned variants of the same stem key (common legacy rename pattern).
        filtered = [c for c in stem_candidates if "/__ignore__/" not in c]
        stem_candidates2 = filtered or stem_candidates
        vers: List[tuple[tuple[int, ...], str]] = []
        for c in stem_candidates2:
            v = _parse_version_suffix(Path(c).stem)
            if v is None:
                vers = []
                break
            vers.append((v, c))
        if vers:
            vers.sort(key=lambda x: x[0])
            return _safe_repo_relpath(vers[-1][1])
    return None


def _is_reasonable_script_anchor_path(path: str) -> bool:
    p = str(path or "").strip()
    if not p:
        return False
    if p.startswith(("reports/", "artifacts/reports/", "artifacts/stores/", "state/", "logs/", "exports/")):
        return False
    if "/__pycache__/" in p:
        return False
    return True


def _dedupe_keep_order(items: List[str]) -> List[str]:
    seen: set[str] = set()
    out: List[str] = []
    for x in items:
        x = str(x).strip()
        if not x or x in seen:
            continue
        seen.add(x)
        out.append(x)
    return out


def parse_json_arg(raw: Optional[str], arg_name: str) -> Dict[str, Any]:
    """Parse a JSON argument that must be an object, or return {} if None."""
    if raw is None:
        return {}
    try:
        value = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise SystemExit(
            json.dumps(
                {
                    "ok": False,
                    "error": "invalid_json_arg",
                    "detail": f"Failed to parse JSON for {arg_name}: {exc}",
                }
            )
        )
    if not isinstance(value, dict):
        raise SystemExit(
            json.dumps(
                {
                    "ok": False,
                    "error": "invalid_json_arg",
                    "detail": f"Expected JSON object for {arg_name}.",
                }
            )
        )
    return value


def generate_message_id(store: Dict[str, Any]) -> str:
    """Generate a new human-friendly message ID of the form 'M00001'."""
    next_id = int(store.get("next_message_id", 1))
    messages = store.get("messages", {})
    while True:
        candidate = f"M{next_id:05d}"
        if candidate not in messages:
            store["next_message_id"] = next_id + 1
            return candidate
        next_id += 1


def message_to_public(message: Dict[str, Any]) -> Dict[str, Any]:
    """Return a stable public representation of a message."""
    return dict(message)


def recent_colleague_messages(
    store: Dict[str, Any],
    channel: str,
    author: Optional[str],
    limit: int = 20,
) -> List[Dict[str, Any]]:
    """Return the latest colleague messages in the same channel.

    A "colleague" message is defined as:
    - Same channel as the current message, and
    - Authored by a *different* author. If the current author is None,
      only messages with a non-None author are considered colleagues.
    """
    all_messages = store.get("messages", {})
    if not isinstance(all_messages, dict):
        logging.warning(
            "Store 'messages' has unexpected type %s; treating as empty.",
            type(all_messages),
        )
        return []

    if author is None:
        filtered = [
            m
            for m in all_messages.values()
            if m.get("channel") == channel and m.get("author") is not None
        ]
    else:
        filtered = [
            m
            for m in all_messages.values()
            if m.get("channel") == channel and m.get("author") != author
        ]

    # Sort chronologically (oldest first), then by id for stability.
    filtered.sort(key=lambda m: (m.get("created_at", ""), m.get("id", "")))

    if limit is not None and limit > 0 and len(filtered) > limit:
        filtered = filtered[-limit:]

    logging.info(
        "Computed %d colleague messages for channel=%s author=%s (limit=%s).",
        len(filtered),
        channel,
        author,
        limit,
    )
    return filtered


def cmd_init(args: argparse.Namespace) -> None:
    """Initialize a new chat store file."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    if path.exists() and not args.force:
        payload = {
            "ok": False,
            "error": "exists",
            "detail": f"Chat store already exists: {path}",
            "file": str(path),
        }
        _safe_print_json(payload)
        sys.exit(1)

    store = default_store()
    path.write_text(
        json.dumps(store, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    logging.info("Initialized new chat store at %s.", path)
    _safe_print_json(
        {
            "ok": True,
            "action": "init",
            "file": str(path),
            "version": store["version"],
        }
    )


