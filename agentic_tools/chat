def _pid_is_running(pid: int) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except OSError as exc:
        if getattr(exc, "errno", None) == errno.ESRCH:
            return False
        # EPERM or other errors -> treat as running to avoid unsafe stale-breaking.
        return True
    except Exception:
        return True


def _read_lock_payload(path: Path) -> Optional[Dict[str, Any]]:
    try:
        # Lockfile is expected to be tiny; cap reads defensively.
        data = path.read_text(encoding="utf-8", errors="replace")
        if len(data) > 8192:
            data = data[:8192]
        obj = json.loads(data) if data.strip() else None
        return obj if isinstance(obj, dict) else None
    except Exception:
        return None


def _lock_age_seconds(path: Path, payload: Optional[Dict[str, Any]]) -> Optional[float]:
    now = time.time()
    if payload:
        created_at = payload.get("created_at")
        if isinstance(created_at, str) and created_at.strip():
            try:
                return max(0.0, now - parse_iso(created_at.strip()))
            except Exception:
                pass
    try:
        st = path.stat()
        return max(0.0, now - float(st.st_mtime))
    except Exception:
        return None


def _try_advisory_lock(fd: int) -> bool:
    """Best-effort additional lock to reduce risk on filesystems with weak O_EXCL semantics."""
    # POSIX: fcntl.flock
    try:
        import fcntl  # type: ignore
    except Exception:
        fcntl = None  # type: ignore

    if fcntl is not None:
        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return True
        except OSError as exc:
            # If not supported, treat as "no advisory lock available" and proceed.
            if getattr(exc, "errno", None) in (errno.ENOTSUP, errno.EINVAL, errno.ENOSYS):
                return True
            return False
        except Exception:
            return False

    # Windows: msvcrt.locking (best-effort)
    try:
        import msvcrt  # type: ignore
    except Exception:
        return True  # no advisory lock available; proceed with file-existence locking.

    try:
        # Lock 1 byte from current position. Ensure we're at offset 0.
        os.lseek(fd, 0, os.SEEK_SET)
        msvcrt.locking(fd, msvcrt.LK_NBLCK, 1)
        return True
    except OSError:
        return False
    except Exception:
        return False


def _unlock_advisory_lock(fd: int) -> None:
    try:
        import fcntl  # type: ignore

        try:
            fcntl.flock(fd, fcntl.LOCK_UN)
            return
        except Exception:
            pass
    except Exception:
        pass

    try:
        import msvcrt  # type: ignore

        try:
            os.lseek(fd, 0, os.SEEK_SET)
            msvcrt.locking(fd, msvcrt.LK_UNLCK, 1)
        except Exception:
            pass
    except Exception:
        pass


@dataclass
class FileLock:
    """Simple cross-process file lock using atomic create/unlink of a lock file."""

    path: Path
    timeout: float = 10.0
    poll_interval: float = 0.05
    stale_timeout: Optional[float] = None

    _fd: Optional[int] = None

    def _effective_timeout(self) -> float:
        return _env_float("CHAT_LOCK_TIMEOUT", self.timeout)

    def _effective_poll_interval(self) -> float:
        return _env_float("CHAT_LOCK_POLL_INTERVAL", self.poll_interval)

    def _effective_stale_timeout(self) -> float:
        if self.stale_timeout is not None and self.stale_timeout > 0:
            base = float(self.stale_timeout)
        else:
            # Conservative default: avoid breaking long operations; used only for clearly stale locks.
            base = max(600.0, self._effective_timeout() * 60.0)
        env_override = os.environ.get("CHAT_LOCK_STALE_SECONDS")
        if env_override is not None:
            try:
                v = float(str(env_override).strip())
                if v > 0:
                    return v
            except Exception:
                return base
        return base

    def _sleep_with_jitter(self) -> None:
        pi = self._effective_poll_interval()
        jitter = random.random() * pi
        time.sleep(pi + jitter)

    def _maybe_break_stale(self) -> bool:
        """Return True if a stale lock was detected and removed."""
        p = self.path
        payload = _read_lock_payload(p)
        age = _lock_age_seconds(p, payload)
        stale_timeout = self._effective_stale_timeout()
        force_break_old = _env_bool("CHAT_LOCK_FORCE_BREAK_OLD", False)

        pid: Optional[int] = None
        if payload and "pid" in payload:
            try:
                pid = int(payload.get("pid"))
            except Exception:
                pid = None

        # Safe stale-breaking policy:
        # - If PID is known and NOT running -> break immediately.
        # - If PID is unknown -> break only if age > stale_timeout.
        # - If PID is running -> break only if explicitly forced AND age > stale_timeout.
        is_stale = False
        if pid is not None:
            if not _pid_is_running(pid):
                is_stale = True
            elif force_break_old and age is not None and age > stale_timeout:
                is_stale = True
        else:
            if age is not None and age > stale_timeout:
                is_stale = True

        if not is_stale:
            return False

        try:
            p.unlink()
            logging.warning("Removed stale lock file %s (age=%s pid=%s).", p, age, pid)
            return True
        except FileNotFoundError:
            return True
        except Exception:
            # If we can't remove it, just treat as not removable.
            return False

    def acquire(self) -> None:
        """Acquire the lock by atomically creating a lock file."""
        # Ensure parent directory exists (best-effort).
        try:
            self.path.parent.mkdir(parents=True, exist_ok=True)
        except Exception:
            pass

        deadline = time.time() + self._effective_timeout()
        while True:
            try:
                fd = os.open(self.path, os.O_CREAT | os.O_EXCL | os.O_RDWR)
            except FileExistsError:
                # Attempt to break stale locks, then retry.
                if self._maybe_break_stale():
                    continue
                if time.time() > deadline:
                    raise FileLockTimeout(f"Timed out acquiring lock {self.path}")
                self._sleep_with_jitter()
                continue
            except IsADirectoryError:
                # Treat as locked/occupied; do not attempt deletion.
                if time.time() > deadline:
                    raise FileLockTimeout(f"Timed out acquiring lock {self.path} (path is a directory)")
                self._sleep_with_jitter()
                continue

            # We created the lock file; write metadata.
            self._fd = fd
            try:
                payload = {
                    "created_at": now_iso(),
                    "pid": os.getpid(),
                    "rand": random.random(),
                }
                os.write(fd, json.dumps(payload).encode("utf-8"))
                os.fsync(fd)
            except Exception:
                # Metadata is best-effort; the lockfile existence remains the primary lock.
                pass

            # Optional advisory lock to reduce risk on weak filesystems (e.g., some NFS setups).
            if _try_advisory_lock(fd):
                return

            # Another process may have concurrently created/claimed via advisory locking.
            # Do NOT unlink here; wait for the winning process to release (unlink) the lockfile.
            try:
                os.close(fd)
            except Exception:
                pass
            self._fd = None

            if time.time() > deadline:
                raise FileLockTimeout(f"Timed out acquiring lock {self.path}")
            self._sleep_with_jitter()

    def release(self) -> None:
        """Release the lock by removing the lock file."""
        fd = self._fd
        self._fd = None
        if fd is not None:
            try:
                _unlock_advisory_lock(fd)
            except Exception:
                pass
            try:
                os.close(fd)
            except Exception:
                pass
        try:
            self.path.unlink()
        except FileNotFoundError:
            return
        except Exception:
            return

    def __enter__(self) -> "FileLock":
        self.acquire()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb) -> None:
        self.release()


class JsonArgumentParser(argparse.ArgumentParser):
