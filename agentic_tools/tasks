    p_init.set_defaults(func=cmd_init)

    p_schema = subparsers.add_parser("schema", help="Output JSON schema for board/tasks.")
    p_schema.set_defaults(func=cmd_schema)

    p_read = subparsers.add_parser("read", help="Read tasks or whole board.")
