def cmd_update(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    repo_files_set, by_basename = _build_repo_file_index(REPO_ROOT)
    in_progress: List[Dict[str, Any]] = []
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        task = board["tasks"].get(args.id)
        if not task:
            _emit_json(
                {
                    "ok": False,
                    "error": "not_found",
                    "detail": f"Task '{args.id}' not found.",
                }
            )
            sys.exit(1)

        raw_set = getattr(args, "set", None)
        patch = parse_json_arg(raw_set, "--set") if raw_set is not None else {}
        if "column" in patch:
            ensure_column(board, patch["column"])

        # Link mutations (do not force callers to hand-write JSON patches).
        links_add = getattr(args, "links_add", None) or []
        links_remove = getattr(args, "links_remove", None) or []
        scripts_add = getattr(args, "scripts_add", None) or []
        scripts_remove = getattr(args, "scripts_remove", None) or []
        if links_add or links_remove:
            cur = task.get("links")
            cur_list: List[str] = list(cur) if isinstance(cur, list) else []
            if links_add:
                cur_list.extend([str(x) for x in links_add if x])
            if links_remove:
                rm = {str(x) for x in links_remove if x}
                cur_list = [x for x in cur_list if str(x) not in rm]
            patch["links"] = cur_list

        if scripts_add or scripts_remove:
            cur = patch.get("links", task.get("links"))
            cur_list = list(cur) if isinstance(cur, list) else []
            if scripts_add:
                cur_list.extend([f"script:{str(x).strip()}" for x in scripts_add if str(x).strip()])
            if scripts_remove:
                rm = {f"script:{str(x).strip()}" for x in scripts_remove if str(x).strip()}
                cur_list = [x for x in cur_list if str(x).strip() not in rm]
            patch["links"] = cur_list

        if "links" in patch:
            require_script_anchor = not bool(getattr(args, "allow_no_script_anchor", False))
            patch["links"] = append_codex_links(list(patch.get("links") or []))
            patch["links"] = _normalize_and_validate_links(
                list(patch.get("links") or []),
                repo_files_set=repo_files_set,
                by_basename=by_basename,
                require_script_anchor=require_script_anchor,
            )
        else:
            title = patch.get("title", task.get("title", ""))
            desc = patch.get("description", task.get("description", ""))
            text_links = extract_link_tokens_from_texts([str(title or ""), str(desc or "")])
            if text_links:
                cur_links = task.get("links")
                cur_list: List[str] = list(cur_links) if isinstance(cur_links, list) else []
                merged = cur_list + list(text_links)
                require_script_anchor = not bool(getattr(args, "allow_no_script_anchor", False))
                merged = append_codex_links(list(merged))
                patch["links"] = _normalize_and_validate_links(
                    list(merged),
                    repo_files_set=repo_files_set,
                    by_basename=by_basename,
                    require_script_anchor=require_script_anchor,
                )

        if not patch:
            _emit_json(
                {
                    "ok": False,
                    "error": "no_changes",
                    "detail": "No changes specified (provide --set and/or --link-add/--link-remove).",
                }
            )
            sys.exit(1)

        for k, v in patch.items():
            if v is None and k in task:
                del task[k]
            else:
                task[k] = v

        if "column" in patch and "status" not in patch:
            task["status"] = column_to_status(task.get("column"))
        if "status" in patch and "column" not in patch and not task.get("column"):
            if task["status"] == "in_progress":
                task["column"] = "doing"
            elif task["status"] == "ready":
                task["column"] = "todo"

        # Backward-compatible: never force link re-validation when the caller did not touch links.
        # We only append Codex context tokens at the end (if missing) to enable high-precision joins.
        cur_links = task.get("links")
        cur_links_list: List[str] = list(cur_links) if isinstance(cur_links, list) else []
        links_with_codex = append_codex_links(cur_links_list)
        if links_with_codex != cur_links_list:
            task["links"] = links_with_codex

        task["updated_at"] = now_iso()
        board["tasks"][args.id] = task
        append_event(
            board,
            make_event(
                "task_updated",
                getattr(args, "agent", None),
                args.id,
                {"set": patch, "changed_fields": sorted(patch.keys())},
            ),
        )
        in_progress = current_in_progress_tasks(board, limit=20)
        collab_context = build_collab_context(
            board,
            agent_id=getattr(args, "agent", None),
        )
        save_board(path, board)

    public_task = task_to_public(task)
    next_steps = next_steps_for_task_action(
        action="update",
        task_id=str(public_task.get("id") or ""),
        title=str(public_task.get("title") or ""),
        column=str(public_task.get("column") or ""),
        status=str(public_task.get("status") or ""),
        links=list(public_task.get("links") or []),
        agent=str(getattr(args, "agent", "") or ""),
    )
    _emit_json(
        {
            "ok": True,
            "task": public_task,
            "next_steps": next_steps,
            "current_in_progress_tasks": {
                "note": (
                    "Keep in mind what other agents are currently working on "
                    "(tasks in 'doing' or leased)."
                ),
                "limit": 20,
                "count": len(in_progress),
                "tasks": in_progress,
            },
            "collab_context": collab_context,
        }
    )


