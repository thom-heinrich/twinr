def _task_relation_conflicts(
    task: Dict[str, Any], tasks_by_id: Dict[str, Dict[str, Any]]
) -> List[str]:
    out: List[str] = []
    relations = task.get("relations")
    if not isinstance(relations, list):
        return out

    for rel in relations:
        if not isinstance(rel, dict):
            continue
        rel_type = str(rel.get("type") or "").strip()
        other_id = str(rel.get("task_id") or "").strip()
        if not rel_type or not other_id:
            continue
        other = tasks_by_id.get(other_id)
        if rel_type not in {"blocked_by", "depends_on"}:
            continue
        if not other:
            out.append(f"{rel_type}:{other_id} (missing dependency task)")
            continue
        other_status = str(other.get("status") or column_to_status(other.get("column"))).lower()
        if other_status not in DONE_STATUSES:
            other_title = str(other.get("title") or other_id).strip() or other_id
            out.append(f"{rel_type}:{other_id} ({other_title}, status={other_status})")
    return _dedupe_keep_order(out)


def _normalize_task_explain(
    task: Dict[str, Any], tasks_by_id: Dict[str, Dict[str, Any]]
) -> Dict[str, Any]:
    metadata = task.get("metadata")
    if not isinstance(metadata, dict):
        metadata = {}

    links = _dedupe_keep_order([str(x).strip() for x in (task.get("links") or []) if str(x).strip()])
    title = str(task.get("title") or "").strip()
    description = str(task.get("description") or "").strip()
    status = str(task.get("status") or column_to_status(task.get("column"))).strip().lower()
    conflicts = _task_relation_conflicts(task, tasks_by_id)

    how_values: List[str] = []
    how_values.extend(_as_string_list(metadata.get("how")))
    how_values.extend(_as_string_list(metadata.get("steps")))
    how_values.extend(_as_string_list(metadata.get("acceptance_criteria")))
    if not how_values and description:
        how_values.append(description)
    if conflicts:
        for item in conflicts:
            how_values.append(f"Resolve dependency before execution: {item}")
    if not how_values:
        how_values.append("Advance this task through workflow columns with verifiable outputs.")

    guardrails: List[str] = []
    guardrails.extend(_as_string_list(metadata.get("guardrails")))
    guardrails.extend(_as_string_list(metadata.get("tests_or_guardrails")))
    guardrails.append("Maintain at least one `script:<repo_relative_path>` anchor in task.links.")
    if str(task.get("lease_owner") or "").strip():
        lease_owner = str(task.get("lease_owner") or "").strip()
        lease_expires_at = str(task.get("lease_expires_at") or "").strip()
        if lease_expires_at:
            guardrails.append(f"Respect active lease by {lease_owner} until {lease_expires_at}.")
        else:
            guardrails.append(f"Respect active lease by {lease_owner}.")

    evidence: List[str] = []
    evidence.extend(_as_string_list(metadata.get("evidence")))
    evidence.extend(
        [x for x in links if any(x.startswith(prefix) for prefix in ("finding:", "fixreport:", "hypothesis:", "task:", "audit_id:", "audit_file:"))]
    )

    why = _pick_first_nonempty(
        metadata.get("rationale"),
        metadata.get("why"),
        description,
        "Task tracked for execution and coordination.",
    )

    return {
        "what": _pick_first_nonempty(title, task.get("id"), "Task"),
        "why": why,
        "how": _dedupe_keep_order(how_values),
        "guardrails": _dedupe_keep_order(guardrails),
        "evidence": _dedupe_keep_order(evidence),
        "conflicts": conflicts,
        "links": links,
        "status": status,
    }


def cmd_overview(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    board = load_board(path)
    tasks_by_id = build_task_index(board)
    tasks = list(tasks_by_id.values())

    by_column: Dict[str, int] = {}
    by_status: Dict[str, int] = {}
    by_priority: Dict[str, int] = {}
    blocked = 0
    for task in tasks:
        column = str(task.get("column") or "unknown")
        status = str(task.get("status") or column_to_status(column)).lower()
        priority = str(task.get("priority") or "normal").lower()
        by_column[column] = int(by_column.get(column, 0)) + 1
        by_status[status] = int(by_status.get(status, 0)) + 1
        by_priority[priority] = int(by_priority.get(priority, 0)) + 1
        if task_is_blocked(task, tasks_by_id):
            blocked += 1

    sample_limit = max(1, min(int(getattr(args, "sample_limit", 8) or 8), 50))

    def _task_preview(task: Dict[str, Any]) -> Dict[str, Any]:
        public = task_to_public(task)
        description = str(public.get("description") or "").strip()
        if len(description) > 180:
            description = description[:177] + "..."
        links = public.get("links") or []
        return {
            "id": str(public.get("id") or ""),
            "title": str(public.get("title") or ""),
            "column": str(public.get("column") or ""),
            "status": str(public.get("status") or column_to_status(public.get("column"))).lower(),
            "priority": str(public.get("priority") or ""),
            "created_at": str(public.get("created_at") or ""),
            "updated_at": str(public.get("updated_at") or ""),
            "description_preview": description,
            "links_count": len(links) if isinstance(links, list) else 0,
        }

    def _sample(selector: Any) -> List[Dict[str, Any]]:
        selected: List[Dict[str, Any]] = []
        for task in tasks:
            if selector(task):
                selected.append(_task_preview(task))
        selected.sort(key=lambda t: (priority_rank(t.get("priority")), str(t.get("created_at") or ""), str(t.get("id") or "")))
        if len(selected) > sample_limit:
            selected = selected[:sample_limit]
        return selected

    output = {
        "ok": True,
        "action": "overview",
        "file": str(path),
        "board": {
            "total_tasks": len(tasks),
            "columns": list(board.get("columns") or []),
            "counts_by_column": by_column,
            "counts_by_status": by_status,
            "counts_by_priority": by_priority,
            "blocked_count": blocked,
            "events_count": len(board.get("events") or []),
            "agents_count": len(board.get("agents") or {}),
        },
        "samples": {
            "in_progress": _sample(lambda t: str(t.get("status") or column_to_status(t.get("column"))).lower() in IN_PROGRESS_STATUSES),
            "blocked": _sample(lambda t: task_is_blocked(t, tasks_by_id)),
            "high_priority_todo": _sample(
                lambda t: str(t.get("column") or "") in {"todo", "doing", "review"}
                and priority_rank(t.get("priority")) <= 1
            ),
        },
        "recommended_next_calls": [
            "tasks list --column todo --limit 20",
            "tasks plan --agent <agent_id>",
            "tasks explain --id <task_id>",
        ],
    }
    _emit_json(output)


