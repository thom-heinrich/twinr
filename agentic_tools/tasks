def cmd_read(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    board = load_board(path)
    invoked_command = str(getattr(args, "command", "read") or "read").strip().lower() or "read"
    include_events = bool(getattr(args, "include_events", False))
    # LLM-friendly guardrails:
    # - `tasks read <task_id>` is a common mistake (positional is meant to be column).
    # - `tasks get <task_id>` is now supported as an alias; it uses `id_positional`.
    id_positional = str(getattr(args, "id_positional", "") or "").strip()
    if not getattr(args, "id", None) and id_positional:
        args.id = id_positional
    if not getattr(args, "id", None):
        col_pos = str(getattr(args, "column_positional", "") or "").strip()
        col_flag = str(getattr(args, "column", "") or "").strip()
        if col_pos and (not col_flag) and _looks_like_task_id(col_pos):
            args.id = col_pos
            args.column_positional = None
    if args.id:
        task = board["tasks"].get(args.id)
        if not task:
            _emit_json(
                {
                    "ok": False,
                    "error": "not_found",
                    "detail": f"Task '{args.id}' not found.",
                }
            )
            sys.exit(1)
        public_task = task_to_public(task)
        next_steps = next_steps_for_task_action(
            action="read",
            task_id=str(public_task.get("id") or ""),
            title=str(public_task.get("title") or ""),
            column=str(public_task.get("column") or ""),
            status=str(public_task.get("status") or ""),
            links=list(public_task.get("links") or []),
            agent=str(getattr(args, "agent", "") or ""),
        )
        _emit_json(
            {
                "ok": True,
                "action": invoked_command,
                "file": str(path),
                "task": public_task,
                "next_steps": next_steps,
            }
        )
        return

    column = args.column or args.column_positional
    if column:
        ensure_column(board, column)

    tags = getattr(args, "tags", None) or []
    tags = [t for t in tags if t]
    statuses = getattr(args, "statuses", None) or []
    statuses = [s for s in statuses if s]
    assignee = getattr(args, "assignee", None)
    search = getattr(args, "search", None)
    filters_present = bool(tags or statuses or assignee or search)
    limit = int(getattr(args, "limit", 0) or 0)

    if column or filters_present:
        tasks_list = [
            task_to_public(t)
            for t in board["tasks"].values()
            if (not column or t.get("column") == column)
        ]
        if filters_present:
            tasks_list = [
                t
                for t in tasks_list
                if task_matches_filters(
                    t,
                    tags=tags or None,
                    assignee=assignee,
                    statuses=statuses or None,
                    search=search,
                )
            ]
        tasks_list.sort(key=lambda t: (t.get("created_at", ""), t.get("id", "")))
        total_count = len(tasks_list)
        truncated = False
        if limit > 0 and len(tasks_list) > limit:
            tasks_list = tasks_list[:limit]
            truncated = True
        out: Dict[str, Any] = {
            "ok": True,
            "action": invoked_command,
            "file": str(path),
            "tasks": tasks_list,
            "count": len(tasks_list),
        }
        if truncated:
            out["total_count"] = total_count
            out["truncated"] = True
            out["limit"] = limit
        if column:
            out["column"] = column
        if filters_present:
            out["filters"] = {
                "tags": tags or None,
                "assignee": assignee or None,
                "status": statuses or None,
                "search": search or None,
            }
        out["recommended_next_calls"] = [
            "tasks explain --id <task_id>",
            "tasks move --id <task_id> --column doing",
            "tasks log --id <task_id> --kind progress --text \"...\"",
        ]
        out["next_steps"] = [
            {
                "text": "Explain a task to see normalized what/why/how and links.",
                "commands": ["tasks explain --id <task_id>"],
                "links": [],
            },
            {
                "text": "Move a task through the workflow once you start/finish work.",
                "commands": ["tasks move --id <task_id> --column doing"],
                "links": [],
            },
        ]
        _emit_json(out)
        return

    # `tasks list` (no filters) should be safe and match the mental model: list tasks, not the entire board.
    # `tasks read` remains the canonical "show board" entrypoint.
    if invoked_command == "list":
        tasks_list = [task_to_public(t) for t in board["tasks"].values()]
        tasks_list.sort(
            key=lambda t: (
                str(t.get("updated_at") or ""),
                str(t.get("created_at") or ""),
                str(t.get("id") or ""),
            ),
            reverse=True,
        )
        total_count = len(tasks_list)
        truncated = False
        if limit > 0 and len(tasks_list) > limit:
            tasks_list = tasks_list[:limit]
            truncated = True
        out: Dict[str, Any] = {
            "ok": True,
            "action": invoked_command,
            "file": str(path),
            "tasks": tasks_list,
            "count": len(tasks_list),
        }
        if truncated:
            out["total_count"] = total_count
            out["truncated"] = True
            out["limit"] = limit
        out["recommended_next_calls"] = [
            "tasks overview",
            "tasks explain --id <task_id>",
            "tasks list --column todo --limit 20",
        ]
        out["next_steps"] = [
            {
                "text": "Use the compact overview to pick the next actionable work item.",
                "commands": ["tasks overview"],
                "links": [],
            },
            {
                "text": "Explain a task to see normalized what/why/how and links.",
                "commands": ["tasks explain --id <task_id>"],
                "links": [],
            },
        ]
        _emit_json(out)
        return

    tasks = {tid: task_to_public(t) for tid, t in board["tasks"].items()}
    out_board = dict(board)
    out_board["tasks"] = tasks
    events = out_board.get("events", [])
    events_list = events if isinstance(events, list) else []
    out_board["events_count"] = len(events_list)
    if not include_events:
        out_board["events"] = []
        out_board["events_truncated"] = len(events_list) > 0
    out: Dict[str, Any] = {"ok": True, "action": invoked_command, "file": str(path), "board": out_board}
    out["recommended_next_calls"] = [
        "tasks overview",
        "tasks list --column todo --limit 20",
