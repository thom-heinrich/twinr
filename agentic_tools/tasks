def main(argv: Optional[List[str]] = None) -> None:
    parser = build_parser()
    argv_list = list(sys.argv[1:] if argv is None else argv)
    pretty_guess = "--json-pretty" in argv_list

    # Allow global flags to appear after the subcommand (LLM/tool friendly).
    _global_arity = {"--json-pretty": 0, "--file": 1}
    moved: List[str] = []
    rest: List[str] = []
    i = 0
    while i < len(argv_list):
        a = argv_list[i]
        if a in _global_arity:
            n = _global_arity[a]
            if n:
                # Missing value: do not reorder (let argparse report).
                if i + n >= len(argv_list):
                    rest.append(a)
                    i += 1
                    continue
                moved.append(a)
                moved.extend(argv_list[i + 1 : i + 1 + n])
                i += 1 + n
                continue
            moved.append(a)
            i += 1
            continue
        if a.startswith("--file="):
            moved.append(a)
            i += 1
            continue
        rest.append(a)
        i += 1
    argv_list = moved + rest

    try:
        args = parser.parse_args(argv_list)
    except _TaskArgparseError as exc:
        payload: Dict[str, Any] = {
            "ok": False,
            "error": "invalid_arguments",
            "error_code": "ARGPARSE_ERROR",
            "detail": exc.message,
            "retryable": False,
        }
        usage = (exc.usage or "").strip()
        if usage:
            payload["usage"] = usage
        _emit_json(payload, pretty=pretty_guess)
        sys.exit(2)
    except SystemExit:
        raise

    global _JSON_PRETTY
    _JSON_PRETTY = bool(getattr(args, "json_pretty", False))

    try:
        handler = getattr(args, "func", None)
        handler_name = getattr(handler, "__name__", "")
        if handler_name in _MUTATING_TASK_HANDLERS:
            _run_task_mutation_with_retry(handler_name.replace("cmd_", ""), lambda: handler(args))
        else:
            handler(args)
    except _TaskUserError as exc:
        _emit_json(exc.payload)
        sys.exit(int(exc.exit_code))
    except FileLockTimeout as e:
        _emit_json(
            {
                "ok": False,
                "error": "lock_timeout",
                "detail": str(e),
            }
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
