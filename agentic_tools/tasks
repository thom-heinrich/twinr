def now_iso() -> str:
    """Return current UTC timestamp in ISO8601 format with 'Z'."""
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def _scan_repo_files_for_script_anchors(repo_root: Path) -> List[str]:
    """
    Return candidate repo-relative file paths for script:<path> anchors.

    IMPORTANT: We intentionally avoid `git` here. This repo is often deployed without a
    git worktree, and agents must still be able to validate script anchors deterministically.
    """
    # Keep this intentionally cheap. Most anchors in tasks should be explicit repo-relative paths.
    # Basename-only anchors are strongly discouraged; we only support repo-root files here.
    out: List[str] = []
    for child in repo_root.iterdir():
        if child.is_file():
            out.append(child.name)
    return sorted(set(out))


def _git_ls_files(repo_root: Path) -> List[str]:
    """
    Backward-compatible test seam for legacy callers that monkeypatch git-backed discovery.

    The tasks tool no longer shells out to `git ls-files`; it uses deterministic local
    repo scanning instead. This shim preserves the historical hook name for tests and
    other read-only integrations that still patch it.
    """
    return _scan_repo_files_for_script_anchors(Path(repo_root))


def _build_repo_file_index(repo_root: Path) -> Tuple[set[str], Dict[str, List[str]]]:
    repo_files = _scan_repo_files_for_script_anchors(repo_root)
    repo_files_set = set(repo_files)
    by_basename: Dict[str, List[str]] = {}
    for p in repo_files:
        by_basename.setdefault(Path(p).name, []).append(p)
    return repo_files_set, by_basename


def _is_reasonable_script_anchor_path(path: str) -> bool:
    p = (path or "").strip()
    if not p:
        return False
    if p.startswith(
        (
            "state/",
            "reports/",
            "research/",
            "artifacts/stores/",
            "artifacts/reports/",
            "logs/",
            "exports/",
        )
    ):
        return False
    if p.startswith("__ignore__/"):
        return False
    if "/__pycache__/" in p or p.endswith("/__pycache__/"):
        return False
    return True


def _normalize_repo_path(raw: str) -> str:
    s = str(raw or "").strip()
    if not s:
        return ""
    if s.startswith("./"):
        s = s[2:]
    rp = str(REPO_ROOT) + "/"
    if s.startswith(rp):
        s = s[len(rp) :]
    rp_noslash = str(REPO_ROOT).lstrip("/") + "/"
    if s.startswith(rp_noslash):
        s = s[len(rp_noslash) :]
    if s.startswith("/etc/systemd/system/"):
        unit = s.split("/etc/systemd/system/", 1)[1]
        s = f"systemd/units/{unit}"
    return s


def _resolve_repo_path(
    raw: str,
    *,
    repo_files_set: set[str],
    by_basename: Dict[str, List[str]],
) -> Optional[str]:
    s = _normalize_repo_path(raw)
    if not s:
        return None

    if any(part == ".." for part in Path(s).parts):
        return None

    if not _is_reasonable_script_anchor_path(s):
        return None

    # Prefer filesystem truth over any external index. Some deployments lack a git worktree
    # (or include untracked-but-real repo files like audit/*), but anchors should still resolve.
    if (REPO_ROOT / s).is_file():
        return s
    if repo_files_set and s in repo_files_set:
        return s

    # Basename-only fallback (unique only).
    if "/" not in s:
        # Accept repo-root files directly (e.g. ".env.example").
        if (REPO_ROOT / s).is_file():
            return s
        candidates = sorted(set(by_basename.get(Path(s).name, [])))
        if len(candidates) == 1:
            return candidates[0]
    return None


def _path_rank(path: str) -> Tuple[int, str]:
    if path.startswith("services/"):
        return (0, path)
    if path.startswith("scripts/"):
        return (1, path)
    if path.startswith("systemd/units/"):
        return (2, path)
    if path.startswith("agentic_tools/"):
        return (3, path)
    if path.startswith("llm/"):
        return (4, path)
    if path.startswith("artifacts/llm/"):
        return (4, path)
    if path.startswith("artifacts/evaluations/"):
        return (5, path)
    if path.startswith("artifacts/audit/"):
        return (6, path)
    return (10, path)


def _dedupe_keep_order(items: List[str]) -> List[str]:
    seen: set[str] = set()
    out: List[str] = []
    for x in items:
        x = str(x).strip()
        if not x or x in seen:
            continue
        seen.add(x)
        out.append(x)
    return out


def _as_string_list(value: Any) -> List[str]:
    if isinstance(value, list):
        out: List[str] = []
        for item in value:
            if item is None:
                continue
            text = str(item).strip()
            if text:
                out.append(text)
        return out
    if isinstance(value, str):
        text = value.strip()
        return [text] if text else []
    return []


def _pick_first_nonempty(*values: Any) -> str:
    for value in values:
        if value is None:
            continue
        text = str(value).strip()
        if text:
            return text
    return ""


def _collect_text_blobs_for_link_extraction(value: Any, *, max_items: int = 200) -> List[str]:
    """
    Collect string blobs for link extraction from an arbitrary JSON-like value.

    Policy:
    - recurse through dict/list structures
    - skip common non-text keys (links/metadata) to avoid echoing already-normalized tokens
    - cap items to keep work bounded
    """
    out: List[str] = []

    def _walk(v: Any) -> None:
        if len(out) >= int(max_items):
            return
        if isinstance(v, str):
            s = v.strip()
            if s:
                out.append(s)
            return
        if isinstance(v, dict):
            for k, vv in v.items():
                if len(out) >= int(max_items):
                    return
                if str(k) in {"links", "metadata"}:
                    continue
                _walk(vv)
            return
        if isinstance(v, list):
            for vv in v:
                if len(out) >= int(max_items):
                    return
                _walk(vv)
            return

    _walk(value)
    return out


def _normalize_and_validate_links(
    links: List[str],
    *,
    repo_files_set: set[str],
    by_basename: Dict[str, List[str]],
    require_script_anchor: bool,
) -> List[str]:
    raw = [str(x).strip() for x in links if isinstance(x, str) and str(x).strip()]
    raw = _dedupe_keep_order(raw)

    bad = [x for x in raw if not LINK_TOKEN_RE.fullmatch(x)]
    if bad:
        raise _TaskUserError(
            {
                "ok": False,
                "error": "invalid_link",
                "detail": "Invalid link token(s). Expected '<kind>:<id>' (no whitespace). See architecture/LINKS_CONTRACT.md.",
                "bad": bad[:20],
            }
        )

    normalized: List[str] = []
    unresolved_scripts: List[str] = []
    for token in raw:
        if not token.startswith("script:"):
            normalized.append(token)
            continue
        raw_path = token.split("script:", 1)[1].strip()
        rp = _resolve_repo_path(raw_path, repo_files_set=repo_files_set, by_basename=by_basename)
        if rp is None:
            unresolved_scripts.append(raw_path)
            continue
        normalized.append(f"script:{rp}")

    if unresolved_scripts:
        raise _TaskUserError(
            {
                "ok": False,
                "error": "invalid_script_anchor",
                "detail": "One or more script:<path> anchors could not be resolved to a safe repo file path. Use a repo-relative file path under /home/thh/tessairact.",
                "bad_paths": unresolved_scripts[:20],
            }
        )

    # Stable ordering for script anchors improves diffability.
    scripts = [t for t in normalized if t.startswith("script:")]
    others = [t for t in normalized if not t.startswith("script:")]
    scripts_sorted = sorted({t.split("script:", 1)[1] for t in scripts}, key=_path_rank)
    normalized = _dedupe_keep_order([f"script:{p}" for p in scripts_sorted] + others)

    if require_script_anchor and not any(t.startswith("script:") for t in normalized):
        raise _TaskUserError(
            {
                "ok": False,
                "error": "missing_script_anchor",
                "detail": (
                    "New tasks MUST include at least one explicit script anchor in task.links. "
                    "Pass --script <repo_relative_path> (repeatable) or --link script:<repo_relative_path>. "
                    "If this is an unanchored intake task, pass --allow-no-script-anchor."
                ),
            }
        )

    return normalized


class FileLockTimeout(_GovernanceFileLockTimeout):
    """Raised when the shared governance lock budget is exhausted."""


class FileLock(_GovernanceFileLock):
    """Tasks board lock backed by the shared governance lock primitive."""

    def __init__(self, path: Path, timeout: float = 10.0, poll_interval: float = 0.05) -> None:
        settings = _resolve_governance_lock_settings(
            timeout_envs=("CAIA_TASKS_LOCK_TIMEOUT_SEC", "TASKS_LOCK_TIMEOUT"),
            timeout_default=float(timeout),
            poll_env="CAIA_TASKS_LOCK_POLL_SEC",
            poll_default=float(poll_interval),
            stale_env="CAIA_TASKS_LOCK_STALE_SEC",
            stale_default=120,
            heartbeat_env="CAIA_TASKS_LOCK_HEARTBEAT_SEC",
        )
        super().__init__(
            path=Path(path),
            timeout_sec=settings.timeout_sec,
            poll_sec=settings.poll_sec,
            stale_after_sec=settings.stale_after_sec,
            heartbeat_sec=settings.heartbeat_sec,
        )


def column_to_status(column: Optional[str]) -> str:
    mapping = {
        "backlog": "open",
        "todo": "ready",
        "doing": "in_progress",
        "review": "review",
        "done": "done",
    }
    if column is None:
        return "open"
    return mapping.get(column, "open")


def normalize_task(task: Dict[str, Any]) -> None:
    """Ensure a task dict has all fields needed for collaboration features."""
    if "column" not in task or not task.get("column"):
        task["column"] = "backlog"

    if "status" not in task or not isinstance(task["status"], str):
        task["status"] = column_to_status(task.get("column"))

    if "priority" not in task or task["priority"] is None:
        task["priority"] = "normal"

    tags = task.get("tags")
    if tags is None:
        task["tags"] = []
    elif not isinstance(tags, list):
        task["tags"] = [tags]

    relations = task.get("relations")
    if relations is None:
        task["relations"] = []
    elif not isinstance(relations, list):
        task["relations"] = []

    links = task.get("links")
    if links is None:
        task["links"] = []
    elif not isinstance(links, list):
        task["links"] = []

    metadata = task.get("metadata")
    if metadata is None or not isinstance(metadata, dict):
        task["metadata"] = {}

    if "lease_owner" not in task:
        task["lease_owner"] = None
    if "lease_expires_at" not in task:
        task["lease_expires_at"] = None

    now = now_iso()
    if "created_at" not in task:
        task["created_at"] = now
    if "updated_at" not in task:
        task["updated_at"] = now


def load_board(path: Path) -> Dict[str, Any]:
    if not path.exists():
        now = now_iso()
        return {
            "version": 2,
            "created_at": now,
            "updated_at": now,
            "revision": 0,
            "columns": list(DEFAULT_COLUMNS),
            "tasks": {},
            "events": [],
            "agents": {},
        }
    with path.open("r", encoding="utf-8") as f:
        try:
            board = json.load(f)
        except json.JSONDecodeError as e:
            raise _TaskUserError(
                {
                    "ok": False,
                    "error": "invalid_json",
                    "detail": f"Failed to parse board JSON: {e}",
                }
            ) from e
    if "tasks" not in board or not isinstance(board["tasks"], dict):
        board["tasks"] = {}
    if "columns" not in board or not isinstance(board["columns"], list):
        board["columns"] = list(DEFAULT_COLUMNS)
    if "revision" not in board:
        board["revision"] = 0
    if "version" not in board:
        board["version"] = 1
    if "events" not in board or not isinstance(board["events"], list):
        board["events"] = []
    if "agents" not in board or not isinstance(board["agents"], dict):
        board["agents"] = {}

    for task in board["tasks"].values():
        if isinstance(task, dict):
            normalize_task(task)

    return board


def save_board(path: Path, board: Dict[str, Any]) -> None:
    board["updated_at"] = now_iso()
    board["revision"] = int(board.get("revision", 0)) + 1
    tmp_path = path.with_suffix(path.suffix + ".tmp")
    with tmp_path.open("w", encoding="utf-8") as f:
        json.dump(board, f, ensure_ascii=False, indent=2, sort_keys=True)
        f.write("\n")
    tmp_path.replace(path)


def generate_task_id(board: Dict[str, Any]) -> str:
    # Short UUID-based id to avoid collisions and keep it machine-friendly.
    tasks = board.get("tasks", {})
    while True:
        candidate = uuid.uuid4().hex[:12]
        if candidate not in tasks:
            return candidate


def task_to_public(task: Dict[str, Any]) -> Dict[str, Any]:
    """Return a stable, public representation of a task.

    This function can be used to filter out any internal-only fields later if needed.
    For now it just returns the task as-is.
    """
    return dict(task)


def task_status_lower(task: Dict[str, Any]) -> str:
    """Return task status in lower-case, falling back to column mapping."""
    status = task.get("status")
    if isinstance(status, str) and status:
        return status.lower()
    return column_to_status(task.get("column")).lower()


def task_matches_filters(
    task: Dict[str, Any],
    tags: Optional[List[str]] = None,
    assignee: Optional[str] = None,
    statuses: Optional[List[str]] = None,
    search: Optional[str] = None,
) -> bool:
    """Return True if task matches all provided filters."""
    if tags:
        desired_tags = [str(t).lower() for t in tags if t]
        task_tags = [str(t).lower() for t in (task.get("tags") or [])]
        if not all(t in task_tags for t in desired_tags):
            return False

    if assignee:
        task_assignee = task.get("assignee")
        task_assignee_str = task_assignee if isinstance(task_assignee, str) else ""
        if task_assignee_str.lower() != assignee.lower():
            return False

    if statuses:
        desired_statuses = {str(s).lower() for s in statuses if s}
        if task_status_lower(task) not in desired_statuses:
            return False

    if search:
        q = search.lower()
        fields: List[str] = []
        for key in ("id", "title", "description", "assignee", "column", "status"):
            val = task.get(key)
            if isinstance(val, str) and val:
                fields.append(val)
        tags_val = task.get("tags") or []
        if isinstance(tags_val, list):
            fields.extend([str(t) for t in tags_val if t is not None])
        links_val = task.get("links") or []
        if isinstance(links_val, list):
            fields.extend([str(x) for x in links_val if x is not None])
        meta = task.get("metadata")
        if isinstance(meta, dict) and meta:
            try:
                fields.append(json.dumps(meta, ensure_ascii=False, sort_keys=True))
            except (TypeError, ValueError):
                pass
        haystack = " ".join(fields).lower()
        if q not in haystack:
            return False

    return True


def ensure_column(board: Dict[str, Any], column: str) -> None:
    if column not in board["columns"]:
        raise _TaskUserError(
            {
                "ok": False,
                "error": "unknown_column",
                "detail": f"Column '{column}' is not defined.",
                "columns": board["columns"],
            }
        )


def current_in_progress_tasks(board: Dict[str, Any], limit: int = 20) -> List[Dict[str, Any]]:
    """Return a list of tasks that are currently in progress.

    A task is considered in progress if:
    - It is in the "doing" column, or
    - It has a non-null lease_owner (leased to an agent), regardless of column.
    """
    tasks = board.get("tasks", {})
    if not isinstance(tasks, dict):
        return []

    in_progress: List[Dict[str, Any]] = []
    for task in tasks.values():
        column = task.get("column")
        lease_owner = task.get("lease_owner")
        if column == "doing" or lease_owner:
            in_progress.append(task)

    # Sort by most recently updated, then id for stability.
    in_progress.sort(
        key=lambda t: (t.get("updated_at", t.get("created_at", "")), t.get("id", ""))
    )
    if limit is not None and limit > 0 and len(in_progress) > limit:
        in_progress = in_progress[-limit:]

    return [task_to_public(t) for t in in_progress]


def priority_rank(priority: Any) -> int:
    if isinstance(priority, (int, float)):
        return int(priority)
    if not isinstance(priority, str):
        return 50
    p = priority.lower()
    mapping = {
        "urgent": 0,
        "now": 0,
        "high": 1,
        "medium": 2,
        "normal": 2,
        "low": 3,
    }
    return mapping.get(p, 50)


def build_task_index(board: Dict[str, Any]) -> Dict[str, Dict[str, Any]]:
    tasks = board.get("tasks", {})
    index: Dict[str, Dict[str, Any]] = {}
    if isinstance(tasks, dict):
        for tid, task in tasks.items():
            if isinstance(task, dict):
                if "id" not in task:
                    task["id"] = tid
                index[tid] = task
    return index


def task_is_blocked(task: Dict[str, Any], tasks_by_id: Dict[str, Dict[str, Any]]) -> bool:
    relations = task.get("relations") or []
    for rel in relations:
        if not isinstance(rel, dict):
            continue
        rel_type = rel.get("type")
        other_id = rel.get("task_id")
        if rel_type not in ("blocked_by", "depends_on"):
            continue
        if not other_id:
            continue
        other = tasks_by_id.get(other_id)
        if not other:
            continue
        status = other.get("status") or column_to_status(other.get("column"))
        if status.lower() not in DONE_STATUSES:
            return True
    return False


def append_event(board: Dict[str, Any], event: Dict[str, Any]) -> None:
    events = board.setdefault("events", [])
    if not isinstance(events, list):
        events = []
        board["events"] = events
    events.append(event)
    if MAX_EVENTS > 0 and len(events) > MAX_EVENTS:
        # Drop oldest events.
        del events[0 : len(events) - MAX_EVENTS]


def make_event(
    kind: str,
    actor: Optional[str],
    task_id: Optional[str],
    payload: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    return {
        "id": uuid.uuid4().hex[:16],
        "ts": now_iso(),
        "kind": kind,
        "actor": actor,
        "task_id": task_id,
        "payload": payload or {},
    }


