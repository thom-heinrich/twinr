def task_is_available_for_lease(task: Dict[str, Any], now_ts: float) -> bool:
    lease_owner = task.get("lease_owner")
    lease_expires_at = task.get("lease_expires_at")
    if not lease_owner and not lease_expires_at:
        return True
    if not lease_expires_at:
        return False
    try:
        time_struct = time.strptime(lease_expires_at, "%Y-%m-%dT%H:%M:%SZ")
        exp_ts = time.mktime(time_struct)
    except Exception:
        return False
    return exp_ts <= now_ts


def cmd_pull(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    if not args.agent:
        raise _TaskUserError(
            {
                "ok": False,
                "error": "missing_agent",
                "detail": "Argument --agent is required for pull.",
            }
        )
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    in_progress: List[Dict[str, Any]] = []
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        ensure_column(board, args.column)
        now_ts = time.time()
        candidates = [
            t
            for t in board["tasks"].values()
            if t.get("column") == args.column and task_is_available_for_lease(t, now_ts)
        ]
        candidates.sort(
            key=lambda t: (
                priority_rank(t.get("priority")),
                t.get("created_at", ""),
                t.get("id", ""),
            )
        )

        limit = max(1, args.limit)
        selected: List[Dict[str, Any]] = []
        lease_seconds = max(1, args.lease_seconds)
        expires_at = time.strftime(
            "%Y-%m-%dT%H:%M:%SZ", time.gmtime(now_ts + lease_seconds)
        )

        for task in candidates[:limit]:
            task["lease_owner"] = args.agent
            task["lease_expires_at"] = expires_at
            task["updated_at"] = now_iso()
            selected.append(task_to_public(task))
            append_event(
                board,
                make_event(
                    "task_leased",
                    args.agent,
                    task.get("id"),
                    {
                        "column": task.get("column"),
                        "lease_expires_at": expires_at,
                    },
                ),
            )

        in_progress = current_in_progress_tasks(board, limit=20)
        collab_context = build_collab_context(board, agent_id=args.agent)
        save_board(path, board)

    pull_steps: List[Dict[str, Any]] = []
