def parse_json_arg(raw: Optional[str], arg_name: str) -> Dict[str, Any]:
    if raw is None:
        return {}
    try:
        value = json.loads(raw)
    except json.JSONDecodeError as e:
        raise _TaskUserError(
            {
                "ok": False,
                "error": "invalid_json_arg",
                "detail": f"Failed to parse JSON for {arg_name}: {e}",
            }
        ) from e
    if not isinstance(value, dict):
        raise _TaskUserError(
            {
                "ok": False,
                "error": "invalid_json_arg",
                "detail": f"Expected JSON object for {arg_name}.",
            }
        )
    return value


def build_agent_plan(
    board: Dict[str, Any],
    agent_id: str,
    limit: int,
    include_blocked: bool,
    include_done: bool,
) -> Dict[str, Any]:
    tasks = list(board.get("tasks", {}).values())
    tasks_by_id = build_task_index(board)
    agents = board.get("agents", {})
    agent = agents.get(agent_id) or {"id": agent_id}
    skills = set(agent.get("skills") or [])

    def task_status(task: Dict[str, Any]) -> str:
        status = task.get("status")
        if isinstance(status, str):
            return status.lower()
        return column_to_status(task.get("column")).lower()

    def score_task(task: Dict[str, Any]) -> Tuple[int, bool, int, str, str]:
        prio_rank = priority_rank(task.get("priority"))
        blocked = task_is_blocked(task, tasks_by_id)
        tags = set(task.get("tags") or [])
        skill_match = len(skills & tags)
        created_at = task.get("created_at", "")
        tid = task.get("id", "")
        # Lower tuple is better: priority, blocked, -skill_match, created_at, id
        return (prio_rank, blocked, -skill_match, created_at, tid)

    wip: List[Dict[str, Any]] = []
    ready: List[Dict[str, Any]] = []
    blocked_list: List[Dict[str, Any]] = []
    done_list: List[Dict[str, Any]] = []

    for task in tasks:
        if not isinstance(task, dict):
            continue
        status = task_status(task)
        if status in DONE_STATUSES:
            done_list.append(task)
            if not include_done:
                continue

        is_wip = task.get("lease_owner") == agent_id or task.get("assignee") == agent_id
        if is_wip and status not in DONE_STATUSES:
            wip.append(task)
            continue

        blocked_flag = task_is_blocked(task, tasks_by_id)
        if blocked_flag:
            blocked_list.append(task)
        else:
            if status in DONE_STATUSES and not include_done:
                continue
            ready.append(task)

    wip_sorted = sorted(wip, key=score_task)
    ready_sorted = sorted(ready, key=score_task)
    blocked_sorted = sorted(blocked_list, key=score_task)

    limit = max(1, limit)
    suggestions: List[Dict[str, Any]] = ready_sorted[:limit]
    if include_blocked and len(suggestions) < limit:
        suggestions = suggestions + blocked_sorted[: limit - len(suggestions)]

    status_counts: Dict[str, int] = {}
    for task in tasks:
        status = (task.get("status") or column_to_status(task.get("column"))).lower()
        status_counts[status] = status_counts.get(status, 0) + 1

    summary = {
        "total_tasks": len(tasks),
        "status_counts": status_counts,
        "agent_wip": len(wip_sorted),
        "agent_ready_candidates": len(ready_sorted),
        "agent_blocked_candidates": len(blocked_sorted),
        "agent_suggestions": len(suggestions),
    }

    return {
        "agent": agent,
        "wip": [task_to_public(t) for t in wip_sorted],
        "ready": [task_to_public(t) for t in ready_sorted],
        "blocked": [task_to_public(t) for t in blocked_sorted],
        "done": [task_to_public(t) for t in done_list] if include_done else [],
        "suggested": [task_to_public(t) for t in suggestions],
        "summary": summary,
    }


def build_collab_context(
    board: Dict[str, Any],
    agent_id: Optional[str] = None,
    suggestion_limit: int = 8,
) -> Dict[str, Any]:
    """Build a compact collaboration context snapshot for agents.

    Agents sollen dieses Tool als globalen, gemeinsamen Zustand betrachten:
    - Vor jedem Planungsschritt erneut synchronisieren.
    - Nach jeder Änderung den Zustand wieder hier reinschreiben.
    """
    tasks_by_id = build_task_index(board)
    total_tasks = len(tasks_by_id)

    status_counts: Dict[str, int] = {}
    column_counts: Dict[str, int] = {}
    for t in tasks_by_id.values():
        status = (t.get("status") or column_to_status(t.get("column"))).lower()
        status_counts[status] = status_counts.get(status, 0) + 1
        col = t.get("column") or "backlog"
        column_counts[col] = column_counts.get(col, 0) + 1

    in_progress_sample = current_in_progress_tasks(board, limit=20)

    context: Dict[str, Any] = {
        "board": {
            "total_tasks": total_tasks,
            "status_counts": status_counts,
            "column_counts": column_counts,
            "in_progress_sample": in_progress_sample,
        },
        "usage_hint": (
            "Agents: This tool is the single shared source of truth for tasks. "
            "On EVERY reasoning/planning step BEFORE deciding next actions, "
            "re-sync with `agent-view` or `plan`. AFTER acting, update the "
            "relevant tasks here so other agents see the fresh state. "
            "Do NOT cache task state in your own memory; always trust the board. "
            "Also, whenever you touch scripts or services for a task, record the change in `scripthistory` so provenance stays accurate, "
            "and if your work updates or tests a trading/analytics hypothesis, capture that via the `hypothesis` tool as well."
        ),
    }

    if agent_id:
        plan = build_agent_plan(
            board,
            agent_id=agent_id,
            limit=suggestion_limit,
            include_blocked=False,
            include_done=False,
        )
        context["agent"] = {
            "id": agent_id,
            "summary": plan["summary"],
            "wip": plan["wip"],
            "suggested_next_tasks": plan["suggested"],
        }
        recommended_args_agent = agent_id
    else:
        recommended_args_agent = "<agent-id>"

    context["recommended_next_calls"] = [
        {
            "command": "agent-view",
            "args": {"--agent": recommended_args_agent, "--limit": suggestion_limit},
            "purpose": (
                "Get your fresh WIP and suggested next tasks BEFORE deciding "
                "what to do next."
            ),
        },
        {
            "command": "events",
            "args": {"--agent": recommended_args_agent, "--limit": 50},
            "purpose": "Inspect recent collaboration events relevant to you.",
        },
    ]

    return context


def cmd_add(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    repo_files_set, by_basename = _build_repo_file_index(REPO_ROOT)
    in_progress: List[Dict[str, Any]] = []
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        ensure_column(board, args.column)

        payload = parse_json_arg(args.data, "--data")
        title = payload.get("title") or args.title
        if not title:
            raise _TaskUserError(
                {
                    "ok": False,
                    "error": "missing_title",
                    "detail": "Task title is required (in --title or --data).",
                }
            )

        description = payload.get("description")
        if getattr(args, "description", None):
            description = args.description

        priority = payload.get("priority")
        if getattr(args, "priority", None):
            priority = args.priority
        if priority is None:
            priority = "normal"

        assignee = payload.get("assignee")
        if getattr(args, "assignee", None):
            assignee = args.assignee

        tags = payload.get("tags", []) or []
        cli_tags = getattr(args, "tags", None) or []
        if cli_tags:
            tags = list(tags) + cli_tags

        links = payload.get("links", []) or []
        cli_links = getattr(args, "links", None) or []
        if cli_links:
            links = list(links) + cli_links

        cli_scripts = getattr(args, "scripts", None) or []
        if cli_scripts:
            links = list(links) + [f"script:{s}" for s in cli_scripts if str(s).strip()]

        text_links = extract_link_tokens_from_texts([str(title or ""), str(description or "")])
        links = list(links) + list(text_links)
        links = append_codex_links(list(links))

        require_script_anchor = not bool(getattr(args, "allow_no_script_anchor", False))
        links = _normalize_and_validate_links(
            list(links),
            repo_files_set=repo_files_set,
            by_basename=by_basename,
            require_script_anchor=require_script_anchor,
        )

        metadata = payload.get("metadata", {}) or {}

        task_id = args.id or generate_task_id(board)
        now_ts = now_iso()
        status = payload.get("status") or column_to_status(args.column)
        task = {
            "id": task_id,
            "title": title,
            "column": args.column,
            "status": status,
            "created_at": now_ts,
            "updated_at": now_ts,
            "description": description,
            "priority": priority,
            "assignee": assignee,
            "tags": tags,
            "links": links,
            "metadata": metadata,
            "lease_owner": None,
            "lease_expires_at": None,
            "relations": payload.get("relations", []) or [],
        }
        for k, v in payload.items():
            if k not in task:
                task[k] = v

        board["tasks"][task_id] = task
        append_event(
            board,
            make_event(
                "task_created",
                getattr(args, "agent", None),
                task_id,
                {
                    "title": title,
                    "column": args.column,
                    "status": status,
                    "priority": priority,
                    "assignee": assignee,
                    "tags": tags,
                },
            ),
        )
        in_progress = current_in_progress_tasks(board, limit=20)
        collab_context = build_collab_context(
            board,
            agent_id=getattr(args, "agent", None),
        )
        save_board(path, board)

    public_task = task_to_public(task)
    next_steps = next_steps_for_task_action(
        action="add",
        task_id=str(public_task.get("id") or ""),
        title=str(public_task.get("title") or ""),
        column=str(public_task.get("column") or ""),
        status=str(public_task.get("status") or ""),
        links=list(public_task.get("links") or []),
        agent=str(getattr(args, "agent", "") or ""),
    )
    _emit_json(
        {
            "ok": True,
            "task": public_task,
            "next_steps": next_steps,
            "current_in_progress_tasks": {
                "note": (
                    "Keep in mind what other agents are currently working on "
