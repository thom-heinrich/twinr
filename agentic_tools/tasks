def build_parser() -> argparse.ArgumentParser:
    parser = _TaskArgumentParser(
        prog="tasks",
        description=(
            "Multi-agent collaboration task tracker CLI for AI/human agents.\n\n"
            "Related tools:\n"
            "  - `findings` for bug/smell intake linked to tasks.\n"
            "  - `fixreport` for closure and prevention after bug fixes.\n"
            "  - `rules`/`ssot` for governance and canonical references.\n"
            "  - `scripthistory`/`hypothesis` for provenance and scientific reasoning.\n\n"
            "Recommended workflow:\n"
            "  1) tasks overview\n"
            "  2) tasks list --column todo --limit 20\n"
            "  3) tasks explain --id <task_id>\n"
            "  4) tasks plan --agent <agent_id>\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--json-pretty",
        action="store_true",
        help="Pretty-print JSON output (indent=2). Default: compact JSON.",
    )
    parser.add_argument(
        "--file",
        default=BOARD_DEFAULT_FILENAME,
        help="Path to board JSON file (default: %(default)s)",
    )

    subparsers = parser.add_subparsers(
        dest="command",
        required=True,
        parser_class=_TaskArgumentParser,
    )

    p_init = subparsers.add_parser("init", help="Initialize a board file.")
    p_init.add_argument(
        "--columns",
        nargs="*",
        help="List of column names (default: backlog todo doing review done)",
    )
    p_init.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing board file if it exists.",
