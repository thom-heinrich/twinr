def attach_governance_hint(payload: Dict[str, Any]) -> Dict[str, Any]:
    """Attach a cross-tool governance hint to every API-style response."""
    if isinstance(payload, dict):
        _normalize_error_envelope(payload)
        payload = enrich_payload_with_hints(payload, tool="tasks")
    if isinstance(payload, dict) and "governance_hint" not in payload:
        payload["governance_hint"] = GOVERNANCE_HINT_TASKS
    return payload


def _looks_like_task_id(value: str) -> bool:
    """
    Heuristic: identify a task id passed positionally where argparse expects a column.

    Tasks created by this tool typically use short hex ids (e.g. 'aeded7f52295').
    We intentionally keep this conservative to avoid misclassifying real column names.
    """
    s = str(value or "").strip().lower()
    return bool(s and _TASK_ID_HEX_RE.fullmatch(s))


def _derive_error_code(error: Any) -> str:
    value = str(error or "").strip()
    if not value:
        return "UNKNOWN_ERROR"
    return _ERROR_CODE_TOKEN_RE.sub("_", value).strip("_").upper() or "UNKNOWN_ERROR"


def _default_retryable(error_code: str) -> bool:
    code = str(error_code or "").upper()
    if code in {"LOCK_TIMEOUT", "TIMEOUT", "IO_ERROR"}:
        return True
    if "TIMEOUT" in code or "LOCK" in code:
        return True
    return False


def _normalize_error_envelope(payload: Dict[str, Any]) -> None:
    """Ensure all error payloads expose the standard machine envelope."""
    if not isinstance(payload, dict):
        return
    if payload.get("ok") is not False:
        return
    error = str(payload.get("error") or "unknown_error")
    payload["error"] = error
    payload["detail"] = str(payload.get("detail") or "")
    error_code = str(payload.get("error_code") or "").strip() or _derive_error_code(error)
    payload["error_code"] = error_code
    if "retryable" not in payload:
        payload["retryable"] = _default_retryable(error_code)


class _TaskUserError(Exception):
    """Raised when a JSON payload should be emitted and the CLI should exit."""

    def __init__(self, payload: Dict[str, Any], exit_code: int = 1) -> None:
        super().__init__(str(payload.get("error") or "task_user_error"))
        self.payload = payload
        self.exit_code = int(exit_code)


def _json_dumps(payload: Any, *, pretty: bool) -> str:
    if pretty:
        return json.dumps(payload, indent=2, sort_keys=True)
    return json.dumps(payload, separators=(",", ":"), sort_keys=True)


def _emit_json(payload: Any, *, pretty: Optional[bool] = None) -> None:
    if pretty is None:
        pretty = bool(_JSON_PRETTY)
    out = attach_governance_hint(payload) if isinstance(payload, dict) else payload
    try:
        sys.stdout.write(_json_dumps(out, pretty=bool(pretty)) + "\n")
    except BrokenPipeError:
        try:
            sys.stdout.close()
        except Exception:
            pass


class _TaskArgparseError(Exception):
    """Raised when argument parsing fails and a JSON envelope should be emitted."""

    def __init__(self, message: str, usage: str = "") -> None:
        super().__init__(message)
        self.message = str(message)
        self.usage = str(usage or "")


class _TaskArgumentParser(argparse.ArgumentParser):
    """ArgumentParser variant that keeps stdout machine-oriented on failures."""

    def error(self, message: str) -> None:  # noqa: A003 (argparse API)
        raise _TaskArgparseError(str(message), self.format_usage())


