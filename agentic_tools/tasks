def cmd_relate(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        tasks = board.get("tasks", {})
        src = tasks.get(args.source_id)
        dst = tasks.get(args.target_id)
        if not src or not dst:
            missing = []
            if not src:
                missing.append(args.source_id)
            if not dst:
                missing.append(args.target_id)
            _emit_json(
                {
                    "ok": False,
                    "error": "not_found",
                    "detail": f"Task(s) not found: {', '.join(missing)}.",
                }
            )
            sys.exit(1)

        if "relations" not in src or not isinstance(src.get("relations"), list):
            src["relations"] = []
        if "relations" not in dst or not isinstance(dst.get("relations"), list):
            dst["relations"] = []

        rel_type = args.relation_type
        remove = args.remove

        def _remove_relation(task: Dict[str, Any], other_id: str, rtype: str) -> None:
            rels = task.get("relations") or []
            task["relations"] = [
                r
                for r in rels
                if not (
                    isinstance(r, dict)
                    and r.get("task_id") == other_id
                    and r.get("type") == rtype
                )
            ]

        def _add_relation(task: Dict[str, Any], other_id: str, rtype: str) -> None:
            rels = task.get("relations") or []
            for r in rels:
                if (
                    isinstance(r, dict)
                    and r.get("task_id") == other_id
                    and r.get("type") == rtype
                ):
                    return
            rels.append({"task_id": other_id, "type": rtype})
            task["relations"] = rels

        if remove:
            _remove_relation(src, args.target_id, rel_type)
            if rel_type in ("relates_to", "duplicate_of"):
                _remove_relation(dst, args.source_id, rel_type)
        else:
            _add_relation(src, args.target_id, rel_type)
            if rel_type in ("relates_to", "duplicate_of"):
                _add_relation(dst, args.source_id, rel_type)

        now_ts = now_iso()
        src["updated_at"] = now_ts
        dst["updated_at"] = now_ts
        tasks[src["id"]] = src
        tasks[dst["id"]] = dst

        append_event(
            board,
            make_event(
                "task_relation_removed" if remove else "task_relation_added",
                getattr(args, "agent", None),
                args.source_id,
                {
                    "from": args.source_id,
                    "to": args.target_id,
                    "type": rel_type,
                    "symmetric": rel_type in ("relates_to", "duplicate_of"),
                },
            ),
        )
        collab_context = build_collab_context(
            board,
            agent_id=getattr(args, "agent", None),
        )
        save_board(path, board)

    src_pub = task_to_public(src)
    dst_pub = task_to_public(dst)
    next_steps = []
    next_steps.extend(
        next_steps_for_task_action(
            action="relate",
            task_id=str(src_pub.get("id") or ""),
            title=str(src_pub.get("title") or ""),
            column=str(src_pub.get("column") or ""),
            status=str(src_pub.get("status") or ""),
            links=list(src_pub.get("links") or []),
            agent=str(getattr(args, "agent", "") or ""),
        )[:4]
    )
    _emit_json(
        {
            "ok": True,
            "source": src_pub,
            "target": dst_pub,
            "next_steps": next_steps,
            "collab_context": collab_context,
        }
    )


def cmd_log(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        task = board["tasks"].get(args.task_id)
        if not task:
            _emit_json(
                {
                    "ok": False,
                    "error": "not_found",
                    "detail": f"Task '{args.task_id}' not found.",
                }
            )
            sys.exit(1)

        payload = parse_json_arg(args.data, "--data")
        if args.text:
            payload.setdefault("text", args.text)

        # Auto-link: scan event payload text blobs and persist inferred link tokens.
        # This intentionally updates only payload.links (not task.links) so task-event edges
        # can be ingested deterministically with span-grounded evidence.
        payload_texts = _collect_text_blobs_for_link_extraction(payload, max_items=200)
        text_links = extract_link_tokens_from_texts(payload_texts)
        if text_links:
            existing = payload.get("links")
            existing_list: List[str] = list(existing) if isinstance(existing, list) else []
            merged = _dedupe_keep_order(existing_list + list(text_links))
            merged = [t for t in merged if LINK_TOKEN_RE.fullmatch(t)]
            if merged:
                payload["links"] = merged

        now_ts = now_iso()
        task["updated_at"] = now_ts
        task["last_activity_at"] = now_ts
        if args.agent:
            task["last_activity_actor"] = args.agent

        cur_links = task.get("links")
        cur_links_list: List[str] = list(cur_links) if isinstance(cur_links, list) else []
        links_with_codex = append_codex_links(cur_links_list)
        if links_with_codex != cur_links_list:
            task["links"] = links_with_codex
        board["tasks"][args.task_id] = task

        event = make_event(args.kind, args.agent, args.task_id, payload)
        append_event(board, event)
        collab_context = build_collab_context(
            board,
            agent_id=getattr(args, "agent", None),
        )
        save_board(path, board)

    public_task = task_to_public(task)
    next_steps = next_steps_for_task_action(
        action="log",
        task_id=str(public_task.get("id") or ""),
        title=str(public_task.get("title") or ""),
        column=str(public_task.get("column") or ""),
        status=str(public_task.get("status") or ""),
        links=list(public_task.get("links") or []),
        agent=str(getattr(args, "agent", "") or ""),
    )
    _emit_json(
        {
            "ok": True,
            "event": event,
            "task": public_task,
            "next_steps": next_steps,
            "collab_context": collab_context,
        }
    )


def cmd_events(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    board = load_board(path)
    events = board.get("events", []) or []
    filtered: List[Dict[str, Any]] = []

    for ev in events:
        if not isinstance(ev, dict):
            continue
        if args.task_id and ev.get("task_id") != args.task_id:
            continue
        if args.agent and ev.get("actor") != args.agent:
            continue
        if args.kind and ev.get("kind") != args.kind:
            continue
        if args.since and ev.get("ts", "") < args.since:
            continue
        filtered.append(ev)

    filtered.sort(key=lambda e: (e.get("ts", ""), e.get("id", "")))
    if args.limit and args.limit > 0 and len(filtered) > args.limit:
        filtered = filtered[-args.limit :]

    _emit_json(
        {
            "ok": True,
            "count": len(filtered),
            "events": filtered,
        }
    )


def cmd_agent_touch(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    collab_context: Optional[Dict[str, Any]] = None
    with lock:
        board = load_board(path)
        agents = board.setdefault("agents", {})
        agent = agents.get(args.agent) or {"id": args.agent}
        if args.kind:
            agent["kind"] = args.kind
        if args.role:
            agent["role"] = args.role

        skills = agent.get("skills") or []
        if not isinstance(skills, list):
            skills = [skills]
        if args.skills:
            skills = list(set(skills) | set(args.skills))
        agent["skills"] = sorted(skills)

        if args.wip_limit is not None:
            agent["wip_limit"] = int(args.wip_limit)

        metadata = agent.get("metadata") or {}
        if not isinstance(metadata, dict):
            metadata = {}
        extra_meta = parse_json_arg(args.metadata, "--metadata")
        if extra_meta:
            metadata.update(extra_meta)
        agent["metadata"] = metadata

        agent["last_seen_at"] = now_iso()
        agents[args.agent] = agent

        append_event(
            board,
            make_event(
                "agent_touch",
                args.agent,
                None,
                {
                    "role": agent.get("role"),
                    "kind": agent.get("kind"),
                    "skills": agent.get("skills"),
                },
            ),
        )
        collab_context = build_collab_context(board, agent_id=args.agent)
        save_board(path, board)

    _emit_json({"ok": True, "agent": agent, "collab_context": collab_context})


def cmd_agent_view(args: argparse.Namespace) -> None:
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    board = load_board(path)
    plan = build_agent_plan(
        board,
        agent_id=args.agent,
        limit=args.limit,
        include_blocked=args.include_blocked,
        include_done=args.include_done,
    )

    wip_ids = {t["id"] for t in plan["wip"] if isinstance(t, dict) and "id" in t}
    events = board.get("events", []) or []
    recent: List[Dict[str, Any]] = []
    for ev in events:
        if not isinstance(ev, dict):
            continue
        if ev.get("actor") == args.agent or (ev.get("task_id") in wip_ids):
            recent.append(ev)
    recent.sort(key=lambda e: (e.get("ts", ""), e.get("id", "")))
    if len(recent) > 50:
        recent = recent[-50:]

    collab_context = build_collab_context(board, agent_id=args.agent)

    def _augment(items: Any, *, action: str) -> Any:
        if not isinstance(items, list):
            return items
        out: List[Dict[str, Any]] = []
        for t in items:
            if not isinstance(t, dict):
                continue
            tt = dict(t)
            tt["next_steps"] = next_steps_for_task_action(
                action=action,
                task_id=str(tt.get("id") or ""),
                title=str(tt.get("title") or ""),
                column=str(tt.get("column") or ""),
                status=str(tt.get("status") or ""),
                links=list(tt.get("links") or []),
                agent=str(args.agent or ""),
            )
            out.append(tt)
        return out

    wip = _augment(plan["wip"], action="agent-view")
    ready = _augment(plan["ready"], action="agent-view")
    blocked = _augment(plan["blocked"], action="agent-view")
    done = _augment(plan["done"], action="agent-view")
    suggested = _augment(plan["suggested"], action="agent-view")

    view_next_steps: List[Dict[str, Any]] = []
    if isinstance(suggested, list) and suggested:
        s0 = suggested[0] if isinstance(suggested[0], dict) else {}
        tid = str(s0.get("id") or "").strip() or "<task_id>"
        view_next_steps.append(
            {
                "text": "Pick one suggested task, move it to doing, and start logging progress.",
                "commands": [
                    f"tasks move --id {tid} --to-column doing --agent {args.agent}",
                    f"tasks log --id {tid} --agent {args.agent} --log '{{\"kind\":\"note\",\"text\":\"starting\"}}'",
                ],
                "links": [f"task:{tid}"],
            }
        )
    if isinstance(wip, list) and wip:
        view_next_steps.append(
            {
                "text": "You already have WIP. Prefer finishing/closing WIP (or release leases) before starting more work.",
                "commands": [f"tasks plan --agent {args.agent}"],
                "links": [],
            }
        )

    _emit_json(
        {
            "ok": True,
            "agent": plan["agent"],
            "summary": plan["summary"],
            "wip": wip,
            "ready": ready,
            "blocked": blocked,
            "done": done,
            "suggested": suggested,
            "next_steps": view_next_steps,
            "recent_events": recent,
            "collab_context": collab_context,
        }
    )


