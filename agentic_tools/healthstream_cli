#!/usr/bin/env python3
"""Agent-facing HealthStream CLI wrapper.

This wrapper exists because `agentic_tools/healthstream/` is a directory (holds
module files). We expose a single executable entrypoint with JSON-only stdout,
matching other agentic tools.
"""

from __future__ import annotations

import sys
from pathlib import Path


def _find_repo_root(start: Path) -> Path:
    start = start.resolve()
    for cand in [start, *start.parents]:
        if (cand / "AGENTS.md").exists() and (cand / "agentic_tools" / "healthstream" / "cli.py").exists():
            return cand
    return start


def _ensure_repo_root_on_path(repo_root: Path) -> None:
    root_str = str(repo_root)
    if root_str not in sys.path:
        sys.path.insert(0, root_str)


def main() -> int:
    repo_root = _find_repo_root(Path.cwd())
    _ensure_repo_root_on_path(repo_root)
    from agentic_tools.healthstream.cli import main as _main

    return _main()


if __name__ == "__main__":
    raise SystemExit(main())

