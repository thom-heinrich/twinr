def now_iso() -> str:
    """Return current UTC timestamp in ISO8601 format with 'Z' suffix."""
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def parse_iso_utc(ts: str) -> Optional[float]:
    """Parse an ISO8601 '...Z' timestamp into a UNIX epoch seconds float."""
    try:
        parsed = time.strptime(ts, "%Y-%m-%dT%H:%M:%SZ")
        return float(calendar.timegm(parsed))
    except Exception:
        return None


def _linux_proc_start_ticks(pid: int) -> Optional[int]:
    """Best-effort process identity marker on Linux via /proc/<pid>/stat starttime ticks."""
    if not sys.platform.startswith("linux"):
        return None
    try:
        stat_path = Path(f"/proc/{pid}/stat")
        raw = stat_path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return None
    # /proc/<pid>/stat: field 2 is comm in parentheses and may contain spaces.
    # We find the last ')' to split safely.
    rparen = raw.rfind(")")
    if rparen < 0:
        return None
    after = raw[rparen + 2 :]  # skip ") "
    fields = after.split()
    # starttime is field 22 overall -> index 19 in "after" (field 3 is fields[0]).
    if len(fields) <= 19:
        return None
    try:
        return int(fields[19])
    except ValueError:
        return None


def _windows_process_info(pid: int) -> Tuple[Optional[bool], Optional[int]]:
    """Best-effort (alive?, create_time_filetime) on Windows.

    Returns:
      - alive: True/False if conclusive, None if unknown.
      - create_time_filetime: 64-bit int FILETIME if available.
    """
    if os.name != "nt":
        return None, None
    try:
        import ctypes
        from ctypes import wintypes
    except Exception:
        return None, None

    kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)

    PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
    STILL_ACTIVE = 259

    OpenProcess = kernel32.OpenProcess
    OpenProcess.argtypes = [wintypes.DWORD, wintypes.BOOL, wintypes.DWORD]
    OpenProcess.restype = wintypes.HANDLE

    GetExitCodeProcess = kernel32.GetExitCodeProcess
    GetExitCodeProcess.argtypes = [wintypes.HANDLE, ctypes.POINTER(wintypes.DWORD)]
    GetExitCodeProcess.restype = wintypes.BOOL

    GetProcessTimes = kernel32.GetProcessTimes
    GetProcessTimes.argtypes = [
        wintypes.HANDLE,
        ctypes.POINTER(wintypes.FILETIME),
        ctypes.POINTER(wintypes.FILETIME),
        ctypes.POINTER(wintypes.FILETIME),
        ctypes.POINTER(wintypes.FILETIME),
    ]
    GetProcessTimes.restype = wintypes.BOOL

    CloseHandle = kernel32.CloseHandle
    CloseHandle.argtypes = [wintypes.HANDLE]
    CloseHandle.restype = wintypes.BOOL

    handle = OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, False, int(pid))
    if not handle:
        err = ctypes.get_last_error()
        # ERROR_INVALID_PARAMETER (87) is typical for "pid does not exist".
        if err == 87:
            return False, None
        # Access denied or others: unknown.
        return None, None

    try:
        exit_code = wintypes.DWORD()
        if not GetExitCodeProcess(handle, ctypes.byref(exit_code)):
            return None, None
        if int(exit_code.value) != STILL_ACTIVE:
            return False, None

        create = wintypes.FILETIME()
        exit_ft = wintypes.FILETIME()
        kernel = wintypes.FILETIME()
        user = wintypes.FILETIME()
        if not GetProcessTimes(
            handle,
            ctypes.byref(create),
            ctypes.byref(exit_ft),
            ctypes.byref(kernel),
            ctypes.byref(user),
        ):
            return True, None

        create_val = (int(create.dwHighDateTime) << 32) | int(create.dwLowDateTime)
        return True, create_val
    finally:
        CloseHandle(handle)


def _current_process_identity() -> Tuple[Optional[str], Optional[int]]:
    """Return (kind, value) process identity marker for the current process."""
    pid = os.getpid()
    if os.name == "nt":
        alive, create_ft = _windows_process_info(pid)
        if create_ft is not None:
            return "win_filetime", create_ft
        return None, None
    if sys.platform.startswith("linux"):
        ticks = _linux_proc_start_ticks(pid)
        if ticks is not None:
            return "linux_start_ticks", ticks
    return None, None


def _pid_alive_with_identity(
    pid: Optional[int],
    expected_kind: Optional[str],
    expected_value: Optional[int],
) -> Tuple[Optional[bool], Optional[bool]]:
    """Return (alive?, identity_matches?).

    alive:
      - True/False: conclusive
      - None: unknown

    identity_matches:
      - True/False: conclusive comparison, only meaningful if alive is True
      - None: unknown/not applicable
    """
    if pid is None:
        return None, None
    try:
        pid_int = int(pid)
    except (TypeError, ValueError):
        return None, None
    if pid_int <= 0:
        return None, None

    if os.name == "nt":
        alive, create_ft = _windows_process_info(pid_int)
        if alive is not True:
            return alive, None
        if (
            expected_kind == "win_filetime"
            and expected_value is not None
            and create_ft is not None
        ):
            return True, (int(create_ft) == int(expected_value))
        return True, None

    # POSIX
    try:
        os.kill(pid_int, 0)
    except ProcessLookupError:
        return False, None
    except PermissionError:
        return True, None
    except OSError:
        return None, None

    # Alive; best-effort identity check (Linux only).
    if expected_kind == "linux_start_ticks" and expected_value is not None:
        actual = _linux_proc_start_ticks(pid_int)
        if actual is None:
            return True, None
        return True, (int(actual) == int(expected_value))
    return True, None


class FileLockTimeout(Exception):
    """Raised when the file-level lock cannot be acquired within the timeout."""


class _LinkLockUnsupported(Exception):
    """Internal: hard-link based lock acquisition is unsupported on this platform/fs."""


@dataclass
class FileLock:
    """Simple cross-process file lock using atomic create/unlink of a lock file.

    Implementation notes (internal):
    - On POSIX, prefers a hard-link based lock pattern to be safer on some NFS setups.
      Falls back to O_CREAT|O_EXCL when hard links are unsupported.
    - Adds an ownership token; release only removes the lock if the token matches,
      preventing accidental unlock of another process' lock.
    - Stale reaping is conservative: it only reaps when the recorded owner is
      conclusively dead or the PID has been reused (identity mismatch).
    """

    path: Path
    timeout: float = 10.0
    poll_interval: float = 0.05
    _token: Optional[str] = field(default=None, init=False, repr=False)
    _acquired: bool = field(default=False, init=False, repr=False)

    def __post_init__(self) -> None:
        raw_timeout = os.environ.get("CAIA_SCRIPTHISTORY_LOCK_TIMEOUT_SEC") or os.environ.get("SCRIPTHISTORY_LOCK_TIMEOUT")
        if raw_timeout and str(raw_timeout).strip():
            try:
                self.timeout = max(0.01, float(str(raw_timeout).strip()))
            except Exception:
                pass
        raw_poll = os.environ.get("CAIA_SCRIPTHISTORY_LOCK_POLL_SEC")
        if raw_poll and str(raw_poll).strip():
            try:
                self.poll_interval = max(0.01, float(str(raw_poll).strip()))
            except Exception:
                pass

    def _lock_payload(self) -> Dict[str, Any]:
        kind, ident = _current_process_identity()
        payload: Dict[str, Any] = {
            "created_at": now_iso(),
            "pid": os.getpid(),
            "rand": random.random(),
            "token": self._token,
        }
        if kind and ident is not None:
            payload["proc_identity_kind"] = kind
            payload["proc_identity"] = ident
        return payload

    def _write_json_fd(self, fd: int, payload: Dict[str, Any]) -> None:
        data = json.dumps(payload, ensure_ascii=False, sort_keys=True)
        os.write(fd, data.encode("utf-8"))

    def _try_acquire_link_lock(self, payload: Dict[str, Any]) -> None:
        """Attempt to acquire lock via hard-link pattern (POSIX)."""
        if os.name == "nt":
            raise _LinkLockUnsupported("hard-link locking not used on Windows")

        # Create a unique temp file in the same directory and link it to the lock path.
        # This pattern is commonly recommended when O_EXCL on the lock path may be unreliable on NFS.
        pid = os.getpid()
        token = payload.get("token") or "notoken"
        tmp_name = f".{self.path.name}.{pid}.{token}.tmp"
        tmp_path = self.path.with_name(tmp_name)

        fd: Optional[int] = None
        try:
            fd = os.open(tmp_path, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
            try:
                self._write_json_fd(fd, payload)
            finally:
                os.close(fd)
                fd = None

            try:
                os.link(tmp_path, self.path)
            except FileExistsError:
                raise
            except OSError as exc:
                # Hard links may be unsupported on the filesystem.
                if exc.errno in (
                    errno.EPERM,
                    errno.EACCES,
                    errno.ENOTSUP,
                    getattr(errno, "EOPNOTSUPP", errno.ENOTSUP),
                    errno.EXDEV,
                ):
                    raise _LinkLockUnsupported(str(exc))
                raise
        finally:
            # Best-effort cleanup of the temp file.
            try:
                tmp_path.unlink()
            except FileNotFoundError:
                pass
            except Exception:
                # Don't fail lock acquisition solely due to temp cleanup.
                logging.debug("Failed to clean lock temp file %s", tmp_path, exc_info=True)

    def _try_acquire_excl_lock(self, payload: Dict[str, Any]) -> None:
        """Attempt to acquire lock via O_CREAT|O_EXCL."""
        fd = os.open(self.path, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
        try:
            self._write_json_fd(fd, payload)
        finally:
            os.close(fd)

    def _read_lock_data(self) -> Tuple[Optional[Dict[str, Any]], Optional[float]]:
        """Return (data_dict_or_none, mtime_epoch_or_none) for the lock file."""
        try:
            st = self.path.stat()
            mtime = float(st.st_mtime)
        except FileNotFoundError:
            return None, None
        except Exception:
            mtime = None

        try:
            with self.path.open("r", encoding="utf-8") as handle:
                data = json.load(handle)
            if not isinstance(data, dict):
                return None, mtime
            return data, mtime
        except FileNotFoundError:
            return None, None
        except Exception:
            return None, mtime

    def _reap_stale_lock(self) -> bool:
        """Attempt to remove a stale lock file; return True if removed."""
        data, mtime = self._read_lock_data()
        if data is None:
            # If unreadable, only reap if it's clearly old (mtime-based).
            if mtime is None:
                return False
            age = time.time() - mtime
            if age > SCRIPTHISTORY_LOCK_STALE_SECONDS:
                logging.warning(
                    "Lock file %s unreadable and older than stale threshold (age=%.2fs); removing defensively.",
                    self.path,
                    age,
                )
                try:
                    self.path.unlink()
                except FileNotFoundError:
                    return False
                except Exception:
                    return False
                return True
            return False

        created_at = data.get("created_at")
        created_epoch = parse_iso_utc(created_at) if isinstance(created_at, str) else None
        if created_epoch is not None:
            age = time.time() - created_epoch
        elif mtime is not None:
            age = time.time() - mtime
        else:
            age = None

        pid_raw = data.get("pid")
        pid_int: Optional[int] = None
        pid_valid = True
        try:
            pid_int = int(pid_raw)
            if pid_int <= 0:
                pid_valid = False
                pid_int = None
        except (TypeError, ValueError):
            pid_valid = False
            pid_int = None

        expected_kind = (
            data.get("proc_identity_kind")
            if isinstance(data.get("proc_identity_kind"), str)
            else None
        )
        expected_value = data.get("proc_identity") if isinstance(data.get("proc_identity"), int) else None

        alive, identity_match = _pid_alive_with_identity(
            pid_int if pid_valid else None, expected_kind, expected_value
        )

        # Conservative stale logic:
        # - If owner is conclusively dead: reap.
        # - If PID is alive but identity mismatches (PID reused): reap.
        # - If PID is missing/invalid AND lock is old: reap.
        if alive is False:
            logging.warning(
                "Removing stale lock %s (pid=%s not alive, age=%.2fs).",
                self.path,
                pid_raw,
                age if age is not None else -1.0,
            )
            try:
                self.path.unlink()
            except FileNotFoundError:
                return False
            return True

        if alive is True and identity_match is False:
            logging.warning(
                "Removing stale lock %s (pid=%s reused; identity mismatch, age=%.2fs).",
                self.path,
                pid_raw,
                age if age is not None else -1.0,
            )
            try:
                self.path.unlink()
            except FileNotFoundError:
                return False
            return True

        if (not pid_valid) and age is not None and age > SCRIPTHISTORY_LOCK_STALE_SECONDS:
            logging.warning(
                "Removing stale lock %s (pid missing/invalid; age=%.2fs).",
                self.path,
                age,
            )
            try:
                self.path.unlink()
            except FileNotFoundError:
                return False
            return True

        return False

    def acquire(self) -> None:
        """Acquire the lock by atomically creating a lock file."""
        # Ensure lock directory exists (handles custom --file paths in nested dirs).
        self.path.parent.mkdir(parents=True, exist_ok=True)
        deadline = time.time() + self.timeout
        self._token = uuid.uuid4().hex
        while True:
            payload = self._lock_payload()
            try:
                # POSIX: try hard-link based lock first for better behavior on some NFS setups.
                if os.name != "nt":
                    try:
                        self._try_acquire_link_lock(payload)
                    except _LinkLockUnsupported:
                        self._try_acquire_excl_lock(payload)
                else:
                    self._try_acquire_excl_lock(payload)

                self._acquired = True
                return
            except FileExistsError:
                if self._reap_stale_lock():
                    continue
                if time.time() > deadline:
                    raise FileLockTimeout(f"Timed out acquiring lock {self.path}")
                jitter = random.random() * self.poll_interval
                time.sleep(self.poll_interval + jitter)

    def release(self) -> None:
        """Release the lock by removing the lock file (only if ownership token matches)."""
        if not self._acquired:
            return
        token = self._token
        if not token:
            return

        # Only unlink if the current lock file still belongs to us.
        try:
            with self.path.open("r", encoding="utf-8") as handle:
                data = json.load(handle)
        except FileNotFoundError:
            return
        except Exception:
            logging.warning("Lock file %s unreadable during release; leaving in place.", self.path)
            return

        if not isinstance(data, dict):
            logging.warning("Lock file %s malformed during release; leaving in place.", self.path)
            return

        if data.get("token") != token:
            logging.warning(
                "Not releasing lock %s due to ownership token mismatch (expected=%s got=%s).",
                self.path,
                token,
                data.get("token"),
            )
            return

        try:
            self.path.unlink()
        except FileNotFoundError:
            return

    def __enter__(self) -> "FileLock":
        self.acquire()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb) -> None:
        self.release()


def configure_logging() -> None:
    """Configure verbose logging to stderr for observability."""
    kwargs = dict(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] scripthistory %(message)s",
        stream=sys.stderr,
    )
    # basicConfig(force=True) is available on modern Python; feature-detect for safety.
    if "force" in inspect.signature(logging.basicConfig).parameters:
        kwargs["force"] = True
    logging.basicConfig(**kwargs)


def emit_error(
    error: str,
    detail: str,
    *,
    file: Optional[Path] = None,
    error_code: str = "",
    retryable: Optional[bool] = None,
    extra: Optional[Dict[str, Any]] = None,
    exit_code: int = 1,
) -> None:
    """Print a JSON error payload and exit."""
    normalized_error = str(error or "")
    normalized_error_code = (
        str(error_code or "").strip()
        or ERROR_CODE_TOKEN_RE.sub("_", normalized_error).strip("_").upper()
        or "UNKNOWN_ERROR"
    )
    if retryable is None:
        code = normalized_error_code.upper()
        retryable = code in {"LOCK_TIMEOUT", "TIMEOUT", "IO_ERROR"} or "TIMEOUT" in code or "LOCK" in code

    payload: Dict[str, Any] = {
        "ok": False,
        "error": normalized_error,
        "error_code": normalized_error_code,
        "detail": str(detail or ""),
        "retryable": bool(retryable),
    }
    if file is not None:
        payload["file"] = str(file)
    if extra:
        payload.update(extra)
    print(json.dumps(attach_governance_hint(payload)))
    sys.exit(exit_code)


_MUTATING_SCRIPTHISTORY_HANDLERS = frozenset(
    {"cmd_init", "cmd_init_script", "cmd_add_change", "cmd_add_knowledge"}
)


def _classify_scripthistory_exception(exc: BaseException) -> Tuple[str, Optional[bool]]:
    if isinstance(exc, FileLockTimeout):
        return ("LOCK_TIMEOUT", True)
    if isinstance(exc, PermissionError):
        return ("PERMISSION_DENIED", False)
    if isinstance(exc, FileNotFoundError):
        return ("NOT_FOUND", False)
    if isinstance(exc, TimeoutError):
        return ("TIMEOUT", True)
    if isinstance(exc, ValueError):
        return ("VALIDATION_ERROR", False)
    if isinstance(exc, OSError):
        return ("IO_ERROR", True)
    return ("UNHANDLED_EXCEPTION", None)


def _scripthistory_cli_retry_budget_sec() -> float:
    return _resolve_governance_retry_budget(
        retry_timeout_env="CAIA_SCRIPTHISTORY_CLI_RETRY_TIMEOUT_SEC",
        lock_timeout_envs=("CAIA_SCRIPTHISTORY_LOCK_TIMEOUT_SEC", "SCRIPTHISTORY_LOCK_TIMEOUT"),
        default_lock_timeout=10.0,
    )


def _scripthistory_cli_retry_poll_sec() -> float:
    return _resolve_governance_retry_poll(
        retry_poll_env="CAIA_SCRIPTHISTORY_CLI_RETRY_POLL_SEC",
        default_poll_sec=0.25,
    )


def _emit_scripthistory_retry(action: str, error_code: str, attempt: int, sleep_s: float, exc: BaseException) -> None:
    logging.warning(
        "Retrying scripthistory mutation after %s action=%s attempt=%s sleep_s=%.3f error=%s",
        error_code,
        action,
        attempt,
        sleep_s,
        exc,
    )


def _run_scripthistory_mutation_with_retry(action: str, op: Any) -> None:
    _run_governance_mutation_with_retry(
        action=action,
        op=op,
        classify_exception=_classify_scripthistory_exception,
        retry_budget_sec=_scripthistory_cli_retry_budget_sec(),
        retry_poll_sec=_scripthistory_cli_retry_poll_sec(),
        emit_retry=lambda error_code, attempt, sleep_s, exc: _emit_scripthistory_retry(
            action,
            error_code,
            attempt,
            sleep_s,
            exc,
        ),
    )


class JsonArgumentParser(argparse.ArgumentParser):
