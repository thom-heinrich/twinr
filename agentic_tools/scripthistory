def default_store() -> Dict[str, Any]:
    """Return a fresh, empty script history store structure."""
    now = now_iso()
    return {
        "version": 1,
        "created_at": now,
        "updated_at": now,
        "revision": 0,
        "next_event_id": 1,
        "scripts": {},  # path -> script
    }


def ensure_store_shape(store: Dict[str, Any]) -> Dict[str, Any]:
    """Ensure mandatory top-level keys exist on the store."""
    if "version" not in store:
        store["version"] = 1
    if "created_at" not in store:
        store["created_at"] = now_iso()
    if "updated_at" not in store:
        store["updated_at"] = now_iso()
    if "revision" not in store:
        store["revision"] = 0
    if "next_event_id" not in store:
        store["next_event_id"] = 1
    if "scripts" not in store or not isinstance(store["scripts"], dict):
        store["scripts"] = {}
    return store


def validate_store(store: Dict[str, Any], path: Path, *, full: bool = True) -> None:
    """Validate the structural integrity of the store.

    When full=False, performs a shallow validation intended for very large stores.
    Default remains full validation for backward-compatible strictness.
    """
    scripts = store.get("scripts", {})
    if not isinstance(scripts, dict):
        emit_error(
            error="invalid_store",
            detail="'scripts' must be an object mapping paths to script entries.",
            file=path,
        )
    for script_path, script in scripts.items():
        if not isinstance(script, dict):
            emit_error(
                error="invalid_store",
                detail="Script entry must be a JSON object.",
                file=path,
                extra={"path": script_path},
            )
        events = script.get("events", [])
        if not isinstance(events, list):
            emit_error(
                error="invalid_store",
                detail="Script 'events' must be a list.",
                file=path,
                extra={"path": script_path},
            )
        if not full:
            continue
        for idx, event in enumerate(events):
            if not isinstance(event, dict):
                emit_error(
                    error="invalid_store",
                    detail="Each event must be a JSON object.",
                    file=path,
                    extra={"path": script_path, "event_index": idx},
                )
            for field in ("id", "type", "comment", "created_at"):
                if field not in event:
                    emit_error(
                        error="invalid_store",
                        detail=f"Event missing required field '{field}'.",
                        file=path,
                        extra={"path": script_path, "event_index": idx},
                    )
            if event.get("type") not in {"init-script", "change", "knowledge"}:
                emit_error(
                    error="invalid_store",
                    detail=f"Unexpected event type '{event.get('type')}'.",
                    file=path,
                    extra={"path": script_path, "event_index": idx},
                )


def load_store(path: Path) -> Dict[str, Any]:
    """Load the script history store from disk, or create a new one."""
    if not path.exists():
        logging.info(
            "Script history store %s does not exist, using in-memory default until first write.",
            path,
        )
        return default_store()
    try:
        with path.open("r", encoding="utf-8") as handle:
            store = json.load(handle)
    except json.JSONDecodeError as exc:
        emit_error(
            error="invalid_json",
            detail=f"Failed to parse script history JSON: {exc}",
            file=path,
        )
    except OSError as exc:
        emit_error(
            error="io_error",
            detail=f"Failed to read script history store: {exc}",
            file=path,
        )
    if not isinstance(store, dict):
        emit_error(
            error="invalid_store",
            detail="Script history store root must be a JSON object.",
            file=path,
        )
    store = ensure_store_shape(store)
    validate_store(store, path, full=SCRIPTHISTORY_VALIDATE_FULL)
    return store


def _fsync_dir(path: Path) -> None:
    """Best-effort fsync of a directory entry on POSIX to improve durability."""
    if os.name == "nt":
        return
    try:
        fd = os.open(str(path), os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
    except Exception:
        return
    try:
        os.fsync(fd)
    except Exception:
        return
    finally:
        try:
            os.close(fd)
        except Exception:
            pass


def save_store(path: Path, store: Dict[str, Any]) -> None:
    """Persist the script history store atomically to disk."""
    store["updated_at"] = now_iso()
    store["revision"] = int(store.get("revision", 0)) + 1
    tmp_path = path.with_suffix(path.suffix + ".tmp")

    existing_mode: Optional[int] = None
    try:
        st = path.stat()
        existing_mode = stat.S_IMODE(st.st_mode)
    except FileNotFoundError:
        existing_mode = None
    except Exception:
        existing_mode = None

    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp_path.parent.mkdir(parents=True, exist_ok=True)
        with tmp_path.open("w", encoding="utf-8") as handle:
            json.dump(
                store,
                handle,
                ensure_ascii=False,
                indent=SCRIPTHISTORY_JSON_INDENT,
                sort_keys=True,
            )
            handle.write("\n")
            handle.flush()
            try:
                os.fsync(handle.fileno())
            except Exception:
                # Best-effort: do not fail persistence if fsync is unsupported.
                pass

        if existing_mode is not None:
            try:
                os.chmod(tmp_path, existing_mode)
            except Exception:
                pass

        tmp_path.replace(path)
        _fsync_dir(path.parent)
    except OSError as exc:
        emit_error(
            error="io_error",
            detail=f"Failed to persist script history store: {exc}",
            file=path,
        )
    logging.info(
        "Persisted script history store to %s (revision=%s).",
        path,
        store["revision"],
    )


def parse_json_arg(raw: Optional[str], arg_name: str) -> Dict[str, Any]:
    """Parse a JSON argument that must be an object, or return {} if None."""
    if raw is None:
        return {}
    try:
        value = json.loads(raw)
    except json.JSONDecodeError as exc:
        emit_error(
            error="invalid_json_arg",
            detail=f"Failed to parse JSON for {arg_name}: {exc}",
        )
    if not isinstance(value, dict):
        emit_error(
            error="invalid_json_arg",
            detail=f"Expected JSON object for {arg_name}.",
        )
    return value


def normalize_links(raw: Optional[List[str]]) -> List[str]:
    """Normalize a list of `links` tokens.

    Backward compatible default:
    - Preserve values as provided (stringified), without validation or deduplication.
    Optional strict mode:
    - If SCRIPTHISTORY_VALIDATE_LINKS=1, enforce kind:id (no whitespace), strip,
      drop empties, and dedupe.
    """
    if not raw:
        return []
    tokens = [str(item) for item in raw]
    if not SCRIPTHISTORY_VALIDATE_LINKS:
        return tokens

    out: List[str] = []
    seen = set()
    for item in tokens:
        s = str(item or "").strip()
        if not s:
            continue
        if not LINK_TOKEN_RE.match(s):
            emit_error(
                error="invalid_link_token",
                detail=f"Invalid link token (expected kind:id, no whitespace): {s!r}",
                extra={"token": s},
            )
        if s in seen:
            continue
        seen.add(s)
        out.append(s)
    return out


WINDOWS_DRIVE_ABS_RE = re.compile(r"^[A-Za-z]:/")


def canonicalize_script_path(path_str: str) -> str:
    """Normalize script path to avoid duplicate aliases.

    Backward compatible behavior:
    - Keeps absolute paths representable; if an absolute path resolves under REPO_ROOT,
      it is canonicalized to a repo-relative path.
    - Normalizes '.', '..' segments to reduce aliasing (e.g. 'a/../b' -> 'b').
    - Normalizes backslashes to forward slashes.
    """
    raw = str(path_str or "").strip()
    if not raw:
        return "."

    s = raw.replace("\\", "/")

    # If path is absolute in this OS sense and is under repo root, store repo-relative.
    try:
        p = Path(s)
        if p.is_absolute():
            try:
                rel = p.resolve().relative_to(REPO_ROOT)
                s = rel.as_posix()
            except Exception:
                s = p.as_posix()
    except Exception:
        pass

    # Strip common prefix noise.
    if s.startswith("./"):
        s = s[2:]

    abs_prefix = ""
    drive_prefix = ""
    rest = s

    m_drive = WINDOWS_DRIVE_ABS_RE.match(rest)
    if m_drive:
        drive_prefix = rest[:2]  # "C:"
        rest = rest[3:]  # after "C:/"
    elif rest.startswith("/"):
        abs_prefix = "/"
        rest = rest[1:]

    parts_in = rest.split("/")
    parts_out: List[str] = []
    for part in parts_in:
        if part in ("", "."):
            continue
        if part == "..":
            if parts_out and parts_out[-1] != "..":
                parts_out.pop()
            else:
                # For absolute paths, ignore attempts to go above root.
                if not (abs_prefix or drive_prefix):
                    parts_out.append("..")
            continue
        parts_out.append(part)

    if drive_prefix:
        if not parts_out:
            # Backward compatible for "C:/"-like inputs: keep as "C:".
            return drive_prefix
        normalized = drive_prefix + "/" + "/".join(parts_out)
        normalized = normalized.rstrip("/")
        return normalized

    normalized = "/".join(parts_out).rstrip("/")

    if abs_prefix:
        # Backward compatible: avoid creating a bare "/" key; map to "." like earlier behavior.
        return (abs_prefix + normalized) if normalized else "."
    return normalized or "."


def generate_event_id(store: Dict[str, Any]) -> str:
    """Generate a new human-friendly event ID of the form 'E00001'."""
    next_id = int(store.get("next_event_id", 1))
    scripts = store.get("scripts", {})

    # Fast path: assume next_event_id is correct; only scan on collision.
    candidate = f"E{next_id:05d}"
    exists = any(
        any(event.get("id") == candidate for event in script.get("events", []))
        for script in scripts.values()
    )
    if not exists:
        store["next_event_id"] = next_id + 1
        return candidate

    # Slow path: advance until a free id is found.
    while True:
        next_id += 1
        candidate = f"E{next_id:05d}"
        exists = any(
            any(event.get("id") == candidate for event in script.get("events", []))
            for script in scripts.values()
        )
        if not exists:
            store["next_event_id"] = next_id + 1
            return candidate


def script_to_public(script: Dict[str, Any]) -> Dict[str, Any]:
    """Return a stable public representation of a script entry."""
    return dict(script)


def event_to_public(event: Dict[str, Any]) -> Dict[str, Any]:
    """Return a stable public representation of an event."""
    return dict(event)


def recent_events_for_script(
    script: Dict[str, Any],
    limit: int = 10,
) -> List[Dict[str, Any]]:
    """Return the most recent events for a script, up to ``limit``.

    The events are returned in chronological order (oldest → newest) within
    the selected tail window so that agents can read the recent history in a
    natural timeline while still focusing on the latest entries.
    """
    if limit <= 0:
        return []
    events = script.get("events", []) or []
    if not events:
        return []
    tail = events[-limit:]
    return [event_to_public(e) for e in tail]


def _as_string_list(value: Any) -> List[str]:
    if isinstance(value, list):
        out: List[str] = []
        for item in value:
            if item is None:
                continue
            text = str(item).strip()
            if text:
                out.append(text)
        return out
    if isinstance(value, str):
        text = value.strip()
        return [text] if text else []
    return []


def _pick_first_nonempty(*values: Any) -> str:
    for value in values:
        if value is None:
            continue
        text = str(value).strip()
        if text:
            return text
    return ""


def _dedupe_keep_order(values: List[str]) -> List[str]:
    out: List[str] = []
    seen: set[str] = set()
    for value in values:
        text = str(value).strip()
        if not text or text in seen:
            continue
        seen.add(text)
        out.append(text)
    return out


def _normalize_script_explain(path_str: str, script: Dict[str, Any]) -> Dict[str, Any]:
    events = list(script.get("events", []) or [])
    changes = [e for e in events if str(e.get("type") or "") == "change"]
    knowledge = [e for e in events if str(e.get("type") or "") == "knowledge"]
    init_events = [e for e in events if str(e.get("type") or "") == "init-script"]
    latest_events = events[-6:] if len(events) > 6 else events

    what = _pick_first_nonempty(
        script.get("description"),
        (init_events[0].get("comment") if init_events else ""),
        path_str,
    )
    why = _pick_first_nonempty(
        (knowledge[-1].get("comment") if knowledge else ""),
        (changes[-1].get("comment") if changes else ""),
        "Maintain append-only provenance for this script.",
    )

    how_values: List[str] = []
    for event in latest_events:
        event_type = str(event.get("type") or "").strip()
        comment = str(event.get("comment") or "").strip()
        if not comment:
            continue
        how_values.append(f"{event_type}: {comment}")
    if not how_values:
        how_values.append("Record init/change/knowledge events with explicit comments.")

    guardrails = [
        "Keep exactly one `init-script` event per script path.",
        "Do not lose chronology; preserve append-only event order.",
        "Use `scripthistory lint` to detect duplicate/open investigation patterns.",
    ]

    links: List[str] = []
    for event in events:
        links.extend(_as_string_list(event.get("links")))
    links = dedupe_link_tokens(links)

    conflicts = [
        issue.get("code")
        for issue in _lint_script(path_str, script)
        if isinstance(issue, dict) and str(issue.get("code") or "").strip()
    ]

    evidence: List[str] = []
    evidence.extend(links)
    evidence.extend(
        [
            f"event:{str(e.get('id') or '').strip()}"
            for e in latest_events
            if str(e.get("id") or "").strip()
        ]
    )

    return {
        "what": what,
        "why": why,
        "how": _dedupe_keep_order(how_values),
        "guardrails": guardrails,
        "evidence": _dedupe_keep_order(evidence),
        "conflicts": _dedupe_keep_order([str(x) for x in conflicts if str(x).strip()]),
        "links": links,
    }


def cmd_init(args: argparse.Namespace) -> None:
    """Initialize a new script history store file."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    if path.exists() and not args.force:
        emit_error(
            error="store_exists",
            detail=(
                f"Script history store already exists at {path}. "
                "Use --force to overwrite."
            ),
            file=path,
            exit_code=1,
        )

    store = default_store()
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps(store, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
            encoding="utf-8",
        )
    except OSError as exc:
        emit_error(
            error="io_error",
            detail=f"Failed to initialize script history store: {exc}",
            file=path,
        )
    logging.info("Initialized new script history store at %s.", path)
    print(
        json.dumps(
            attach_governance_hint(
                {
                    "ok": True,
                    "action": "init",
                    "file": str(path),
                    "version": store["version"],
                }
            )
        )
    )


