def _load_json_doc(path: Path, *, label: str) -> Dict[str, Any]:
    try:
        text = path.read_text(encoding="utf-8")
    except FileNotFoundError as exc:
        raise FileNotFoundError(f"missing {label}: {path}") from exc
    try:
        doc = json.loads(text)
    except json.JSONDecodeError as exc:
        raise ValueError(f"invalid json for {label}: {path}: {exc}") from exc
    if not isinstance(doc, dict):
        raise ValueError(f"invalid {label}: expected json object at {path}")
    return doc


def cmd_code_revisions(args: argparse.Namespace) -> None:
    """
    Read the script-indexer artifacts for a repo-relative script path.

    This is separate from the scripthistory store itself; it provides a quick
    inspection view over `common/indexer/scripts/<path>/...`.
    """
    rr_raw = str(getattr(args, "repo_root", "") or "").strip()
    if rr_raw:
        rr = Path(rr_raw).expanduser()
        rr = rr.resolve() if rr.is_absolute() else (Path.cwd() / rr).resolve()
    else:
        rr = REPO_ROOT.resolve()

    script_path = str(getattr(args, "path", "") or "").strip()
    if not script_path:
        emit_error(error="invalid_path", detail="--path is required", extra={"path": script_path})

    p_rel = Path(script_path.lstrip("/"))
    if p_rel.is_absolute() or ".." in p_rel.parts:
        emit_error(error="invalid_path", detail="--path must be repo-relative and must not contain '..'", extra={"path": script_path})

    # Compatibility: during the 2026-01 LLM path migration, historical code-index
    # artifacts may exist under either `llm/...` or `artifacts/llm/...` depending
    # on which revision created the index entry.
    #
    # We treat both as aliases for the purpose of reading the code-index store.
    candidates: List[Path] = [p_rel]
    if p_rel.parts and p_rel.parts[0] == "llm":
        candidates.append(Path("artifacts") / p_rel)
    if len(p_rel.parts) >= 2 and p_rel.parts[0] == "artifacts" and p_rel.parts[1] == "llm":
        candidates.append(Path(*p_rel.parts[1:]))

    seen: set[str] = set()
    uniq: List[Path] = []
    for cand in candidates:
        s = str(cand).replace("\\", "/")
        if s in seen:
            continue
        seen.add(s)
        uniq.append(Path(s))
    candidates = uniq

    base: Optional[Path] = None
    current_path: Optional[Path] = None
    current: Optional[Dict[str, Any]] = None
    path_indexed = ""
    rev = ""

    found_current_json: List[str] = []
    for cand in candidates:
        base2 = (rr / "common" / "indexer" / "scripts" / cand).resolve()
        cur2 = (base2 / "current.json").resolve()
        if not cur2.is_file():
            continue
        found_current_json.append(str(cur2))
        doc2 = _load_json_doc(cur2, label="current.json")
        rev2 = str((doc2.get("revision_sha256") or "").strip())
        if not rev2:
            continue
        base = base2
        current_path = cur2
        current = doc2
        path_indexed = str(cand).replace("\\", "/")
        rev = rev2
        break

    if base is None or current_path is None or current is None:
        if found_current_json:
            emit_error(
                error="missing_revision",
                detail="current.json missing revision_sha256 for all candidate paths",
                extra={"path": script_path, "current_json": found_current_json[:20]},
            )
        emit_error(
            error="missing_index_artifacts",
            detail=(
                "Missing code-index artifacts for path. "
                "Expected: common/indexer/scripts/<path>/current.json."
            ),
            extra={"path": script_path, "candidates": [str(c) for c in candidates]},
        )

    selected_revision: Dict[str, Any] = dict(current)

    events: List[Dict[str, Any]] = []
    events_dir = (base / "events").resolve()
    if events_dir.exists() and events_dir.is_dir():
        files = sorted([p for p in events_dir.iterdir() if p.is_file() and p.name.endswith(".json")], key=lambda x: x.name)
        limit_events = int(getattr(args, "limit_events", 0) or 0)
        for p in files:
            if limit_events and len(events) >= limit_events:
                break
            try:
                events.append(_load_json_doc(p, label="event"))
            except Exception as exc:
                logging.warning("Skipping invalid event json %s: %s", p, exc)

    chunks: List[Dict[str, Any]] = []
    if bool(getattr(args, "include_chunks", False)):
        chunks_dir = (base / "revisions" / rev / "chunks").resolve()
        if chunks_dir.exists() and chunks_dir.is_dir():
            files = sorted([p for p in chunks_dir.iterdir() if p.is_file() and p.name.endswith(".json")], key=lambda x: x.name)
            limit_chunks = int(getattr(args, "limit_chunks", 0) or 0)
            omit_text = bool(getattr(args, "omit_text", False))
            for p in files:
                if limit_chunks and len(chunks) >= limit_chunks:
                    break
                try:
                    doc = _load_json_doc(p, label="chunk")
                except Exception as exc:
                    logging.warning("Skipping invalid chunk json %s: %s", p, exc)
                    continue
                if omit_text:
                    doc.pop("text", None)
                chunks.append(doc)

    print(
        json.dumps(
            attach_governance_hint(
                {
                    "ok": True,
                    "action": "code_revisions",
                    "repo_root": str(rr),
                    "path": script_path,
                    "path_indexed": path_indexed,
                    "path_candidates": [str(c) for c in candidates],
                    "index_dir": str(base),
                    "current": current,
                    "selected_revision": selected_revision,
                    "events": events,
                    "chunks": chunks,
                }
            )
        )
    )


def _lint_script(path_str: str, script: Dict[str, Any]) -> List[Dict[str, Any]]:
    """Return a list of structural issues for a single script."""
    issues: List[Dict[str, Any]] = []
    events = script.get("events", []) or []

    # 1) Multiple init-script events.
    init_events = [e for e in events if e.get("type") == "init-script"]
    if len(init_events) == 0:
        issues.append(
            {
                "path": path_str,
                "severity": "warning",
                "code": "missing_init_script",
                "message": "Script has no 'init-script' event; consider adding one to document its purpose.",
                "event_ids": [],
            }
        )
    elif len(init_events) > 1:
        issues.append(
            {
                "path": path_str,
                "severity": "error",
                "code": "multiple_init_script",
                "message": "Script has multiple 'init-script' events; only one is expected per logical script.",
                "event_ids": [e.get("id") for e in init_events if e.get("id")],
            }
        )

    # 2) Duplicate events (type+comment+agent+metadata).
    key_to_events: Dict[str, List[Dict[str, Any]]] = {}
    for e in events:
        key_obj = {
            "type": e.get("type"),
            "comment": e.get("comment"),
            "agent": e.get("agent"),
            "metadata": e.get("metadata") or {},
            "links": e.get("links") or [],
        }
        key = json.dumps(key_obj, sort_keys=True, ensure_ascii=False)
        key_to_events.setdefault(key, []).append(e)

    for group in key_to_events.values():
        if len(group) > 1:
            group_sorted = sorted(group, key=lambda ev: ev.get("created_at") or "")
            issues.append(
                {
                    "path": path_str,
                    "severity": "warning",
                    "code": "duplicate_events",
                    "message": (
                        "Multiple events share identical type/comment/agent/metadata; "
                        "ensure duplicates are intentional or rely on dedupe when writing."
                    ),
                    "event_ids": [ev.get("id") for ev in group_sorted if ev.get("id")],
                }
            )

    # 3) Open investigations: events that look like investigations without a visible closure.
    investigating_events: List[Dict[str, Any]] = []
    for e in events:
        comment = (e.get("comment") or "").lower()
        if any(token in comment for token in ("investigat", "inspect", "audit")):
            investigating_events.append(e)

    if investigating_events:
        last_investigation = investigating_events[-1]
        try:
            idx_last = events.index(last_investigation)
        except ValueError:
            idx_last = len(events) - 1
        later_events = events[idx_last + 1 :]
        resolved = False
        for e2 in later_events:
            c2 = (e2.get("comment") or "").lower()
            if any(
                token in c2
                for token in ("resolved", "fixed", "retired", "closed", "decommission")
            ):
                resolved = True
                break
        if not resolved:
            issues.append(
                {
                    "path": path_str,
                    "severity": "info",
                    "code": "open_investigation",
                    "message": (
                        "Latest investigation/audit-style event has no obvious "
                        "closing event (resolved/fixed/retired/closed)."
                    ),
                    "event_ids": [last_investigation.get("id")],
                }
            )

    return issues


def cmd_lint(args: argparse.Namespace) -> None:
    """Analyze one script or the whole store for structural issues."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    store = load_store(path)
    scripts = store.get("scripts", {}) or {}

    issues: List[Dict[str, Any]] = []
    lint_path: Optional[str] = None
    if args.path:
        canonical = canonicalize_script_path(args.path)
        located = _locate_script_entry(store, canonical)
        script = located[1] if located else None
        if not script:
            emit_error(
                error="unknown_script",
                detail=f"Script '{args.path}' is not known to scripthistory.",
                file=path,
                extra={"path": args.path},
            )
        lint_path = args.path
        issues = _lint_script(lint_path, script)
    else:
        for p, s in scripts.items():
            issues.extend(_lint_script(p, s))

    print(
        json.dumps(
            attach_governance_hint(
                {
                    "ok": True,
                    "action": "lint",
                    "file": str(path),
                    "path": lint_path,
                    "issue_count": len(issues),
                    "issues": issues,
                }
            )
        )
    )


