def cmd_list_scripts(args: argparse.Namespace) -> None:
    """List all scripts that have history entries."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    store = load_store(path)
    scripts: List[Dict[str, Any]] = []
    search = str(getattr(args, "search", "") or "").strip().lower()
    for p, s in sorted(store.get("scripts", {}).items(), key=lambda item: item[0]):
        item = {
            "path": p,
            "created_at": s.get("created_at"),
            "updated_at": s.get("updated_at"),
            "description": s.get("description"),
            "event_count": len(s.get("events", [])),
        }
        if search:
            hay = " ".join([str(item.get("path") or ""), str(item.get("description") or "")]).lower()
            if search not in hay:
                continue
        scripts.append(item)
    limit = int(getattr(args, "limit", 0) or 0)
    if limit > 0 and len(scripts) > limit:
        scripts = scripts[:limit]
    print(
        json.dumps(
            attach_governance_hint(
                {
                    "ok": True,
                    "action": "list-scripts",
                    "file": str(path),
                    "scripts": scripts,
                    "count": len(scripts),
                    "search": search or None,
                    "limit": limit if limit > 0 else None,
                }
            )
        )
    )


def cmd_overview(args: argparse.Namespace) -> None:
    """Return compact store-wide summary for fast agent orientation."""
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    store = load_store(path)
    scripts = store.get("scripts", {}) or {}

    total_events = 0
    by_event_type: Dict[str, int] = {}
    top_by_events: List[Dict[str, Any]] = []
    open_investigation = 0
    for script_path, script in scripts.items():
        events = script.get("events", []) or []
        event_count = len(events)
        total_events += event_count
        for event in events:
            event_type = str(event.get("type") or "unknown")
            by_event_type[event_type] = int(by_event_type.get(event_type, 0)) + 1
        issues = _lint_script(str(script_path), script if isinstance(script, dict) else {})
        if any(str(issue.get("code") or "") == "open_investigation" for issue in issues if isinstance(issue, dict)):
            open_investigation += 1
        top_by_events.append(
            {
                "path": str(script_path),
                "event_count": event_count,
                "updated_at": script.get("updated_at"),
                "description": script.get("description"),
            }
        )

    top_by_events.sort(key=lambda item: (-int(item.get("event_count") or 0), str(item.get("path") or "")))
    sample_limit = max(1, min(int(getattr(args, "sample_limit", 12) or 12), 100))

    print(
        json.dumps(
            attach_governance_hint(
                {
                    "ok": True,
                    "action": "overview",
                    "file": str(path),
                    "summary": {
                        "script_count": len(scripts),
                        "event_count": total_events,
                        "counts_by_event_type": by_event_type,
                        "open_investigation_scripts": open_investigation,
                    },
                    "top_scripts": top_by_events[:sample_limit],
                    "recommended_next_calls": [
                        "scripthistory list-scripts --limit 30",
                        "scripthistory explain --path <repo_relative_path>",
                        "scripthistory lint --path <repo_relative_path>",
                    ],
                }
            )
