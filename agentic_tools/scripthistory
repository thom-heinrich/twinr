def main(argv: Optional[List[str]] = None) -> None:
    """Entry point for the CLI."""
    configure_logging()
    parser = build_parser()
    args: Optional[argparse.Namespace] = None
    try:
        args = parser.parse_args(argv)
        handler = getattr(args, "func", None)
        handler_name = getattr(handler, "__name__", "")
        if handler_name in _MUTATING_SCRIPTHISTORY_HANDLERS:
            _run_scripthistory_mutation_with_retry(handler_name.replace("cmd_", ""), lambda: handler(args))
        else:
            handler(args)
    except FileLockTimeout as exc:
        emit_error(
            error="lock_timeout",
            detail=str(exc),
            file=Path(getattr(args, "file", SCRIPTHISTORY_DEFAULT_FILENAME)),
        )
    except SystemExit:
        raise
    except Exception as exc:
        logging.exception("Unhandled scripthistory exception")
        file_arg = getattr(args, "file", SCRIPTHISTORY_DEFAULT_FILENAME) if args else None
        emit_error(
            error="internal_error",
            detail=str(exc),
            file=Path(file_arg) if file_arg else None,
        )


if __name__ == "__main__":
    main()
