def _locate_script_entry(
    store: Dict[str, Any], canonical_path: str
) -> Optional[Tuple[str, Dict[str, Any]]]:
    """Return (stored_path, script) for a canonical path, if present."""
    scripts = store.get("scripts", {}) or {}
    direct = scripts.get(canonical_path)
    if direct is not None:
        return canonical_path, direct
    for path_key, script in scripts.items():
        if path_key == canonical_path:
            continue
        if canonicalize_script_path(path_key) == canonical_path:
            return path_key, script
    return None


def _ensure_script(
    store: Dict[str, Any],
    path_str: str,
    create_if_missing: bool,
) -> Dict[str, Any]:
    """Get or optionally create a script entry."""
    canonical_path = canonicalize_script_path(path_str)
    scripts = store.get("scripts", {}) or {}
    located = _locate_script_entry(store, canonical_path)
    if located:
        existing_path, script = located
        # Migrate alias to canonical key to avoid fragmentation.
        if existing_path != canonical_path:
            scripts.pop(existing_path, None)
            script["path"] = canonical_path
            scripts[canonical_path] = script
            store["scripts"] = scripts
        return script

    if not create_if_missing:
        emit_error(
            error="unknown_script",
            detail=(
                f"Script '{canonical_path}' is not known to scripthistory. "
                "Use 'init-script' first."
            ),
            extra={"path": canonical_path},
        )
    now = now_iso()
    script = {
        "path": canonical_path,
        "created_at": now,
        "updated_at": now,
        "description": None,
        "metadata": {},
        "events": [],
    }
    scripts[canonical_path] = script
    store["scripts"] = scripts
    return script


def _maybe_dedupe_event(
    script: Dict[str, Any],
    event_type: str,
    comment: str,
    agent: Optional[str],
    metadata: Dict[str, Any],
    links: List[str],
    now_epoch: float,
) -> Tuple[Optional[Dict[str, Any]], bool]:
    """Check whether a new event would be a duplicate of the last one.

    Returns (event, True) if a duplicate should be reused, (None, False) otherwise.
    """
    if not SCRIPTHISTORY_DEDUP_ENABLE:
        return None, False

    events = script.get("events", []) or []
    if not events:
        return None, False

    last = events[-1]
    if last.get("type") != event_type:
        return None, False
    if (last.get("comment") or "") != (comment or ""):
        return None, False
    if (last.get("agent") or None) != (agent or None):
        return None, False
    if (last.get("metadata") or {}) != (metadata or {}):
        return None, False
    if (last.get("links") or []) != (links or []):
        return None, False

    last_ts = last.get("created_at")
    last_epoch = parse_iso_utc(last_ts) if isinstance(last_ts, str) else None
    if last_epoch is None:
        return None, False

    if abs(now_epoch - last_epoch) <= SCRIPTHISTORY_DEDUP_WINDOW_SECONDS:
        # Treat as duplicate.
        return last, True

    return None, False


def _append_event(
    store: Dict[str, Any],
    script: Dict[str, Any],
    event_type: str,
    comment: str,
    agent: Optional[str],
    metadata: Dict[str, Any],
    links: List[str],
) -> Tuple[Dict[str, Any], bool]:
    """Append an event to a script and update store timestamps.

    Returns (event, changed_bool). If changed_bool is False, the event is a
    deduped re-use of the last event and the store MUST NOT be rewritten.
    """
    now_str = now_iso()
    now_epoch = parse_iso_utc(now_str) or time.time()

    # Dedupe identical back-to-back events within a short time window.
    reused, is_dup = _maybe_dedupe_event(
        script, event_type, comment, agent, metadata, links, now_epoch
    )
    if is_dup and reused is not None:
        logging.info(
            "Deduplicated %s event for script '%s' (reusing id=%s).",
            event_type,
            script.get("path"),
            reused.get("id"),
        )
        return reused, False

    event_id = generate_event_id(store)
    event = {
        "id": event_id,
        "type": event_type,
        "comment": comment,
        "agent": agent,
        "created_at": now_str,
        "metadata": metadata,
    }
    if links:
        event["links"] = links
    script.setdefault("events", []).append(event)
    script["updated_at"] = now_str
    return event, True


def cmd_init_script(args: argparse.Namespace) -> None:
    """
    Initialize history for a script.

    Semantics
    ---------
    - If the script does not yet exist in the store, a new script entry is
      created and a single 'init-script' event is appended.
    - If the script already exists and already has an init-script event, this
      command is idempotent: it returns ok=true with status='exists' and the
      existing script plus recent events, without creating a second init event.
    - If the script already exists but is missing an init-script event (e.g.
      created via --auto-init on other commands), this command backfills a single
      init-script event to restore invariants.
    """
    path = resolve_repo_path(args.file, repo_root=REPO_ROOT)
    ensure_parent_dir(path)
    lock = FileLock(path.with_suffix(path.suffix + ".lock"))
    metadata = parse_json_arg(args.data, "--data")
    links = normalize_links(getattr(args, "links", None))
    inferred_links = extract_link_tokens_from_texts([args.comment or ""])
    links = _merge_links(links, inferred_links)
    canonical_path = canonicalize_script_path(args.path)

    has_init = False
    existing: Optional[Dict[str, Any]] = None
    with lock:
        store = load_store(path)
        located = _locate_script_entry(store, canonical_path)
        existing = located[1] if located else None
        if existing is not None:
            has_init = any(
                (e.get("type") == "init-script")
                for e in (existing.get("events", []) or [])
                if isinstance(e, dict)
            )
            if has_init:
                recent_events = recent_events_for_script(existing, limit=10)
                print(
                    json.dumps(
                        attach_governance_hint(
                            {
                                "ok": True,
                                "action": "init-script",
                                "status": "exists",
                                "file": str(path),
                                "script": script_to_public(existing),
                                "recent_events": recent_events,
                                "recent_count": len(recent_events),
                                "recent_limit": 10,
                            }
                        )
                    )
                )
                return
            script = existing
        else:
            script = _ensure_script(store, canonical_path, create_if_missing=True)

        # Set or update description/metadata.
        now = now_iso()
        if args.comment and not script.get("description"):
            script["description"] = args.comment
        if metadata:
            merged = dict(script.get("metadata", {}))
            merged.update(metadata)
            script["metadata"] = merged
        script["updated_at"] = now

        # Append (or backfill) an init-script event.
        init_comment = args.comment or "Initialize script history."
        event, changed = _append_event(
            store,
            script,
            event_type="init-script",
            comment=init_comment,
            agent=args.agent,
            metadata=metadata,
            links=links,
        )
        if changed:
            save_store(path, store)
        else:
            logging.info(
                "Init-script dedupe triggered for '%s'; store not rewritten.", args.path
            )

    out: Dict[str, Any] = {
        "ok": True,
        "action": "init-script",
        "file": str(path),
        "script": script_to_public(script),
        "event": event_to_public(event),
    }
    if existing is not None and not has_init:
        out["status"] = "backfilled"
    print(json.dumps(attach_governance_hint(out)))


